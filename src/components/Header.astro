---
import { Icon } from 'astro-icon/components';
---
<!-- Announcement Bar -->
<div class="announcement-bar">
  <span data-i18n="announce">🎉 เปิดให้บริการสาขาใหม่ รพ.เมดิไทย เชียงใหม่ แล้ววันนี้ &nbsp;<a href="/locations">ดูรายละเอียด →</a></span>
  <button class="announcement-close" aria-label="Close"><Icon name="fa6-solid:xmark" /></button>
</div>

<!-- Header -->
<header class="header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-icon"><Icon name="fa6-solid:hospital" /></div>
      <div class="logo-text">
        <div class="logo-name" data-i18n="logo_name">MediThai</div>
        <div class="logo-sub" data-i18n="logo_sub">เครือโรงพยาบาล</div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav">
      <div class="nav-item">
        <a href="/" class="nav-link" data-i18n="nav_home">หน้าแรก</a>
      </div>
      <div class="nav-item">
        <a href="#" class="nav-link" data-i18n="nav_hospitals">โรงพยาบาล <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/hospitals/medithai-bangkok"><Icon name="fa6-solid:building-columns" /><span data-i18n="dd_bkk">MediThai กรุงเทพ</span></a>
          <a href="/hospitals/medithai-heart"><Icon name="fa6-solid:heart-pulse" /><span data-i18n="dd_heart">MediThai หัวใจ</span></a>
          <a href="/hospitals/medithai-cancer"><Icon name="fa6-solid:ribbon" /><span data-i18n="dd_cancer">MediThai มะเร็ง</span></a>
          <a href="/hospitals/medithai-spine"><Icon name="fa6-solid:brain" /><span data-i18n="dd_spine">MediThai สมองและกระดูก</span></a>
          <a href="/hospitals/medithai-children"><Icon name="fa6-solid:child" /><span data-i18n="dd_kids">MediThai เด็ก</span></a>
          <a href="/hospitals/medithai-chiangmai"><Icon name="fa6-solid:mountain" /><span data-i18n="dd_chiang">MediThai เชียงใหม่</span></a>
        </div>
      </div>
      <div class="nav-item">
        <a href="#" class="nav-link" data-i18n="nav_services">บริการ <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/appointments"><Icon name="fa6-solid:calendar-check" /><span data-i18n="dd_appt">นัดหมายแพทย์</span></a>
          <a href="/appointments#virtual"><Icon name="fa6-solid:video" /><span data-i18n="dd_virtual">Virtual Visit</span></a>
          <a href="/appointments#second"><Icon name="fa6-solid:magnifying-glass-plus" /><span data-i18n="dd_second">Second Opinion</span></a>
          <a href="#"><Icon name="fa6-solid:file-medical" /><span data-i18n="dd_records">เวชระเบียน</span></a>
          <a href="#"><Icon name="fa6-solid:receipt" /><span data-i18n="dd_billing">ตรวจสอบค่าบริการ</span></a>
          <a href="#"><Icon name="fa6-solid:shield-halved" /><span data-i18n="dd_insurance">ประกันสุขภาพ</span></a>
        </div>
      </div>
      <div class="nav-item">
        <a href="/doctors" class="nav-link" data-i18n="nav_doctors">แพทย์</a>
      </div>
      <div class="nav-item">
        <a href="/packages" class="nav-link" data-i18n="nav_packages">แพ็กเกจ</a>
      </div>
      <div class="nav-item">
        <a href="/health-library" class="nav-link" data-i18n="nav_library">คลังความรู้</a>
      </div>
      <div class="nav-item">
        <a href="/about" class="nav-link" data-i18n="nav_about">เกี่ยวกับเรา</a>
      </div>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <div class="lang-toggle">
        <button class="lang-btn active" data-lang="th">TH</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="nav_appt">นัดหมาย</a>
    </div>

    <button class="mobile-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Nav -->
<nav class="mobile-nav">
  <a href="/" data-i18n="nav_home">หน้าแรก <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/locations" data-i18n="nav_hospitals">โรงพยาบาล <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/appointments" data-i18n="nav_services">บริการ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/doctors" data-i18n="nav_doctors">แพทย์ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/packages" data-i18n="nav_packages">แพ็กเกจ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/health-library" data-i18n="nav_library">คลังความรู้ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/about" data-i18n="nav_about">เกี่ยวกับเรา <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/contact" style="margin-top:12px;background:var(--primary);color:#fff;padding:14px;border-radius:12px;justify-content:center" data-i18n="nav_appt">นัดหมายออนไลน์</a>
</nav>
