---
import { Icon } from 'astro-icon/components';
---
<!-- Announcement Bar -->
<div class="announcement-bar">
  <span data-i18n="announce">🎉 เปิดให้บริการสาขาใหม่ รพ.เมดิไทย เชียงใหม่ แล้ววันนี้ &nbsp;<a href="/locations">ดูรายละเอียด →</a></span>
  <button class="announcement-close" aria-label="Close"><Icon name="fa6-solid:xmark" /></button>
</div>

<!-- Header -->
<header class="header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-icon"><Icon name="fa6-solid:hospital" /></div>
      <div class="logo-text">
        <div class="logo-name" data-i18n="logo_name">MediThai</div>
        <div class="logo-sub" data-i18n="logo_sub">เครือโรงพยาบาล</div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav">
      <div class="nav-item" data-nav-id="home">
        <a href="/" class="nav-link" data-i18n="nav_home">หน้าแรก</a>
      </div>
      <div class="nav-item" data-nav-id="hospitals">
        <a href="#" class="nav-link" data-i18n="nav_hospitals">โรงพยาบาล <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/hospitals/medithai-bangkok" data-nav-id="h-bkk"><Icon name="fa6-solid:building-columns" /><span data-i18n="dd_bkk">MediThai กรุงเทพ</span></a>
          <a href="/hospitals/medithai-heart" data-nav-id="h-heart"><Icon name="fa6-solid:heart-pulse" /><span data-i18n="dd_heart">MediThai หัวใจ</span></a>
          <a href="/hospitals/medithai-cancer" data-nav-id="h-cancer"><Icon name="fa6-solid:ribbon" /><span data-i18n="dd_cancer">MediThai มะเร็ง</span></a>
          <a href="/hospitals/medithai-spine" data-nav-id="h-spine"><Icon name="fa6-solid:brain" /><span data-i18n="dd_spine">MediThai สมองและกระดูก</span></a>
          <a href="/hospitals/medithai-children" data-nav-id="h-child"><Icon name="fa6-solid:child" /><span data-i18n="dd_kids">MediThai เด็ก</span></a>
          <a href="/hospitals/medithai-chiangmai" data-nav-id="h-cm"><Icon name="fa6-solid:mountain" /><span data-i18n="dd_chiang">MediThai เชียงใหม่</span></a>
        </div>
      </div>
      <div class="nav-item" data-nav-id="services">
        <a href="#" class="nav-link">บริการ <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/appointments" data-nav-id="s-appt"><Icon name="fa6-solid:calendar-check" /><span>นัดหมายแพทย์</span></a>
          <a href="/telehealth" data-nav-id="s-tele"><Icon name="fa6-solid:video" /><span>พบแพทย์ออนไลน์</span></a>
          <a href="/symptoms" data-nav-id="s-sym"><Icon name="fa6-solid:stethoscope" /><span>ตรวจสอบอาการ</span></a>
          <a href="/medical-records" data-nav-id="s-rec"><Icon name="fa6-solid:file-medical" /><span>ขอเวชระเบียน</span></a>
          <a href="/bill-payment" data-nav-id="s-bill"><Icon name="fa6-solid:receipt" /><span>ชำระค่าบริการ</span></a>
          <a href="/executive-health" data-nav-id="s-exec"><Icon name="fa6-solid:star" /><span>Executive Health</span></a>
        </div>
      </div>
      <div class="nav-item" data-nav-id="doctors">
        <a href="/doctors" class="nav-link">แพทย์</a>
      </div>
      <div class="nav-item" data-nav-id="packages">
        <a href="#" class="nav-link">แพ็กเกจ <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/packages" data-nav-id="p-pkg"><Icon name="fa6-solid:box-open" /><span>แพ็กเกจสุขภาพ</span></a>
          <a href="/executive-health" data-nav-id="p-exec"><Icon name="fa6-solid:star" /><span>Executive Health</span></a>
          <a href="/loyalty" data-nav-id="p-card"><Icon name="fa6-solid:id-card" /><span>MediThai Card</span></a>
          <a href="/corporate" data-nav-id="p-corp"><Icon name="fa6-solid:building" /><span>บริการองค์กร</span></a>
        </div>
      </div>
      <div class="nav-item" data-nav-id="health">
        <a href="#" class="nav-link">ข้อมูลสุขภาพ <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/health-library" data-nav-id="hl-lib"><Icon name="fa6-solid:book-medical" /><span>คลังความรู้</span></a>
          <a href="/symptoms" data-nav-id="hl-sym"><Icon name="fa6-solid:stethoscope" /><span>ตรวจสอบอาการ</span></a>
          <a href="/calculators" data-nav-id="hl-calc"><Icon name="fa6-solid:calculator" /><span>โปรแกรมคำนวณสุขภาพ</span></a>
          <a href="/patient-stories" data-nav-id="hl-story"><Icon name="fa6-solid:heart" /><span>เรื่องราวผู้ป่วย</span></a>
        </div>
      </div>
      <div class="nav-item" data-nav-id="about">
        <a href="#" class="nav-link">เกี่ยวกับ <Icon name="fa6-solid:chevron-down" /></a>
        <div class="dropdown">
          <a href="/about" data-nav-id="a-about"><Icon name="fa6-solid:circle-info" /><span>เกี่ยวกับเรา</span></a>
          <a href="/expat-hub" data-nav-id="a-expat"><Icon name="fa6-solid:globe" /><span>Expat Hub</span></a>
          <a href="/careers" data-nav-id="a-career"><Icon name="fa6-solid:briefcase" /><span>ร่วมงานกับเรา</span></a>
          <a href="/giving" data-nav-id="a-give"><Icon name="fa6-solid:hand-holding-heart" /><span>ร่วมสนับสนุน</span></a>
        </div>
      </div>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <div class="lang-toggle">
        <button class="lang-btn active" data-lang="th">TH</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <!-- Auth state: shown/hidden by client-side JS -->
      <div id="header-auth" style="display:flex;align-items:center;gap:8px">
        <a href="/login" id="header-login-btn" class="btn btn-outline btn-sm">เข้าสู่ระบบ</a>
        <div id="header-user-menu" class="user-menu" style="display:none">
          <a href="/dashboard" class="btn btn-outline btn-sm">แดชบอร์ด</a>
          <form method="POST" action="/logout" style="display:inline">
            <button type="submit" class="btn btn-ghost btn-sm">ออก</button>
          </form>
        </div>
      </div>
      <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="nav_appt">นัดหมาย</a>
    </div>

    <button class="mobile-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Nav -->
<nav class="mobile-nav">
  <a href="/">หน้าแรก <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/locations">โรงพยาบาล <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/appointments">นัดหมาย <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/telehealth">พบแพทย์ออนไลน์ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/doctors">แพทย์ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/packages">แพ็กเกจ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/executive-health">Executive Health <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/loyalty">MediThai Card <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/health-library">คลังความรู้ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/symptoms">ตรวจสอบอาการ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/calculators">โปรแกรมคำนวณสุขภาพ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/patient-stories">เรื่องราวผู้ป่วย <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/expat-hub">Expat Hub <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/corporate">บริการองค์กร <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/careers">ร่วมงานกับเรา <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/bill-payment">ชำระค่าบริการ <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/giving">ร่วมสนับสนุน <Icon name="fa6-solid:arrow-right" /></a>
  <a href="/contact" style="margin-top:12px;background:var(--primary);color:#fff;padding:14px;border-radius:12px;justify-content:center">นัดหมายออนไลน์</a>
</nav>

<script>
  // Client-side auth state for header
  (async () => {
    try {
      const { createBrowserClient } = await import('@supabase/ssr');
      const supabase = createBrowserClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
      );
      const { data: { user } } = await supabase.auth.getUser();
      const loginBtn = document.getElementById('header-login-btn');
      const userMenu = document.getElementById('header-user-menu');
      if (user && loginBtn && userMenu) {
        loginBtn.style.display = 'none';
        userMenu.style.display = 'flex';
      }
    } catch {}
  })();
</script>
