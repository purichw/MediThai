---
import Layout from '../../components/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout
  title="MediThai หัวใจ | เครือโรงพยาบาล MediThai"
  description="ศูนย์โรคหัวใจและหลอดเลือดระดับโลก ทีมแพทย์เฉพาะทาง 35+ ท่าน"
  extraScripts={`
    <script src="/js/hospital-page.js"></script>
    <script>initHospitalPage({id:'heart'});</script>
  `}
>

<section class="hosp-hero" style="background:linear-gradient(135deg,#7F1D1D 0%,#991B1B 50%,#EF4444 100%)">
  <div class="container">
    <div class="breadcrumb" style="margin-bottom:20px"><a href="/" style="color:rgba(255,255,255,.6)">หน้าแรก</a><Icon name="fa6-solid:chevron-right" style="color:rgba(255,255,255,.4)" /><a href="/locations" style="color:rgba(255,255,255,.6)">โรงพยาบาล</a><Icon name="fa6-solid:chevron-right" style="color:rgba(255,255,255,.4)" /><span style="color:#fff">MediThai หัวใจ</span></div>
    <div class="hosp-hero-inner">
      <div>
        <div class="hosp-badge"><Icon name="fa6-solid:heart-pulse" /> โรงพยาบาลเฉพาะทางโรคหัวใจ</div>
        <h1 class="hosp-title">MediThai หัวใจ</h1>
        <p class="hosp-desc">ศูนย์โรคหัวใจและหลอดเลือดระดับโลก ทีมแพทย์เฉพาะทาง 35+ ท่าน พร้อม Cardiac Cath Lab 4 ห้อง เทคโนโลยี MitraClip และ MICS ล่าสุด</p>
        <div class="hosp-accred-row"><span class="hosp-accred-chip"><Icon name="fa6-solid:certificate" /> JCI</span><span class="hosp-accred-chip"><Icon name="fa6-solid:award" /> HA Thailand</span><span class="hosp-accred-chip">🏆 Best Cardiac Hospital</span></div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:20px">
          <a href="/appointments" class="btn btn-primary btn-lg"><Icon name="fa6-solid:calendar-check" /> นัดหมาย</a>
          <a href="/concierge" class="btn btn-secondary btn-lg"><Icon name="fa6-solid:user-nurse" /> Surgery Concierge</a>
        </div>
      </div>
      <div class="hosp-quick-stats">
        <div class="hosp-qstat"><div class="num">35+</div><div class="lbl">แพทย์หัวใจ</div></div>
        <div class="hosp-qstat"><div class="num">4</div><div class="lbl">Cath Lab</div></div>
        <div class="hosp-qstat"><div class="num">200</div><div class="lbl">เตียง</div></div>
        <div class="hosp-qstat"><div class="num" style="color:#FCA5A5">4.9 ⭐</div><div class="lbl">Rating</div></div>
      </div>
    </div>
    <div style="margin-top:24px">
      <div style="font-size:.75rem;color:rgba(255,255,255,.5);margin-bottom:8px"><Icon name="fa6-solid:train-subway" style="margin-right:4px" />การเดินทาง</div>
      <div class="transit-badges">
        <span class="transit-badge bts"><Icon name="fa6-solid:train" /> BTS ช่องนนทรี 300ม.</span>
        <span class="transit-badge mrt"><Icon name="fa6-solid:train-subway" /> MRT สีลม 500ม.</span>
      </div>
    </div>
  </div>
</section>

<section style="background:var(--gray-50);padding:56px 0">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:28px">
      <div><div class="tag"><Icon name="fa6-solid:tag" /> แพ็กเกจ</div><h2 class="section-heading" style="margin-bottom:0">แพ็กเกจจาก MediThai หัวใจ</h2></div>
      <a href="/packages" class="view-all-link">ดูทั้งหมด <Icon name="fa6-solid:arrow-right" /></a>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px">
      <button class="tab-btn active hosp-tab" data-cat="all">ทั้งหมด</button>
      <button class="tab-btn hosp-tab" data-cat="heart">ตรวจหัวใจ</button>
      <button class="tab-btn hosp-tab" data-cat="surgery">ผ่าตัด</button>
    </div>
    <div class="pkg-grid">
      <div class="pkg-card" data-cat="heart"><div class="pkg-thumb" style="background:linear-gradient(135deg,#EF4444,#DC2626)"><Icon name="fa6-solid:heart-pulse" /><div class="pkg-discount-badge">-40%</div><div class="pkg-trust-chips"><span class="trust-chip bestseller">ขายดี</span></div></div><div class="pkg-hospital-bar"><div class="pkg-hospital-dot" style="background:#EF4444"></div>MediThai หัวใจ</div><div class="pkg-card-body"><div class="pkg-card-title">3 โปรแกรมตรวจหัวใจ ออกแบบเพื่อคุณโดยเฉพาะ</div><ul class="pkg-includes"><li><Icon name="fa6-solid:check" />EKG + Echocardiogram</li><li><Icon name="fa6-solid:check" />Exercise Stress Test</li><li><Icon name="fa6-solid:check" />Coronary CT Angiography</li></ul><div class="pkg-rating"><div class="stars"><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star-half-stroke" /></div><span class="rating-score">4.8</span><span class="rating-count">(203)</span></div><div class="pkg-price-block"><div class="pkg-price-row"><span class="pkg-price-now">฿7,500</span><span class="pkg-price-was">฿12,500</span></div><div class="pkg-installment"><Icon name="fa6-solid:credit-card" />ผ่อน 0% 3 เดือน</div><div class="pkg-cta-row"><a href="/packages" class="btn btn-outline btn-sm">รายละเอียด</a><a href="/appointments" class="btn btn-primary btn-sm">ซื้อเลย</a></div></div></div></div>
      <div class="pkg-card" data-cat="surgery"><div class="pkg-thumb" style="background:linear-gradient(135deg,#F59E0B,#D97706)"><Icon name="fa6-solid:heart" /><div class="pkg-discount-badge">-30%</div><div class="pkg-trust-chips"><span class="trust-chip limited">จำนวนจำกัด</span></div></div><div class="pkg-hospital-bar"><div class="pkg-hospital-dot" style="background:#EF4444"></div>MediThai หัวใจ</div><div class="pkg-card-body"><div class="pkg-card-title">แพ็กเกจสวนหัวใจและผ่าตัดหัวใจ ราคาพิเศษ</div><ul class="pkg-includes"><li><Icon name="fa6-solid:check" />Cardiac Catheterization</li><li><Icon name="fa6-solid:check" />PTCA / Stent</li><li><Icon name="fa6-solid:check" />มีพยาบาลดูแลตลอด</li></ul><div class="pkg-rating"><div class="stars"><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star" /><Icon name="fa6-solid:star-half-stroke" /></div><span class="rating-score">4.9</span><span class="rating-count">(56)</span></div><div class="pkg-price-block"><div class="pkg-price-row"><span class="pkg-price-now">฿54,000</span><span class="pkg-price-was">฿78,000</span></div><div class="pkg-installment"><Icon name="fa6-solid:credit-card" />ผ่อน 0% 10 เดือน</div><div class="pkg-cta-row"><a href="/concierge" class="btn btn-outline btn-sm">ปรึกษาทีม</a><a href="/appointments" class="btn btn-primary btn-sm">จองเลย</a></div></div></div></div>
    </div>
  </div>
</section>

<section style="background:#fff;padding:56px 0">
  <div class="container">
    <h2 class="section-heading reveal">แพทย์เฉพาะทางหัวใจ</h2>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:28px">
      <div class="doctor-card reveal"><div class="doctor-photo"><div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#FFF1F2,#FFE4E6)"><Icon name="fa6-solid:user-doctor" style="color:#EF4444" /></div><div class="doctor-specialty-badge" style="background:#EF4444">ศูนย์หัวใจ</div></div><div class="doctor-name">นพ. ชาติทนง ยอดวุฒิ</div><div class="doctor-title">อายุรแพทย์โรคหัวใจ</div><div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div><div class="doctor-tags"><span class="doctor-tag">MitraClip</span><span class="doctor-tag">EP</span></div><a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px">นัดหมาย</a></div>
      <div class="doctor-card reveal reveal-delay-1"><div class="doctor-photo"><div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#FFF1F2,#FFE4E6)"><Icon name="fa6-solid:user-doctor" style="color:#EF4444" /></div><div class="doctor-specialty-badge" style="background:#EF4444">ผ่าตัดหัวใจ</div></div><div class="doctor-name">นพ. ณัฐพล อารยวุฒิกุล</div><div class="doctor-title">ศัลยแพทย์หัวใจ</div><div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div><div class="doctor-tags"><span class="doctor-tag">MICS</span><span class="doctor-tag">Open Heart</span></div><a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px">นัดหมาย</a></div>
      <div class="doctor-card reveal reveal-delay-2"><div class="doctor-photo"><div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#FFF1F2,#FFE4E6)"><Icon name="fa6-solid:user-doctor" style="color:#EF4444" /></div><div class="doctor-specialty-badge" style="background:#EF4444">Interventional</div></div><div class="doctor-name">นพ. ธีระ วงศ์สุนทร</div><div class="doctor-title">อินเตอร์เวนชันแพทย์หัวใจ</div><div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div><div class="doctor-tags"><span class="doctor-tag">PTCA</span><span class="doctor-tag">Stent</span></div><a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px">นัดหมาย</a></div>
      <div class="doctor-card reveal reveal-delay-3"><div class="doctor-photo"><div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#FFF1F2,#FFE4E6)"><Icon name="fa6-solid:user-doctor" style="color:#EF4444" /></div><div class="doctor-specialty-badge" style="background:#EF4444">Heart Failure</div></div><div class="doctor-name">พญ. ลภัสรดา มณีแดง</div><div class="doctor-title">อายุรแพทย์หัวใจล้มเหลว</div><div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div><div class="doctor-tags"><span class="doctor-tag">Heart Failure</span><span class="doctor-tag">Rehab</span></div><a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px">นัดหมาย</a></div>
    </div>
    <div class="text-center" style="margin-top:28px"><a href="/doctors" class="view-all-link">ดูแพทย์ทั้งหมด <Icon name="fa6-solid:arrow-right" /></a></div>
  </div>
</section>

<section style="background:var(--gray-50);padding:48px 0">
  <div class="container">
    <div class="contact-info-item"><div class="contact-icon"><Icon name="fa6-solid:location-dot" /></div><div><h4>ที่อยู่</h4><p>1 ซอยสาทร 15 ถนนสาทรใต้ แขวงยานนาวา สาทร กรุงเทพ 10120</p></div></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px">
      <a href="/appointments" class="btn btn-primary"><Icon name="fa6-solid:calendar-check" /> นัดหมาย</a>
      <a href="tel:023103100" class="btn btn-outline"><Icon name="fa6-solid:phone" /> 02-310-3100</a>
    </div>
  </div>
</section>

</Layout>
