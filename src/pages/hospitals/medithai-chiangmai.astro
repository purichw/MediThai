---
import Layout from '../../components/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout
  title="MediThai เชียงใหม่ | เครือโรงพยาบาล MediThai"
  description="โรงพยาบาลล่าสุดในเครือ รองรับผู้ป่วยนานาชาติ Medical Tourism"
  extraScripts={`
    <script src="/js/hospital-page.js"></script>
    <script>initHospitalPage({id:'chiangmai'});</script>
  `}
>

<section class="hosp-hero" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%)">
  <div class="container">
    <div class="breadcrumb" style="margin-bottom:20px"><a href="/" style="color:rgba(255,255,255,.6)">หน้าแรก</a><Icon name="fa6-solid:chevron-right" style="color:rgba(255,255,255,.4)" /><a href="/locations" style="color:rgba(255,255,255,.6)">โรงพยาบาล</a><Icon name="fa6-solid:chevron-right" style="color:rgba(255,255,255,.4)" /><span style="color:#fff">MediThai เชียงใหม่</span></div>
    <div class="hosp-hero-inner">
      <div>
        <div class="hosp-badge"><Icon name="fa6-solid:mountain-city" /> สาขาใหม่ ภาคเหนือ ✨</div>
        <h1 class="hosp-title">MediThai เชียงใหม่</h1>
        <p class="hosp-desc">โรงพยาบาลล่าสุดในเครือ รองรับผู้ป่วยนานาชาติ Medical Tourism ทีมแพทย์ 6 ภาษา ไทย อังกฤษ จีน ญี่ปุ่น เกาหลี อาหรับ</p>
        <div class="hosp-accred-row"><span class="hosp-accred-chip"><Icon name="fa6-solid:certificate" /> JCI</span><span class="hosp-accred-chip"><Icon name="fa6-solid:award" /> HA Thailand</span></div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:20px">
          <a href="/appointments" class="btn btn-primary btn-lg"><Icon name="fa6-solid:calendar-check" /> นัดหมาย</a>
          <a href="tel:0533103000" class="btn btn-secondary btn-lg"><Icon name="fa6-solid:phone" /> 053-310-3000</a>
        </div>
      </div>
      <div class="hosp-quick-stats">
        <div class="hosp-qstat"><div class="num">50+</div><div class="lbl">แพทย์</div></div>
        <div class="hosp-qstat"><div class="num" style="color:#FDE68A">4.8 ⭐</div><div class="lbl">Rating</div></div>
      </div>
    </div>
    <div style="margin-top:24px"><div style="font-size:.75rem;color:rgba(255,255,255,.5);margin-bottom:8px"><Icon name="fa6-solid:train-subway" style="margin-right:4px" />การเดินทาง</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <span style="background:rgba(255,255,255,.15);color:#fff;font-size:.75rem;font-weight:600;padding:5px 12px;border-radius:8px"><Icon name="fa6-solid:route" style="margin-right:4px" />รถสองแถว / รถตู้สาธารณะ</span>
      <span style="background:rgba(255,255,255,.15);color:#fff;font-size:.75rem;font-weight:600;padding:5px 12px;border-radius:8px"><Icon name="fa6-solid:route" style="margin-right:4px" />Grab ใช้งานได้</span>
    </div></div>
  </div>
</section>

<section style="background:var(--gray-50);padding:32px 0">
  <div class="container">
    <div class="contact-info-item"><div class="contact-icon" style="background:rgba(8,145,178,.1);color:#F59E0B"><Icon name="fa6-solid:phone" /></div><div><h4>ติดต่อ MediThai เชียงใหม่</h4><p>053-310-3000</p></div></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px">
      <a href="/appointments" class="btn btn-primary"><Icon name="fa6-solid:calendar-check" /> นัดหมาย</a>
      <a href="/hospitals/medithai-bangkok" class="btn btn-outline"><Icon name="fa6-solid:building-columns" /> MediThai กรุงเทพ (HQ)</a>
    </div>
  </div>
</section>

</Layout>
