        <a href="/doctors/chayaphon-cheerathanom" class="btn btn-outline btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:6px">ดูโปรไฟล์</a>
        <a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px" data-i18n="doc_appt">นัดหมาย</a>
