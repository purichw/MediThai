        <div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div>
        <div class="doctor-tags"><span class="doctor-tag">MICS</span><span class="doctor-tag">Open Heart Surgery</span></div>
        <a href="/doctors/natthaphon-arayawuttikun" class="btn btn-outline btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:6px">ดูโปรไฟล์</a>
