---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getDoctorsFromDB } from '../lib/doctorsData';
import { loadPageCMS } from '../lib/cmsPage';

const doctors = await getDoctorsFromDB();
const { th, cmsScript } = await loadPageCMS('doctors', {
  pg_title: 'ค้นหาแพทย์',
  pg_desc: 'ทีมแพทย์เชี่ยวชาญกว่า 200 ท่าน พร้อมดูแลคุณ',
  pg_title_en: 'Find a Doctor',
  pg_desc_en: 'Our team of 200+ specialist doctors, ready to care for you',
});
---
<Layout title="ค้นหาแพทย์ | MediThai Hospital Network" description="ทีมแพทย์เชี่ยวชาญกว่า 200 ท่าน พร้อมดูแลคุณ"
  extraHead={`${cmsScript}
    <style>
    .doctors-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; }
    @media(max-width:1100px){ .doctors-grid{grid-template-columns:repeat(3,1fr);} }
    @media(max-width:768px) { .doctors-grid{grid-template-columns:repeat(2,1fr);} }
    @media(max-width:480px) { .doctors-grid{grid-template-columns:1fr;} }
    .no-results{ text-align:center; padding:80px 20px; color:var(--gray-400); }
    </style>
  `}
  extraScripts={`<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>`}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span data-i18n="nav_doctors">แพทย์</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
  </div>
</section>

<section class="section-pad-sm" style="background:var(--gray-50)">
  <div class="container">
    <div class="filter-bar">
      <div class="search-input-wrap">
        <Icon name="fa6-solid:magnifying-glass" />
        <input type="text" id="doctor-search" class="search-input" data-i18n-ph="search_ph" placeholder="ค้นหาแพทย์ ความเชี่ยวชาญ..." />
      </div>
      <select id="doc-spec-filter" class="filter-select" data-i18n-opt-default="filter_spec">
        <option value="">ทุกความเชี่ยวชาญ</option>
        <option value="heart" data-th="ศูนย์หัวใจ" data-en="Heart Center">ศูนย์หัวใจ</option>
        <option value="cancer" data-th="ศูนย์มะเร็ง" data-en="Cancer Center">ศูนย์มะเร็ง</option>
        <option value="neuro" data-th="ศูนย์สมองและระบบประสาท" data-en="Brain & Spine">ศูนย์สมองและระบบประสาท</option>
        <option value="ortho" data-th="ศูนย์กระดูกและข้อ" data-en="Orthopedics">ศูนย์กระดูกและข้อ</option>
        <option value="peds" data-th="ศูนย์เด็ก" data-en="Children's">ศูนย์เด็ก</option>
        <option value="obgyn" data-th="ศูนย์สตรี" data-en="Women's Health">ศูนย์สตรี</option>
        <option value="eye" data-th="ศูนย์ตา" data-en="Eye Center">ศูนย์ตา</option>
        <option value="internal" data-th="อายุรกรรม" data-en="Internal Medicine">อายุรกรรม</option>
      </select>
      <select id="doc-hosp-filter" class="filter-select" data-i18n-opt-default="filter_hosp">
        <option value="">ทุกสาขา</option>
        <option value="bkk">MediThai กรุงเทพ</option>
        <option value="heart">MediThai หัวใจ</option>
        <option value="cancer">MediThai มะเร็ง</option>
        <option value="spine">MediThai สมองและกระดูก</option>
        <option value="kids">MediThai เด็ก</option>
        <option value="chiang">MediThai เชียงใหม่</option>
      </select>
      <select class="filter-select" data-i18n-opt-default="filter_lang">
        <option value="">ภาษาที่พูด</option>
        <option value="th">ภาษาไทย / Thai</option>
        <option value="en">English</option>
        <option value="zh">中文</option>
        <option value="ja">日本語</option>
      </select>
    </div>

    <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:24px">
      แสดง <strong style="color:var(--primary)">{doctors.length}</strong> แพทย์จากทั้งหมด 200+ ท่าน
    </p>

    <div class="doctors-grid" id="doctors-grid">
      {doctors.map((doc, i) => {
        const specKey = doc.specialty.includes('หัวใจ') ? 'heart'
          : doc.specialty.includes('มะเร็ง') ? 'cancer'
          : (doc.specialty.includes('ประสาท') || doc.specialty.includes('สมอง')) ? 'neuro'
          : doc.specialty.includes('กระดูก') ? 'ortho'
          : doc.specialty.includes('เด็ก') ? 'peds'
          : (doc.specialty.includes('สตรี') || doc.specialty.includes('นรีเวช')) ? 'obgyn'
          : doc.specialty.includes('ตา') ? 'eye'
          : 'internal';
        const delay = i % 4 === 1 ? ' reveal-delay-1' : i % 4 === 2 ? ' reveal-delay-2' : i % 4 === 3 ? ' reveal-delay-3' : '';
        return (
          <div class={`doctor-card reveal${delay}`} data-specialty={specKey} data-hospital={doc.hospitalKey}>
            <div class="doctor-photo">
              <div class="doctor-photo-placeholder" style={`background:linear-gradient(135deg,${doc.color}18,${doc.color}30)`}>
                <Icon name="fa6-solid:user-doctor" style={`color:${doc.color}`} />
              </div>
              <div class="doctor-specialty-badge" style={`background:${doc.color}`}>{doc.specialty}</div>
            </div>
            <div class="doctor-name">{doc.nameTh}</div>
            <div class="doctor-title">{doc.titleTh}</div>
            <div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> {doc.hospital}</div>
            <div class="doctor-tags">{doc.tags.slice(0,3).map(t => <span class="doctor-tag">{t}</span>)}</div>
            <a href={`/doctors/${doc.id}`} class="btn btn-outline btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:6px">ดูโปรไฟล์</a>
            <a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:8px">นัดหมาย</a>
          </div>
        );
      })}
    </div>

    <div class="text-center" style="margin-top:48px">
      <button class="btn btn-outline btn-lg">
        <Icon name="fa6-solid:rotate" /> โหลดเพิ่มเติม (188 ท่าน)
      </button>
    </div>
  </div>
</section>

<section style="background:linear-gradient(135deg,var(--primary-dark),var(--primary));padding:72px 0;text-align:center">
  <div class="container">
    <h2 style="color:#fff;font-size:clamp(1.5rem,3vw,2rem);margin-bottom:12px">ไม่แน่ใจว่าควรพบแพทย์สาขาไหน?</h2>
    <p style="color:rgba(255,255,255,.75);margin-bottom:32px">ปรึกษาทีมงานของเราได้เลย เราพร้อมช่วยแนะนำ</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <a href="tel:1722" class="btn btn-white btn-lg"><Icon name="fa6-solid:phone" /> โทร 1722</a>
      <a href="/appointments" class="btn btn-primary btn-lg"><Icon name="fa6-solid:calendar-check" /> นัดหมายออนไลน์</a>
    </div>
  </div>
</section>

</Layout>
