        <div class="doctor-photo"><div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#FDF4FF,#F5D0FE)"><Icon name="fa6-solid:user-doctor" style="color:#9333EA" /></div><div class="doctor-specialty-badge" style="background:#9333EA">สูติ-นรีเวช</div></div>
