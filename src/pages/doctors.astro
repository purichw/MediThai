        <div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai มะเร็ง</div>
        <div class="doctor-tags"><span class="doctor-tag">AI Mammography</span><span class="doctor-tag">Breast MRI</span></div>
        <a href="/doctors/saranya-ngamrasmeewong" class="btn btn-outline btn-sm" style="width:calc(100% - 40px);justify-content:center;margin-bottom:6px">ดูโปรไฟล์</a>
