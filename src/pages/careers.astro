---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('careers');

const heroTitle = cms.t('hero', 'pg_title', 'ร่วมเป็นส่วนหนึ่งของ MediThai', 'Join the MediThai Team');
const heroDesc  = cms.t('hero', 'pg_desc', 'เราเชื่อว่าบุคลากรที่ดีคือหัวใจของการรักษาพยาบาลที่ดี มาร่วมสร้างอนาคตทางการแพทย์ไปด้วยกัน', 'We believe great people are the heart of great healthcare. Join us in building the future of medicine.');

const bnTag     = cms.t('benefits', 'tag', 'ทำไมต้อง MediThai', 'Why MediThai');
const bnHeading = cms.t('benefits', 'heading', 'สิทธิประโยชน์ที่คุณจะได้รับ', 'Benefits You\'ll Receive');
const benefits = cms.items('benefits', 'items').map((it, i) => ({
  icon: it.icon || 'circle-check', color: it.color || '#0891B2',
  title: cms.li('benefits', 'items', i, 'title', it),
  desc:  cms.li('benefits', 'items', i, 'desc', it),
}));

const jbTag     = cms.t('jobs', 'tag', 'ตำแหน่งที่เปิดรับ', 'Open Positions');
const jbHeading = cms.t('jobs', 'heading', 'ตำแหน่งงานว่าง', 'Job Openings');
const jbCta     = cms.t('jobs', 'cta_text', 'ไม่พบตำแหน่งที่ต้องการ? ส่ง Resume มาเพื่อพิจารณาสำหรับตำแหน่งอนาคต', 'Don\'t see the right position? Send us your resume for future consideration.');
const jobs = cms.items('jobs', 'items').map((it, i) => ({
  color: it.color || '#0891B2', type: it.type || 'Full-time', urgent: it.urgent === 'yes',
  title:    cms.li('jobs', 'items', i, 'title', it),
  dept:     cms.li('jobs', 'items', i, 'dept', it),
  location: cms.li('jobs', 'items', i, 'location', it),
}));

const cmsScript = cms.script();
---
<Layout title="ร่วมงานกับเรา | MediThai" description="ร่วมเป็นส่วนหนึ่งของทีม MediThai เปิดรับสมัครงานหลายตำแหน่ง"
  extraHead={`${cmsScript}<style>
  .job-card { background:#fff; border-radius:16px; padding:24px; box-shadow:var(--shadow-sm); border:1px solid var(--gray-100); display:flex; align-items:flex-start; gap:16px; transition:all .3s; }
  .job-card:hover { box-shadow:var(--shadow-lg); transform:translateY(-2px); border-color:var(--secondary); }
  .benefit-card { background:#fff; border-radius:16px; padding:28px; text-align:center; box-shadow:var(--shadow-sm); }
  .benefit-icon { width:56px; height:56px; border-radius:14px; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; }
  </style>`}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span data-i18n={heroTitle.k}>{heroTitle.th}</span></div>
    <h1 data-i18n={heroTitle.k}>{heroTitle.th}</h1>
    <p data-i18n={heroDesc.k} set:html={heroDesc.th}></p>
  </div>
</section>

<!-- Why join us -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag" data-i18n={bnTag.k}>{bnTag.th}</span>
      <h2 data-i18n={bnHeading.k}>{bnHeading.th}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
      {benefits.map((b, i) => (
        <div class={`benefit-card reveal${i%4===1?' reveal-delay-1':i%4===2?' reveal-delay-2':i%4===3?' reveal-delay-3':''}`}>
          <div class="benefit-icon" style={`background:${b.color}15`}>
            <Icon name={`fa6-solid:${b.icon}`} style={`color:${b.color};width:1.4rem;height:1.4rem`} />
          </div>
          <h3 style="font-size:.9rem;font-weight:700;color:var(--primary);margin-bottom:6px" data-i18n={b.title.k}>{b.title.th}</h3>
          <p style="font-size:.8rem;color:var(--gray-600);line-height:1.6" data-i18n={b.desc.k}>{b.desc.th}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Job listings -->
<section class="section-pad">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:32px">
      <span class="tag" data-i18n={jbTag.k}>{jbTag.th}</span>
      <h2 data-i18n={jbHeading.k}>{jbHeading.th}</h2>
      <p>{jobs.length} ตำแหน่งที่เปิดรับสมัครในขณะนี้</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px;max-width:800px;margin:0 auto">
      {jobs.map((j, i) => (
        <div class={`job-card reveal${i%2===1?' reveal-delay-1':''}`}>
          <div style={`width:48px;height:48px;border-radius:12px;background:${j.color}15;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
            <Icon name="fa6-solid:briefcase-medical" style={`color:${j.color};width:1.2rem;height:1.2rem`} />
          </div>
          <div style="flex:1">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px">
              <span style="font-weight:700;color:var(--primary)" data-i18n={j.title.k}>{j.title.th}</span>
              {j.urgent && <span style="background:#FEE2E2;color:#991B1B;font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:20px">ด่วน</span>}
            </div>
            <div style="font-size:.8rem;color:var(--gray-500);display:flex;gap:16px;flex-wrap:wrap">
              <span><Icon name="fa6-solid:tag" style={`color:${j.color}`} /> <span data-i18n={j.dept.k}>{j.dept.th}</span></span>
              <span><Icon name="fa6-solid:location-dot" /> <span data-i18n={j.location.k}>{j.location.th}</span></span>
              <span><Icon name="fa6-solid:clock" /> {j.type}</span>
            </div>
          </div>
          <a href="/contact?subject=สมัครงาน: " class="btn btn-outline btn-sm" style="white-space:nowrap">สมัครงาน</a>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:32px">
      <p style="color:var(--gray-600);margin-bottom:16px" data-i18n={jbCta.k}>{jbCta.th}</p>
      <a href="/contact" class="btn btn-primary"><Icon name="fa6-solid:paper-plane" /> ส่ง Resume</a>
    </div>
  </div>
</section>

</Layout>
