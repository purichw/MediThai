---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('health-library');
const heroTitle = cms.t('hero', 'pg_title', 'คลังความรู้สุขภาพ', 'Health Library');
const heroDesc  = cms.t('hero', 'pg_desc', 'บทความสุขภาพโดยแพทย์ผู้เชี่ยวชาญ', 'Health articles by specialist doctors');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th };

const ftHeading = cms.t('featured', 'heading', 'CKM Syndrome โรคหัวใจ ไต เมตาบอลิก ภัยเงียบของคนยุคใหม่', 'CKM Syndrome — the silent heart-kidney-metabolic threat');
const ftSub     = cms.t('featured', 'sub', 'CKM Syndrome คืออะไร? ทำไมคนทำงานในยุคนี้ต้องระวัง อ่านบทความโดย นพ.ชยพล ชีถนอม อายุรแพทย์จาก MediThai กรุงเทพ', 'What is CKM Syndrome and why should working people beware? By Dr. Chayapol, internist at MediThai Bangkok.');
const ftByline  = cms.t('featured', 'byline', 'นพ. ชยพล ชีถนอม · วันนี้', 'Dr. Chayapol Cheethanom · Today');
const ftBtn     = cms.t('featured', 'btn', 'อ่านบทความ', 'Read Article');

const articles = cms.items('articles', 'items').map((it, i) => {
  const grad = (it.grad || '#475569,#334155').split(',');
  return {
    author: it.author, date: it.date, catkey: it.catkey || 'general', letter: it.letter || 'ก',
    g1: grad[0], g2: grad[1] || grad[0], href: it.href || '#', img: it.img || '',
    title: cms.li('articles', 'items', i, 'title', it),
    cat:   cms.li('articles', 'items', i, 'cat', it),
  };
});

const cmsScript = cms.script();
---
<Layout title="คลังความรู้สุขภาพ | MediThai Hospital Network" description="บทความสุขภาพโดยแพทย์ผู้เชี่ยวชาญ"
  extraHead={`${cmsScript}
    <style>
    .lib-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
    @media(max-width:900px){.lib-grid{grid-template-columns:repeat(2,1fr);}}
    @media(max-width:560px){.lib-grid{grid-template-columns:1fr;}}
    .topic-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:48px;}
    @media(max-width:860px){.topic-grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:480px){.topic-grid{grid-template-columns:repeat(2,1fr);}}
    .topic-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:var(--radius-lg);padding:20px 12px;text-align:center;cursor:pointer;transition:var(--t) var(--ease);text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0;}
    .topic-card:hover,.topic-card.active{border-color:var(--secondary);background:rgba(8,145,178,.04);transform:translateY(-4px);box-shadow:var(--shadow-md);}
    .topic-icon{width:60px;height:60px;border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;transition:var(--t) var(--ease);}
    .topic-icon [data-icon]{width:1.5rem;height:1.5rem;}
    .topic-card span{font-size:.82rem;font-weight:600;color:var(--gray-700);}
    .topic-card span{font-size:.78rem;font-weight:600;color:var(--gray-700);}
    .featured-article{background:linear-gradient(135deg,var(--primary-dark),var(--primary));border-radius:var(--radius-xl);padding:40px;color:#fff;margin-bottom:40px;position:relative;overflow:hidden;}
    .featured-article::after{content:'';position:absolute;right:-40px;top:-40px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.05);}
    </style>
  `}
  extraScripts={`
    <script>
    function filterArticles(cat, el) {
      document.querySelectorAll('.topic-card').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      document.querySelectorAll('.article-card[data-cat]').forEach(card => {
        card.style.display = card.dataset.cat === cat ? '' : 'none';
      });
    }
    </script>
  `}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>คลังความรู้</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
  </div>
</section>

<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="filter-bar reveal" style="margin-bottom:32px">
      <div class="search-input-wrap" style="flex:1">
        <Icon name="fa6-solid:magnifying-glass" />
        <input type="text" class="search-input" placeholder="ค้นหาบทความ โรค อาการ..." />
      </div>
      <select class="filter-select">
        <option>ทุกหมวด</option>
        <option>โรคหัวใจ</option>
        <option>มะเร็ง</option>
        <option>ระบบประสาท</option>
        <option>กระดูกและข้อ</option>
        <option>สุขภาพเด็ก</option>
        <option>สุขภาพสตรี</option>
      </select>
    </div>

    <div class="tag reveal"><Icon name="fa6-solid:layer-group" /> หมวดหมู่ยอดนิยม</div>
    <div class="topic-grid reveal">
      <a href="#articles" class="topic-card" onclick="filterArticles('heart',this)">
        <div class="topic-icon" style="background:rgba(239,68,68,.1)"><Icon name="fa6-solid:heart-pulse" style="color:#EF4444" /></div>
        <span>โรคหัวใจ</span>
      </a>
      <a href="#articles" class="topic-card" onclick="filterArticles('cancer',this)">
        <div class="topic-icon" style="background:rgba(139,92,246,.1)"><Icon name="fa6-solid:ribbon" style="color:#8B5CF6" /></div>
        <span>มะเร็ง</span>
      </a>
      <a href="#articles" class="topic-card" onclick="filterArticles('neuro',this)">
        <div class="topic-icon" style="background:rgba(8,145,178,.1)"><Icon name="fa6-solid:brain" style="color:#0891B2" /></div>
        <span>ระบบประสาท</span>
      </a>
      <a href="#articles" class="topic-card" onclick="filterArticles('ortho',this)">
        <div class="topic-icon" style="background:rgba(217,119,6,.1)"><Icon name="fa6-solid:bone" style="color:#D97706" /></div>
        <span>กระดูกและข้อ</span>
      </a>
      <a href="#articles" class="topic-card" onclick="filterArticles('peds',this)">
        <div class="topic-icon" style="background:rgba(16,185,129,.1)"><Icon name="fa6-solid:child-reaching" style="color:#10B981" /></div>
        <span>สุขภาพเด็ก</span>
      </a>
      <a href="#articles" class="topic-card" onclick="filterArticles('women',this)">
        <div class="topic-icon" style="background:rgba(219,39,119,.1)"><Icon name="fa6-solid:venus" style="color:#DB2777" /></div>
        <span>สุขภาพสตรี</span>
      </a>
    </div>

    <div class="tag reveal"><Icon name="fa6-solid:magnifying-glass" /> ค้นหาโรคตามตัวอักษร</div>
    <div class="az-nav reveal" id="articles">
      <button class="az-btn active" data-letter="ALL">ทั้งหมด</button>
      <button class="az-btn" data-letter="ก">ก</button>
      <button class="az-btn" data-letter="ข">ข</button>
      <button class="az-btn" data-letter="ค">ค</button>
      <button class="az-btn" data-letter="ต">ต</button>
      <button class="az-btn" data-letter="ท">ท</button>
      <button class="az-btn" data-letter="น">น</button>
      <button class="az-btn" data-letter="ป">ป</button>
      <button class="az-btn" data-letter="ผ">ผ</button>
      <button class="az-btn" data-letter="ฝ">ฝ</button>
      <button class="az-btn" data-letter="พ">พ</button>
      <button class="az-btn" data-letter="ม">ม</button>
      <button class="az-btn" data-letter="ร">ร</button>
      <button class="az-btn" data-letter="ว">ว</button>
      <button class="az-btn" data-letter="ส">ส</button>
      <button class="az-btn" data-letter="ห">ห</button>
      <button class="az-btn" data-letter="อ">อ</button>
    </div>

    <div class="featured-article reveal">
      <div class="tag" style="background:rgba(255,255,255,.2);color:#fff"><Icon name="fa6-solid:star" /> บทความแนะนำ</div>
      <h2 style="font-size:clamp(1.2rem,2.5vw,1.8rem);font-weight:700;color:#fff;margin-bottom:12px" data-i18n={ftHeading.k}>{ftHeading.th}</h2>
      <p style="color:rgba(255,255,255,.75);font-size:.9rem;max-width:560px;margin-bottom:20px" data-i18n={ftSub.k}>{ftSub.th}</p>
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <a href="#" class="btn btn-white btn-sm"><Icon name="fa6-solid:book-open" /> <span data-i18n={ftBtn.k}>{ftBtn.th}</span></a>
        <span style="color:rgba(255,255,255,.6);font-size:.8rem"><Icon name="fa6-solid:user-doctor" style="margin-right:4px" /><span data-i18n={ftByline.k}>{ftByline.th}</span></span>
      </div>
    </div>

    <div class="lib-grid">
      {articles.map((a, i) => (
        <a href={a.href} class={`article-card reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`} data-letter={a.letter} data-cat={a.catkey}>
          <div class="article-img" style={a.img ? `background:url('${a.img}') center/cover` : `background:linear-gradient(135deg,${a.g1},${a.g2})`}></div>
          <div class="article-body">
            <div class="article-cat" data-i18n={a.cat.k}>{a.cat.th}</div>
            <div class="article-title" data-i18n={a.title.k}>{a.title.th}</div>
            <div class="article-meta"><span class="article-author"><span class="article-author-avatar"><Icon name="fa6-solid:user-doctor" /></span>{a.author}</span><span>{a.date}</span></div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center" style="margin-top:48px">
      <button class="btn btn-outline btn-lg"><Icon name="fa6-solid:rotate" /> โหลดบทความเพิ่มเติม</button>
    </div>
  </div>
</section>

<section style="background:var(--gray-50);padding:64px 0 0">
  <div class="container">
    <div class="newsletter-box reveal">
      <div class="newsletter-text"><h2 data-i18n="news_title">รับข่าวสารสุขภาพ</h2><p data-i18n="news_sub">รับบทความสุขภาพและโปรโมชั่นพิเศษทางอีเมล</p></div>
      <form class="newsletter-form" onsubmit="return false">
        <input type="email" placeholder="กรอกอีเมลของคุณ" />
        <button type="submit" class="btn btn-white">สมัคร</button>
      </form>
    </div>
  </div>
</section>

</Layout>
