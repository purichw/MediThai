---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('giving');
const heroTitle = cms.t('hero', 'pg_title', 'ร่วมสร้างสุขภาพที่ดีให้ทุกคน', 'Building Better Health for All');
const heroDesc  = cms.t('hero', 'pg_desc', 'กองทุน MediThai Care Fund ช่วยเหลือผู้ป่วยที่ขาดแคลนและด้อยโอกาสให้เข้าถึงการรักษาพยาบาลที่มีคุณภาพ', 'The MediThai Care Fund helps underprivileged patients access quality medical care.');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th };

const impact = cms.items('impact', 'items').map((it, i) => ({
  num: it.num, icon: it.icon || 'circle-check',
  label: cms.li('impact', 'items', i, 'label', it),
}));

const pgTag     = cms.t('programs', 'tag', 'โครงการ', 'Programs');
const pgHeading = cms.t('programs', 'heading', 'โครงการที่คุณสนับสนุนได้', 'Programs You Can Support');
const programs = cms.items('programs', 'items').map((it, i) => ({
  icon: it.icon || 'hand-holding-heart', color: it.color || '#0891B2',
  funded: parseInt(it.funded || '0', 10) || 0,
  title: cms.li('programs', 'items', i, 'title', it),
  desc:  cms.li('programs', 'items', i, 'desc', it),
}));

const cmsScript = cms.script();
---
<Layout title="ร่วมสนับสนุน | MediThai" description="ร่วมสนับสนุนกองทุนสุขภาพ MediThai เพื่อผู้ป่วยที่ขาดแคลน">
<Fragment set:html={cmsScript} />

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>ร่วมสนับสนุน</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
  </div>
</section>

<!-- Impact numbers -->
<section style="background:#fff;padding:56px 0">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center">
      {impact.map(s => (
        <div class="reveal">
          <Icon name={`fa6-solid:${s.icon}`} style="font-size:1.5rem;color:var(--accent);margin-bottom:8px" />
          <div style="font-size:2rem;font-weight:800;color:var(--primary)">{s.num}</div>
          <div style="font-size:.875rem;color:var(--gray-600)" data-i18n={s.label.k}>{s.label.th}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Programs -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:40px">
      <span class="tag" data-i18n={pgTag.k}>{pgTag.th}</span>
      <h2 data-i18n={pgHeading.k}>{pgHeading.th}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px">
      {programs.map((p,i) => (
        <div class={`reveal${i%3===1?' reveal-delay-1':i%3===2?' reveal-delay-2':''}`} style="background:#fff;border-radius:20px;padding:28px;box-shadow:var(--shadow-md)">
          <div style={`width:56px;height:56px;border-radius:14px;background:${p.color}15;display:flex;align-items:center;justify-content:center;margin-bottom:16px`}>
            <Icon name={`fa6-solid:${p.icon}`} style={`color:${p.color};width:1.4rem;height:1.4rem`} />
          </div>
          <h3 style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:8px" data-i18n={p.title.k}>{p.title.th}</h3>
          <p style="font-size:.85rem;color:var(--gray-600);line-height:1.7;margin-bottom:16px" data-i18n={p.desc.k}>{p.desc.th}</p>
          <div style="margin-bottom:4px;display:flex;justify-content:space-between;font-size:.8rem">
            <span style="color:var(--gray-500)">ได้รับทุนแล้ว</span>
            <span style={`font-weight:700;color:${p.color}`}>{p.funded}%</span>
          </div>
          <div style="height:6px;background:var(--gray-100);border-radius:3px;overflow:hidden">
            <div style={`height:100%;width:${p.funded}%;background:${p.color};border-radius:3px`}></div>
          </div>
          <a href="#donate" class="btn btn-outline btn-sm" style={`width:100%;justify-content:center;margin-top:16px;color:${p.color};border-color:${p.color}`}>บริจาคเพื่อโครงการนี้</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Donation form -->
<section class="section-pad" id="donate">
  <div class="container" style="max-width:600px">
    <div class="section-header text-center reveal" style="margin-bottom:32px">
      <span class="tag">บริจาค</span>
      <h2>ร่วมบริจาค</h2>
      <p>ทุกบาทของคุณส่งต่อถึงผู้ป่วยโดยตรง</p>
    </div>
    <div class="reveal" style="background:#fff;border-radius:20px;padding:40px;box-shadow:var(--shadow-md)">
      <p style="font-weight:600;color:var(--primary);margin-bottom:12px">เลือกจำนวนเงิน</p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:20px">
        {['100','500','1,000','5,000'].map(amt => (
          <button onclick="setAmt(this,'{amt}')" class="btn btn-outline btn-sm" style="justify-content:center">฿{amt}</button>
        ))}
      </div>
      <div class="form-group">
        <label>หรือกรอกจำนวนเงินเอง (บาท)</label>
        <input type="number" min="20" placeholder="ขั้นต่ำ 20 บาท" />
      </div>
      <div class="form-group">
        <label>ชื่อผู้บริจาค</label>
        <input type="text" placeholder="ชื่อ-นามสกุล (หรือ 'นิรนาม')" />
      </div>
      <div class="form-group">
        <label>อีเมล (รับใบเสร็จ)</label>
        <input type="email" placeholder="your@email.com" />
      </div>
      <div class="form-group">
        <label>โครงการที่ต้องการสนับสนุน</label>
        <select class="filter-select" style="width:100%;height:48px">
          <option>กองทุนทั่วไป (จัดสรรตามความจำเป็น)</option>
          <option>เด็กขาดแคลนเข้าถึงการรักษา</option>
          <option>ผู้สูงอายุขาดแคลน</option>
          <option>ทุนการศึกษาพยาบาล</option>
          <option>แพทย์อาสาชนบท</option>
          <option>ทุนวิจัยทางการแพทย์</option>
        </select>
      </div>
      <button class="btn btn-primary btn-full" style="background:var(--accent);border-color:var(--accent)">
        <Icon name="fa6-solid:heart" /> บริจาคเลย
      </button>
      <p style="font-size:.75rem;color:var(--gray-500);text-align:center;margin-top:12px">
        บริจาคผ่านระบบ 2C2P · ปลอดภัย · สามารถนำใบเสร็จไปลดหย่อนภาษีได้
      </p>
    </div>

    <div style="background:var(--gray-50);border-radius:16px;padding:20px;margin-top:16px;text-align:center">
      <p style="font-size:.875rem;color:var(--gray-600)">ต้องการบริจาคผ่านธนาคาร หรือต้องการใบรับรองการบริจาค</p>
      <a href="/contact" style="color:var(--secondary);font-size:.875rem;font-weight:600">ติดต่อฝ่ายมูลนิธิ →</a>
    </div>
  </div>
</section>

</Layout>
