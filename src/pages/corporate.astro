---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('corporate');
const heroTitle = cms.t('hero', 'pg_title', 'บริการสุขภาพสำหรับองค์กร', 'Corporate Health Services');
const heroDesc  = cms.t('hero', 'pg_desc', 'พนักงานที่มีสุขภาพดีคือรากฐานขององค์กรที่แข็งแกร่ง ให้ MediThai ดูแลทีมของคุณ', 'Healthy employees are the foundation of a strong organization. Let MediThai care for your team.');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th };

const stats = cms.items('stats', 'items').map((it, i) => ({
  num: it.num, icon: it.icon || 'circle-check',
  label: cms.li('stats', 'items', i, 'label', it),
}));

const svTag     = cms.t('services', 'tag', 'Corporate Solutions', 'Corporate Solutions');
const svHeading = cms.t('services', 'heading', 'บริการที่ครบวงจรสำหรับองค์กร', 'Complete services for organizations');
const services = cms.items('services', 'items').map((it, i) => ({
  icon: it.icon || 'circle-check', color: it.color || '#0891B2',
  title: cms.li('services', 'items', i, 'title', it),
  desc:  cms.li('services', 'items', i, 'desc', it),
}));

const pkTag     = cms.t('packages', 'tag', 'แพ็กเกจองค์กร', 'Corporate Packages');
const pkHeading = cms.t('packages', 'heading', 'ราคาพิเศษสำหรับองค์กร', 'Special corporate pricing');
const incLis = (text: string, color: string) => (text || '').split('\n').filter(Boolean).map(it =>
  `<li style="display:flex;gap:8px;align-items:center;font-size:.875rem;color:var(--gray-700);padding:6px 0;border-bottom:1px solid var(--gray-50)"><span style="color:${color};font-weight:700;flex-shrink:0">✓</span> ${it}</li>`).join('');
const plans = cms.items('packages', 'plans').map((it, i) => {
  const color = it.color || '#0891B2';
  const inc = cms.li('packages', 'plans', i, 'inc', it);
  return {
    name: it.name, price: it.price, color, featured: it.featured === 'yes',
    size: cms.li('packages', 'plans', i, 'size', it),
    per:  cms.li('packages', 'plans', i, 'per', it),
    incHtml: cms.t('packages', `plan${i}_inc_html`, incLis(inc.th, color), incLis(inc.en, color)),
  };
});

const cmsScript = cms.script();
---
<Layout title="บริการสุขภาพองค์กร | MediThai" description="แพ็กเกจสุขภาพสำหรับองค์กร ดูแลพนักงานของคุณด้วยมาตรฐานระดับโรงพยาบาลชั้นนำ">
<Fragment set:html={cmsScript} />

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>บริการองค์กร</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
    <a href="#contact-form" class="btn btn-accent" style="margin-top:24px"><Icon name="fa6-solid:building" /> ติดต่อทีมองค์กร</a>
  </div>
</section>

<!-- Stats -->
<section style="background:#fff;padding:56px 0;border-bottom:1px solid var(--gray-100)">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center">
      {stats.map(s => (
        <div class="reveal">
          <Icon name={`fa6-solid:${s.icon}`} style="font-size:1.5rem;color:var(--secondary);margin-bottom:8px" />
          <div style="font-size:2rem;font-weight:800;color:var(--primary)">{s.num}</div>
          <div style="font-size:.875rem;color:var(--gray-600)" data-i18n={s.label.k}>{s.label.th}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Services -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag" data-i18n={svTag.k}>{svTag.th}</span>
      <h2 data-i18n={svHeading.k}>{svHeading.th}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px">
      {services.map((s,i) => (
        <div class={`reveal${i%3===1?' reveal-delay-1':i%3===2?' reveal-delay-2':''}`} style="background:#fff;border-radius:20px;padding:28px;box-shadow:var(--shadow-sm)">
          <div style={`width:56px;height:56px;border-radius:14px;background:${s.color}15;display:flex;align-items:center;justify-content:center;margin-bottom:16px`}>
            <Icon name={`fa6-solid:${s.icon}`} style={`color:${s.color};width:1.4rem;height:1.4rem`} />
          </div>
          <h3 style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:8px" data-i18n={s.title.k}>{s.title.th}</h3>
          <p style="font-size:.875rem;color:var(--gray-600);line-height:1.7" data-i18n={s.desc.k}>{s.desc.th}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Packages -->
<section class="section-pad">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:40px">
      <span class="tag" data-i18n={pkTag.k}>{pkTag.th}</span>
      <h2 data-i18n={pkHeading.k}>{pkHeading.th}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:900px;margin:0 auto">
      {plans.map((p,i) => (
        <div class={`reveal${i===1?' reveal-delay-1':i===2?' reveal-delay-2':''}`} style={`background:#fff;border-radius:20px;padding:32px;box-shadow:var(--shadow-md);${p.featured?`border:2px solid ${p.color}`:''}`}>
          {p.featured && <span style={`background:${p.color};color:#fff;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:12px;display:inline-block`}>แนะนำ</span>}
          <h3 style={`font-size:1.1rem;font-weight:700;color:${p.color};margin-bottom:4px`}>{p.name}</h3>
          <p style="font-size:.8rem;color:var(--gray-500);margin-bottom:12px" data-i18n={p.size.k}>{p.size.th}</p>
          <div style="margin-bottom:20px">
            <span style="font-size:2rem;font-weight:800;color:var(--primary)">฿{p.price}</span>
            <span style="font-size:.8rem;color:var(--gray-500)"> <span data-i18n={p.per.k}>{p.per.th}</span></span>
          </div>
          <ul style="list-style:none;margin-bottom:24px" data-i18n={p.incHtml.k} set:html={p.incHtml.th}></ul>
          <a href="#contact-form" class="btn btn-primary" style={`width:100%;justify-content:center;background:${p.color};border-color:${p.color}`}>ติดต่อทีมองค์กร</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Contact form -->
<section class="section-pad" id="contact-form" style="background:var(--gray-50)">
  <div class="container" style="max-width:640px">
    <div class="section-header text-center reveal" style="margin-bottom:32px">
      <span class="tag">ติดต่อเรา</span>
      <h2>สนใจโปรแกรมองค์กร?</h2>
      <p>ทีมผู้เชี่ยวชาญของเราพร้อมออกแบบโปรแกรมที่เหมาะกับองค์กรของคุณ</p>
    </div>
    <form class="auth-form reveal" style="background:#fff;border-radius:20px;padding:40px;box-shadow:var(--shadow-md)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="form-group"><label>ชื่อ-นามสกุล</label><input type="text" required placeholder="สมชาย วงศ์ดี" /></div>
        <div class="form-group"><label>ตำแหน่ง</label><input type="text" required placeholder="HR Manager" /></div>
      </div>
      <div class="form-group"><label>ชื่อบริษัท</label><input type="text" required placeholder="บริษัท ABC จำกัด" /></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="form-group"><label>อีเมล</label><input type="email" required /></div>
        <div class="form-group"><label>เบอร์โทรศัพท์</label><input type="tel" required /></div>
      </div>
      <div class="form-group">
        <label>จำนวนพนักงานโดยประมาณ</label>
        <select class="filter-select" style="width:100%;height:48px">
          <option>5–49 คน</option><option>50–199 คน</option><option>200–499 คน</option><option>500+ คน</option>
        </select>
      </div>
      <div class="form-group"><label>ความต้องการเพิ่มเติม</label><textarea rows="3" placeholder="อธิบายความต้องการหรือบริการที่สนใจ..."></textarea></div>
      <button type="submit" class="btn btn-primary btn-full"><Icon name="fa6-solid:paper-plane" /> ส่งข้อมูล</button>
    </form>
  </div>
</section>

</Layout>
