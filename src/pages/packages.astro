---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('packages');
const heroTitle = cms.t('hero', 'pg_title', 'แพ็กเกจสุขภาพ', 'Health Packages');
const heroDesc  = cms.t('hero', 'pg_desc', 'ดูแลสุขภาพที่นี่ เช็กราคา หาโปรจากโรงพยาบาลในเครือ MediThai', 'Browse health packages & promotions from MediThai hospitals.');
const promoTitle = cms.t('promo', 'promo_title', 'MediThai Health Pass — ตรวจสุขภาพรายปี ซื้อครั้งเดียวตรวจได้ทั้งปี', 'MediThai Health Pass — Annual check-up, one purchase all year.');
const promoSub   = cms.t('promo', 'promo_sub', 'เริ่มต้น ฿2,990/ปี · เลือกตรวจได้หลายรายการ · ทุกสาขาในเครือ', 'From ฿2,990/year · Multiple tests available · All branches');
const promoBtn   = cms.t('promo', 'promo_btn', 'ดูรายละเอียด', 'See details');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th, promo_title: promoTitle.th, promo_sub: promoSub.th, promo_btn: promoBtn.th };

const HOSP: Record<string, { name: string; color: string }> = {
  bkk:    { name: 'MediThai กรุงเทพ',        color: '#1B3A6B' },
  heart:  { name: 'MediThai หัวใจ',           color: '#EF4444' },
  cancer: { name: 'MediThai มะเร็ง',           color: '#8B5CF6' },
  spine:  { name: 'MediThai สมองและกระดูก',   color: '#0891B2' },
  kids:   { name: 'MediThai เด็ก',             color: '#10B981' },
  chiang: { name: 'MediThai เชียงใหม่',        color: '#F59E0B' },
};
const CHIP_CLASS = (label: string) => {
  if (/ขายดี/.test(label)) return 'bestseller';
  if (/ถูกที่สุด/.test(label)) return 'cheapest';
  if (/ใหม่/.test(label)) return 'new';
  if (/จำกัด/.test(label)) return 'limited';
  if (/bundle/i.test(label)) return 'bundle';
  return 'recommended';
};
const starsFor = (rating: number) => ({ full: Math.floor(rating), half: rating - Math.floor(rating) >= 0.3 });
const fmtPrice = (n: string) => {
  const v = parseInt(n || '0', 10);
  return v ? v.toLocaleString('en-US') : '';
};
const incLi = (text: string) => (text || '').split('\n').filter(Boolean).map(l =>
  `<li><span style="color:var(--secondary);font-weight:700">✓</span>${l}</li>`).join('');

const pkgCards = cms.items('cards', 'items').map((it, i) => {
  const inc = cms.li('cards', 'items', i, 'includes', it);
  const hosp = HOSP[it.hospital] || HOSP.bkk;
  const grad = (it.grad || '#1B3A6B,#2554A0').split(',');
  return {
    cat: it.cat || 'checkup', hospital: it.hospital || 'bkk', gender: it.gender || 'all', age: it.age || 'all',
    price: it.price || '0', priceNow: fmtPrice(it.price), priceWas: fmtPrice(it.price_was),
    discount: it.discount || '', rating: parseFloat(it.rating || '5'), reviews: it.reviews || '0',
    icon: it.icon || 'box-open', g1: grad[0], g2: grad[1] || grad[0],
    hospName: hosp.name, hospColor: hosp.color,
    chips: (it.chips || '').split(',').map(c => c.trim()).filter(Boolean).map(c => ({ label: c, cls: CHIP_CLASS(c) })),
    title: cms.li('cards', 'items', i, 'title', it),
    installment: cms.li('cards', 'items', i, 'installment', it),
    expires: cms.li('cards', 'items', i, 'expires', it),
    incHtml: cms.t('cards', `pkg${i}_inc_html`, incLi(inc.th), incLi(inc.en)),
    stars: starsFor(parseFloat(it.rating || '5')),
  };
});

const hpTag     = cms.t('healthpass', 'tag', 'MediThai Health Pass', 'MediThai Health Pass');
const hpHeading = cms.t('healthpass', 'heading', 'ตรวจสุขภาพรายปี ซื้อครั้งเดียวตรวจได้ทั้งปี', 'Annual check-ups — one purchase, all year');
const hpSub     = cms.t('healthpass', 'sub', 'เหมือน All You Can Check — เลือกแผนที่ใช่ เพิ่มรายการตรวจได้ตลอดปี ทุกสาขาในเครือ', 'Like All You Can Check — pick a plan, add tests all year, every branch.');
const hpPlans = cms.items('healthpass', 'plans').map((it, i) => {
  const feats = cms.li('healthpass', 'plans', i, 'features', it);
  return {
    name: it.name, price: it.price, icon: it.icon || 'leaf', color: it.color || '#0891B2',
    featured: it.featured === 'yes',
    period: cms.li('healthpass', 'plans', i, 'period', it),
    featHtml: cms.t('healthpass', `plan${i}_feat_html`, incLi(feats.th), incLi(feats.en)),
  };
});

const cmsScript = cms.script();
---
<Layout
  title={`${th.pg_title} | MediThai Hospital Network`}
  description={th.pg_desc}
  extraHead={`
    <link rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>
    ${cmsScript}
  `}
  extraScripts={`
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
    function toggleSidebar(){
      document.getElementById('filter-sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
    function setSortTab(btn){
      document.querySelectorAll('.sort-tab').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
    }
    let activeGender='all';
    function setGender(g,el){
      activeGender=g;
      document.querySelectorAll('[data-gender]').forEach(b=>b.classList.remove('active'));
      el.classList.add('active');
      filterPackages();
    }
    let activeAge='all';
    function setAge(a,el){
      activeAge=a;
      document.querySelectorAll('[data-age]').forEach(b=>b.classList.remove('active'));
      el.classList.add('active');
      filterPackages();
    }
    function setPriceRange(min,max,el){
      document.getElementById('price-min').value=min||'';
      document.getElementById('price-max').value=max===999999?'':max;
      filterPackages();
    }
    function setCategory(cat,el){
      document.querySelectorAll('.cat-hero-btn').forEach(b=>b.classList.remove('active-hero'));
      el.classList.add('active-hero');
      document.querySelectorAll('.filter-check input[type="checkbox"]').forEach(cb=>{
        if(cb.value===cat) cb.checked=true;
      });
      filterPackages();
    }
    function filterPackages(){
      const q=(document.getElementById('pkg-search')?.value||'').toLowerCase();
      const cats=[...document.querySelectorAll('.filter-check input[type="checkbox"]:checked')].map(c=>c.value).filter(v=>['checkup','cancer','heart','surgery','vaccine','bundle'].includes(v));
      const hosps=[...document.querySelectorAll('.filter-check input[type="checkbox"]:checked')].map(c=>c.value).filter(v=>['bkk','heart','cancer','spine','kids','chiang'].includes(v));
      const minP=parseFloat(document.getElementById('price-min')?.value)||0;
      const maxP=parseFloat(document.getElementById('price-max')?.value)||Infinity;
      let visible=0;
      document.querySelectorAll('.pkg-card').forEach(card=>{
        const cardCat=card.dataset.cat||'';
        const cardHosp=card.dataset.hospital||'';
        const cardGender=card.dataset.gender||'all';
        const cardAge=card.dataset.age||'all';
        const price=parseFloat(card.dataset.price)||0;
        const title=card.querySelector('.pkg-card-title')?.textContent.toLowerCase()||'';
        const matchCat=!cats.length||cats.some(c=>cardCat.includes(c));
        const matchHosp=!hosps.length||hosps.includes(cardHosp);
        const matchGender=activeGender==='all'||cardGender==='all'||cardGender===activeGender;
        const matchAge=activeAge==='all'||cardAge==='all'||cardAge===activeAge;
        const matchPrice=price>=minP&&price<=maxP;
        const matchQ=!q||title.includes(q);
        const show=matchCat&&matchHosp&&matchGender&&matchAge&&matchPrice&&matchQ;
        card.style.display=show?'':'none';
        if(show) visible++;
      });
      const el=document.getElementById('pkg-count');
      if(el) el.textContent=visible||'0';
    }
    function resetFilters(){
      document.querySelectorAll('.filter-check input').forEach(i=>i.checked=false);
      document.getElementById('pkg-search').value='';
      document.getElementById('price-min').value='';
      document.getElementById('price-max').value='';
      activeGender='all'; activeAge='all';
      document.querySelectorAll('[data-gender],[data-age]').forEach(b=>{
        b.classList.toggle('active',b.dataset.gender==='all'||b.dataset.age==='all');
      });
      filterPackages();
    }
    </script>
  `}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span data-i18n="pg_title">{th.pg_title}</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
    <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:28px">
      <a href="#" onclick="setCategory('checkup',this);return false" class="btn btn-secondary btn-sm cat-hero-btn active-hero"><Icon name="fa6-solid:clipboard-list" /> ตรวจสุขภาพ</a>
      <a href="#" onclick="setCategory('cancer',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:ribbon" /> มะเร็ง</a>
      <a href="#" onclick="setCategory('heart',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:heart-pulse" /> หัวใจ</a>
      <a href="#" onclick="setCategory('surgery',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:scissors" /> ผ่าตัด</a>
      <a href="#" onclick="setCategory('vaccine',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:syringe" /> วัคซีน</a>
      <a href="/concierge" class="btn btn-white btn-sm"><Icon name="fa6-solid:user-nurse" /> Surgery Concierge</a>
    </div>
  </div>
</section>

<div style="background:linear-gradient(90deg,#1B3A6B,#0891B2);padding:14px 0">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:12px;color:#fff">
      <Icon name="fa6-solid:infinity" style="font-size:1.3rem;color:#F59E0B" />
      <div>
        <div style="font-family:var(--font-heading);font-weight:600;font-size:.92rem" data-i18n="promo_title">{th.promo_title}</div>
        <div style="font-size:.75rem;opacity:.75" data-i18n="promo_sub">{th.promo_sub}</div>
      </div>
    </div>
    <a href="#health-pass" class="btn btn-white btn-sm" data-i18n="promo_btn">{th.promo_btn} <Icon name="fa6-solid:arrow-right" /></a>
  </div>
</div>

<section style="background:var(--gray-50);padding:40px 0 80px">
  <div class="container">

    <button class="filter-sidebar-mobile-toggle" onclick="toggleSidebar()">
      <Icon name="fa6-solid:sliders" /> ตัวกรอง
      <span id="filter-count" style="background:var(--accent);border-radius:99px;padding:1px 8px;font-size:.72rem;margin-left:4px;display:none">0</span>
    </button>

    <div class="filter-sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

    <div class="pkg-layout" style="margin-top:20px">

      <div class="filter-sidebar" id="filter-sidebar">
        <div class="sidebar-header">
          <h3><Icon name="fa6-solid:sliders" style="margin-right:6px" />ตัวกรอง</h3>
          <button class="sidebar-reset" onclick="resetFilters()">รีเซ็ตทั้งหมด</button>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">ค้นหา</div>
          <div style="position:relative">
            <Icon name="fa6-solid:magnifying-glass" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--gray-400);font-size:.8rem" />
            <input type="text" id="pkg-search" placeholder="ค้นหาแพ็กเกจ..." style="width:100%;padding:9px 12px 9px 34px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:.83rem;outline:none" oninput="filterPackages()" />
          </div>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">ประเภท</div>
          <div class="filter-check-list">
            <label class="filter-check"><input type="checkbox" value="checkup" onchange="filterPackages()" /> ตรวจสุขภาพ <span class="count">42</span></label>
            <label class="filter-check"><input type="checkbox" value="cancer" onchange="filterPackages()" /> ตรวจมะเร็ง <span class="count">18</span></label>
            <label class="filter-check"><input type="checkbox" value="heart" onchange="filterPackages()" /> ตรวจหัวใจ <span class="count">12</span></label>
            <label class="filter-check"><input type="checkbox" value="surgery" onchange="filterPackages()" /> ผ่าตัด <span class="count">24</span></label>
            <label class="filter-check"><input type="checkbox" value="vaccine" onchange="filterPackages()" /> วัคซีน <span class="count">15</span></label>
            <label class="filter-check"><input type="checkbox" value="bundle" onchange="filterPackages()" /> Bundle / มัดรวม <span class="count">9</span></label>
          </div>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">เพศ</div>
          <div class="chip-filters">
            <button class="chip-filter active" data-gender="all" onclick="setGender('all',this)">ทั้งหมด</button>
            <button class="chip-filter" data-gender="male" onclick="setGender('male',this)"><Icon name="fa6-solid:mars" /> ชาย</button>
            <button class="chip-filter" data-gender="female" onclick="setGender('female',this)"><Icon name="fa6-solid:venus" /> หญิง</button>
          </div>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">ช่วงอายุ</div>
          <div class="chip-filters">
            <button class="chip-filter active" data-age="all" onclick="setAge('all',this)">ทุกวัย</button>
            <button class="chip-filter" data-age="16-30" onclick="setAge('16-30',this)">16-30</button>
            <button class="chip-filter" data-age="31-45" onclick="setAge('31-45',this)">31-45</button>
            <button class="chip-filter" data-age="46-60" onclick="setAge('46-60',this)">46-60</button>
            <button class="chip-filter" data-age="61+" onclick="setAge('61+',this)">61+</button>
          </div>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">โรงพยาบาล</div>
          <div class="filter-check-list">
            <label class="filter-check"><input type="checkbox" value="bkk" onchange="filterPackages()" /> MediThai กรุงเทพ <span class="count">35</span></label>
            <label class="filter-check"><input type="checkbox" value="heart" onchange="filterPackages()" /> MediThai หัวใจ <span class="count">18</span></label>
            <label class="filter-check"><input type="checkbox" value="cancer" onchange="filterPackages()" /> MediThai มะเร็ง <span class="count">22</span></label>
            <label class="filter-check"><input type="checkbox" value="spine" onchange="filterPackages()" /> MediThai สมองและกระดูก <span class="count">14</span></label>
            <label class="filter-check"><input type="checkbox" value="kids" onchange="filterPackages()" /> MediThai เด็ก <span class="count">11</span></label>
            <label class="filter-check"><input type="checkbox" value="chiang" onchange="filterPackages()" /> MediThai เชียงใหม่ <span class="count">20</span></label>
          </div>
        </div>
        <div class="filter-group">
          <div class="filter-group-title">ช่วงราคา (บาท)</div>
          <div class="price-range-inputs">
            <input type="number" id="price-min" placeholder="ต่ำสุด" oninput="filterPackages()" />
            <input type="number" id="price-max" placeholder="สูงสุด" oninput="filterPackages()" />
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px">
            <button class="chip-filter" onclick="setPriceRange(0,5000,this)">&lt; ฿5K</button>
            <button class="chip-filter" onclick="setPriceRange(5000,20000,this)">฿5K-20K</button>
            <button class="chip-filter" onclick="setPriceRange(20000,100000,this)">฿20K-100K</button>
            <button class="chip-filter" onclick="setPriceRange(100000,999999,this)">&gt; ฿100K</button>
          </div>
        </div>
      </div>

      <div>
        <div class="results-bar">
          <span class="results-count">แสดง <strong id="pkg-count">9</strong> แพ็กเกจ</span>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <div class="sort-tabs">
              <button class="sort-tab active" onclick="setSortTab(this)">แนะนำ</button>
              <button class="sort-tab" onclick="setSortTab(this)">ขายดี</button>
              <button class="sort-tab" onclick="setSortTab(this)">ราคาน้อย→มาก</button>
              <button class="sort-tab" onclick="setSortTab(this)">ลดมากสุด</button>
            </div>
          </div>
        </div>

        <div class="pkg-grid" id="pkg-grid">
          {pkgCards.map(p => (
            <div class="pkg-card" data-cat={p.cat} data-hospital={p.hospital} data-gender={p.gender} data-age={p.age} data-price={p.price}>
              <div class="pkg-thumb" style={`background:linear-gradient(135deg,${p.g1},${p.g2})`}>
                <Icon name={`fa6-solid:${p.icon}`} />
                {p.discount && <div class="pkg-discount-badge">{p.discount}</div>}
                <div class="pkg-trust-chips">{p.chips.map(c => <span class={`trust-chip ${c.cls}`}>{c.label}</span>)}</div>
              </div>
              <div class="pkg-hospital-bar"><div class="pkg-hospital-dot" style={`background:${p.hospColor}`}></div>{p.hospName}</div>
              <div class="pkg-card-body">
                <div class="pkg-card-title" data-i18n={p.title.k}>{p.title.th}</div>
                <ul class="pkg-includes" data-i18n={p.incHtml.k} set:html={p.incHtml.th}></ul>
                <div class="pkg-rating">
                  <div class="stars">
                    {Array.from({ length: p.stars.full }).map(() => <Icon name="fa6-solid:star" />)}
                    {p.stars.half && <Icon name="fa6-solid:star-half-stroke" />}
                  </div>
                  <span class="rating-score">{p.rating.toFixed(1)}</span><span class="rating-count">({p.reviews} รีวิว)</span>
                </div>
                <div class="pkg-price-block">
                  <div class="pkg-price-row"><span class="pkg-price-now">฿{p.priceNow}</span>{p.priceWas && <span class="pkg-price-was">฿{p.priceWas}</span>}</div>
                  {p.installment.th && <div class="pkg-installment"><Icon name="fa6-solid:credit-card" /><span data-i18n={p.installment.k}>{p.installment.th}</span></div>}
                  {p.expires.th && <div class="pkg-expires-row"><Icon name="fa6-regular:clock" /><span data-i18n={p.expires.k}>{p.expires.th}</span></div>}
                  <div class="pkg-cta-row"><a href="#" class="btn btn-outline btn-sm">รายละเอียด</a><a href="/appointments" class="btn btn-primary btn-sm">ซื้อเลย</a></div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center" style="margin-top:36px">
          <button class="btn btn-outline btn-lg"><Icon name="fa6-solid:rotate" /> โหลดแพ็กเกจเพิ่ม (111 รายการ)</button>
        </div>
      </div>
    </div>

    <!-- HEALTH PASS -->
    <div id="health-pass" style="margin-top:80px">
      <div class="text-center reveal" style="margin-bottom:40px">
        <div class="tag"><Icon name="fa6-solid:infinity" /> <span data-i18n={hpTag.k}>{hpTag.th}</span></div>
        <h2 class="section-heading" data-i18n={hpHeading.k}>{hpHeading.th}</h2>
        <p class="section-sub" style="margin:0 auto" data-i18n={hpSub.k}>{hpSub.th}</p>
      </div>
      <div class="health-pass-cards reveal">
        {hpPlans.map(p => (
          <div class={`health-pass-card${p.featured ? ' featured' : ''}`}>
            <div class="pass-icon" style={`background:${p.color}1a;color:${p.color}`}><Icon name={`fa6-solid:${p.icon}`} /></div>
            <h3>{p.name}</h3>
            <div class="pass-price">{p.price}</div>
            <div class="pass-period" data-i18n={p.period.k}>{p.period.th}</div>
            <ul class="pass-features" data-i18n={p.featHtml.k} set:html={p.featHtml.th}></ul>
            <a href="/appointments" class={`btn ${p.featured ? 'btn-primary' : 'btn-outline'}`} style="width:100%;justify-content:center">เลือกแผนนี้</a>
          </div>
        ))}
      </div>
    </div>

    <!-- CORPORATE -->
    <div style="margin-top:80px;background:linear-gradient(135deg,#0F2447,#1B3A6B);border-radius:var(--radius-xl);padding:48px;display:flex;align-items:center;gap:48px;flex-wrap:wrap">
      <div style="flex:1">
        <div class="tag" style="background:rgba(255,255,255,.15);color:#fff"><Icon name="fa6-solid:building" /> แพ็กเกจองค์กร</div>
        <h2 style="color:#fff;font-size:1.6rem;font-weight:700;margin-bottom:10px">ตรวจสุขภาพพนักงาน<br>ราคาพิเศษสำหรับองค์กร</h2>
        <p style="color:rgba(255,255,255,.75);margin-bottom:20px;font-size:.9rem;max-width:400px">รองรับตั้งแต่ 10–10,000 คน ออกแบบโปรแกรมเฉพาะองค์กร รายงานสุขภาพรายบุคคลและภาพรวม เบิกภาษีได้</p>
