      <a href="#" onclick="setCategory('surgery',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:scissors" /> ผ่าตัด</a>
      <a href="#" onclick="setCategory('vaccine',this);return false" class="btn btn-secondary btn-sm cat-hero-btn"><Icon name="fa6-solid:syringe" /> วัคซีน</a>
      <a href="/concierge" class="btn btn-white btn-sm"><Icon name="fa6-solid:user-nurse" /> Surgery Concierge</a>
    </div>
  </div>
</section>

<div style="background:linear-gradient(90deg,#1B3A6B,#0891B2);padding:14px 0">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:12px;color:#fff">
      <Icon name="fa6-solid:infinity" style="font-size:1.3rem;color:#F59E0B" />
      <div>
        <div style="font-family:var(--font-heading);font-weight:600;font-size:.92rem" data-i18n="promo_title">{th.promo_title}</div>
        <div style="font-size:.75rem;opacity:.75" data-i18n="promo_sub">{th.promo_sub}</div>
