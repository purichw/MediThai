---
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout title="MediThai Card — โปรแกรมสมาชิก | MediThai" description="สะสมแต้มทุกครั้งที่ใช้บริการ แลกรับส่วนลด และสิทธิพิเศษมากมาย">

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>MediThai Card</span></div>
    <h1>MediThai Loyalty Card</h1>
    <p>สะสมแต้มทุกครั้งที่ใช้บริการ แลกรับส่วนลด และสิทธิพิเศษในโรงพยาบาลเครือ MediThai ทั้ง 6 สาขา</p>
    <a href="/register" class="btn btn-accent" style="margin-top:24px"><Icon name="fa6-solid:id-card" /> สมัครสมาชิกฟรี</a>
  </div>
</section>

<!-- Tiers -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag">ระดับสมาชิก</span>
      <h2>4 ระดับ สิทธิประโยชน์ที่แตกต่างกัน</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
      {[
        { name:'Silver', thb:'0–9,999', color:'#94A3B8', bg:'#F8FAFC', points:'1 แต้ม / 100 บาท', perks:['ส่วนลด 5% แพ็กเกจ','ข่าวสารสมาชิก','Telehealth ราคาพิเศษ'] },
        { name:'Gold', thb:'10,000–49,999', color:'#F59E0B', bg:'#FFFBEB', points:'1.5 แต้ม / 100 บาท', perks:['ส่วนลด 10% แพ็กเกจ','ตรวจสุขภาพฟรี 1 ครั้ง/ปี','Priority Queue','Telehealth ฟรี 2 ครั้ง/ปี'] },
        { name:'Platinum', thb:'50,000–199,999', color:'#0891B2', bg:'#EFF6FF', points:'2 แต้ม / 100 บาท', perks:['ส่วนลด 15% ทุกบริการ','ตรวจสุขภาพ Premium ฟรี','ห้อง VIP หากนอนพัก','Dedicated Care Manager','Telehealth ฟรีไม่จำกัด'] },
        { name:'Diamond', thb:'200,000+ บาท/ปี', color:'#1B3A6B', bg:'linear-gradient(135deg,#EFF6FF,#F5F3FF)', points:'3 แต้ม / 100 บาท', perks:['ส่วนลด 20% ทุกบริการ','Executive Health ฟรี','Concierge 24/7','รถรับ-ส่ง VIP','Second Opinion ฟรี 1 ครั้ง/ปี','ครอบครัวร่วมได้รับสิทธิ์'] },
      ].map((t,i) => (
        <div class={`reveal${i===1?' reveal-delay-1':i===2?' reveal-delay-2':i===3?' reveal-delay-3':''}`} style={`background:${t.bg};border-radius:20px;padding:28px;box-shadow:var(--shadow-sm);border:2px solid ${t.color}30`}>
          <div style={`font-size:2rem;margin-bottom:8px`}>{t.name==='Silver'?'🥈':t.name==='Gold'?'🥇':t.name==='Platinum'?'💠':'💎'}</div>
          <h3 style={`font-size:1.3rem;font-weight:800;color:${t.color};margin-bottom:4px`}>{t.name}</h3>
          <p style="font-size:.75rem;color:var(--gray-500);margin-bottom:12px">ยอดสะสม {t.thb} บาท/ปี</p>
          <div style={`background:${t.color}15;border-radius:8px;padding:6px 12px;font-size:.8rem;font-weight:600;color:${t.color};margin-bottom:16px;display:inline-block`}>{t.points}</div>
          <ul style="list-style:none">
            {t.perks.map(p => (
              <li style="display:flex;gap:8px;align-items:flex-start;font-size:.8rem;color:var(--gray-700);margin-bottom:6px">
                <Icon name="fa6-solid:check" style={`color:${t.color};flex-shrink:0;margin-top:2px`} /> {p}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- How to earn -->
<section class="section-pad">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div class="reveal-left">
        <span class="tag" style="margin-bottom:16px">สะสมแต้ม</span>
        <h2 style="margin-bottom:24px">สะสมแต้มได้จากทุกการใช้บริการ</h2>
        <div style="display:flex;flex-direction:column;gap:16px">
          {[
            { icon:'fa6-solid:stethoscope', color:'#0891B2', title:'ค่าบริการตรวจรักษา', desc:'ทุก 100 บาท = 1 แต้ม (ขึ้นอยู่กับระดับสมาชิก)' },
            { icon:'fa6-solid:box-open', color:'#8B5CF6', title:'ซื้อแพ็กเกจสุขภาพ', desc:'แต้มโบนัส 2 เท่าสำหรับแพ็กเกจตรวจสุขภาพ' },
            { icon:'fa6-solid:video', color:'#10B981', title:'Telehealth', desc:'ทุกครั้งที่ใช้บริการ Telehealth รับ 50 แต้ม' },
            { icon:'fa6-solid:user-plus', color:'#F59E0B', title:'แนะนำเพื่อน', desc:'แนะนำเพื่อนสมัครสมาชิก รับ 200 แต้ม' },
          ].map(e => (
            <div style="display:flex;gap:16px;align-items:flex-start">
              <div style={`width:48px;height:48px;border-radius:12px;background:${e.color}15;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
                <Icon name={e.icon} style={`color:${e.color};width:1.2rem;height:1.2rem`} />
              </div>
              <div>
                <strong style="color:var(--primary);font-size:.9rem">{e.title}</strong>
                <p style="font-size:.8rem;color:var(--gray-600);margin-top:2px">{e.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="reveal-right">
        <div style="background:linear-gradient(135deg,#1B3A6B,#0891B2);border-radius:24px;padding:32px;color:#fff">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
            <div style="font-size:1.2rem;font-weight:700">MediThai Card</div>
            <Icon name="fa6-solid:id-card" style="font-size:1.5rem;opacity:.7" />
          </div>
          <div style="font-size:.8rem;opacity:.6;margin-bottom:4px">สมาชิกหมายเลข</div>
          <div style="font-size:1.2rem;letter-spacing:4px;margin-bottom:24px">MT•••• •••• 4521</div>
          <div style="display:flex;justify-content:space-between">
            <div>
              <div style="font-size:.7rem;opacity:.6">แต้มสะสม</div>
              <div style="font-size:1.5rem;font-weight:800">12,450</div>
            </div>
            <div>
              <div style="font-size:.7rem;opacity:.6">ระดับ</div>
              <div style="font-size:1.5rem;font-weight:800">Gold 🥇</div>
            </div>
            <div>
              <div style="font-size:.7rem;opacity:.6">มูลค่า</div>
              <div style="font-size:1.5rem;font-weight:800">฿1,245</div>
            </div>
          </div>
        </div>
        <div style="background:var(--gray-50);border-radius:16px;padding:20px;margin-top:16px">
          <p style="font-weight:600;color:var(--primary);margin-bottom:12px">แลกแต้มเป็น</p>
          {[['100 แต้ม = ส่วนลด ฿10','fa6-solid:tag'],['500 แต้ม = ตรวจสุขภาพ Basic','fa6-solid:heart-pulse'],['1,000 แต้ม = Telehealth 1 ครั้ง','fa6-solid:video']].map(([t,i]) => (
            <div style="display:flex;gap:8px;align-items:center;font-size:.875rem;color:var(--gray-700);margin-bottom:8px">
              <Icon name={i} style="color:var(--secondary)" /> {t}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-pad-sm" style="background:var(--primary);color:#fff;text-align:center">
  <div class="container">
    <h2 style="margin-bottom:12px">สมัครสมาชิกฟรี — เริ่มสะสมแต้มวันนี้</h2>
    <p style="opacity:.8;margin-bottom:24px">สมัครฟรี ไม่มีค่าใช้จ่าย สะสมแต้มได้ทันทีตั้งแต่การใช้บริการครั้งแรก</p>
    <a href="/register" class="btn btn-accent"><Icon name="fa6-solid:id-card" /> สมัครสมาชิกเลย</a>
  </div>
</section>

</Layout>
