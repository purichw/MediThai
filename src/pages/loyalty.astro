---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('loyalty');
const heroTitle = cms.t('hero', 'pg_title', 'MediThai Loyalty Card', 'MediThai Loyalty Card');
const heroDesc  = cms.t('hero', 'pg_desc', 'สะสมแต้มทุกครั้งที่ใช้บริการ แลกรับส่วนลด และสิทธิพิเศษในโรงพยาบาลเครือ MediThai ทั้ง 6 สาขา', 'Earn points with every visit, redeem for discounts and special privileges across all 6 MediThai hospitals.');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th };

const trTag     = cms.t('tiers', 'tag', 'ระดับสมาชิก', 'Membership Tiers');
const trHeading = cms.t('tiers', 'heading', '4 ระดับ สิทธิประโยชน์ที่แตกต่างกัน', '4 tiers with distinct benefits');
const CHECKT = (color: string) => `<span style="color:${color};font-weight:700;flex-shrink:0">✓</span>`;
const perkLis = (text: string, color: string) => (text || '').split('\n').filter(Boolean).map(p =>
  `<li style="display:flex;gap:8px;align-items:flex-start;font-size:.8rem;color:var(--gray-700);margin-bottom:6px">${CHECKT(color)} ${p}</li>`).join('');
const tiers = cms.items('tiers', 'items').map((it, i) => {
  const color = it.color || '#94A3B8';
  const perks = cms.li('tiers', 'items', i, 'perks', it);
  return {
    name: it.name, emoji: it.emoji || '🏅', color,
    thb:    cms.li('tiers', 'items', i, 'thb', it),
    points: cms.li('tiers', 'items', i, 'points', it),
    perksHtml: cms.t('tiers', `tier${i}_perks_html`, perkLis(perks.th, color), perkLis(perks.en, color)),
  };
});

const erTag     = cms.t('earn', 'tag', 'สะสมแต้ม', 'Earning Points');
const erHeading = cms.t('earn', 'heading', 'สะสมแต้มได้จากทุกการใช้บริการ', 'Earn points from every service');
const earns = cms.items('earn', 'items').map((it, i) => ({
  icon: it.icon || 'star', color: it.color || '#0891B2',
  title: cms.li('earn', 'items', i, 'title', it),
  desc:  cms.li('earn', 'items', i, 'desc', it),
}));
const redeems = cms.items('earn', 'redeem').map((it, i) => ({
  icon: it.icon || 'tag',
  text: cms.li('earn', 'redeem', i, 'text', it),
}));

const ctaHeading = cms.t('cta', 'heading', 'สมัครสมาชิกฟรี — เริ่มสะสมแต้มวันนี้', 'Join free — start earning today');
const ctaSub     = cms.t('cta', 'sub', 'สมัครฟรี ไม่มีค่าใช้จ่าย สะสมแต้มได้ทันทีตั้งแต่การใช้บริการครั้งแรก', 'Free to join — earn points from your very first visit.');
const ctaBtn     = cms.t('cta', 'btn', 'สมัครสมาชิกเลย', 'Sign Up Now');

const cmsScript = cms.script();
---
<Layout title="MediThai Card — โปรแกรมสมาชิก | MediThai" description="สะสมแต้มทุกครั้งที่ใช้บริการ แลกรับส่วนลด และสิทธิพิเศษมากมาย">
<Fragment set:html={cmsScript} />

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>MediThai Card</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
    <a href="/register" class="btn btn-accent" style="margin-top:24px"><Icon name="fa6-solid:id-card" /> สมัครสมาชิกฟรี</a>
  </div>
</section>

<!-- Tiers -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag" data-i18n={trTag.k}>{trTag.th}</span>
      <h2 data-i18n={trHeading.k}>{trHeading.th}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
      {tiers.map((t,i) => (
        <div class={`reveal${i===1?' reveal-delay-1':i===2?' reveal-delay-2':i===3?' reveal-delay-3':''}`} style={`background:${t.color}08;border-radius:20px;padding:28px;box-shadow:var(--shadow-sm);border:2px solid ${t.color}30`}>
          <div style={`font-size:2rem;margin-bottom:8px`}>{t.emoji}</div>
          <h3 style={`font-size:1.3rem;font-weight:800;color:${t.color};margin-bottom:4px`}>{t.name}</h3>
          <p style="font-size:.75rem;color:var(--gray-500);margin-bottom:12px">ยอดสะสม <span data-i18n={t.thb.k}>{t.thb.th}</span> บาท/ปี</p>
          <div style={`background:${t.color}15;border-radius:8px;padding:6px 12px;font-size:.8rem;font-weight:600;color:${t.color};margin-bottom:16px;display:inline-block`} data-i18n={t.points.k}>{t.points.th}</div>
          <ul style="list-style:none" data-i18n={t.perksHtml.k} set:html={t.perksHtml.th}></ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- How to earn -->
<section class="section-pad">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div class="reveal-left">
        <span class="tag" style="margin-bottom:16px" data-i18n={erTag.k}>{erTag.th}</span>
        <h2 style="margin-bottom:24px" data-i18n={erHeading.k}>{erHeading.th}</h2>
        <div style="display:flex;flex-direction:column;gap:16px">
          {earns.map(e => (
            <div style="display:flex;gap:16px;align-items:flex-start">
              <div style={`width:48px;height:48px;border-radius:12px;background:${e.color}15;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
                <Icon name={`fa6-solid:${e.icon}`} style={`color:${e.color};width:1.2rem;height:1.2rem`} />
              </div>
              <div>
                <strong style="color:var(--primary);font-size:.9rem" data-i18n={e.title.k}>{e.title.th}</strong>
                <p style="font-size:.8rem;color:var(--gray-600);margin-top:2px" data-i18n={e.desc.k}>{e.desc.th}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="reveal-right">
        <div style="background:linear-gradient(135deg,#1B3A6B,#0891B2);border-radius:24px;padding:32px;color:#fff">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
            <div style="font-size:1.2rem;font-weight:700">MediThai Card</div>
            <Icon name="fa6-solid:id-card" style="font-size:1.5rem;opacity:.7" />
          </div>
          <div style="font-size:.8rem;opacity:.6;margin-bottom:4px">สมาชิกหมายเลข</div>
          <div style="font-size:1.2rem;letter-spacing:4px;margin-bottom:24px">MT•••• •••• 4521</div>
          <div style="display:flex;justify-content:space-between">
            <div>
              <div style="font-size:.7rem;opacity:.6">แต้มสะสม</div>
              <div style="font-size:1.5rem;font-weight:800">12,450</div>
            </div>
            <div>
              <div style="font-size:.7rem;opacity:.6">ระดับ</div>
              <div style="font-size:1.5rem;font-weight:800">Gold 🥇</div>
            </div>
            <div>
              <div style="font-size:.7rem;opacity:.6">มูลค่า</div>
              <div style="font-size:1.5rem;font-weight:800">฿1,245</div>
            </div>
          </div>
        </div>
        <div style="background:var(--gray-50);border-radius:16px;padding:20px;margin-top:16px">
          <p style="font-weight:600;color:var(--primary);margin-bottom:12px">แลกแต้มเป็น</p>
          {redeems.map(r => (
            <div style="display:flex;gap:8px;align-items:center;font-size:.875rem;color:var(--gray-700);margin-bottom:8px">
              <Icon name={`fa6-solid:${r.icon}`} style="color:var(--secondary)" /> <span data-i18n={r.text.k}>{r.text.th}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-pad-sm" style="background:var(--primary);color:#fff;text-align:center">
  <div class="container">
    <h2 style="margin-bottom:12px" data-i18n={ctaHeading.k}>{ctaHeading.th}</h2>
    <p style="opacity:.8;margin-bottom:24px" data-i18n={ctaSub.k}>{ctaSub.th}</p>
    <a href="/register" class="btn btn-accent"><Icon name="fa6-solid:id-card" /> <span data-i18n={ctaBtn.k}>{ctaBtn.th}</span></a>
  </div>
</section>

</Layout>
