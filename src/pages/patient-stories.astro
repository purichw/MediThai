---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('patient-stories');

const heroTitle = cms.t('hero', 'pg_title', 'เรื่องราวความสำเร็จของผู้ป่วย', 'Patient Success Stories');
const heroDesc  = cms.t('hero', 'pg_desc', 'ฟังเรื่องราวจริงของผู้ป่วยที่ฟื้นคืนสุขภาพและคุณภาพชีวิตที่ดีกลับมา', 'Hear real stories of patients who regained their health and quality of life.');

const stats = cms.items('stats', 'items').map((it, i) => ({
  num: it.num, icon: it.icon || 'circle-check',
  label: cms.li('stats', 'items', i, 'label', it),
}));

const stTag     = cms.t('stories', 'tag', 'Patient Stories', 'Patient Stories');
const stHeading = cms.t('stories', 'heading', 'ชีวิตที่เปลี่ยนไป', 'Lives Changed');
const stSub     = cms.t('stories', 'sub', 'เรื่องราวจริงจากผู้ป่วยที่ไว้วางใจทีมแพทย์ MediThai', 'Real stories from patients who trusted MediThai doctors');
const stories = cms.items('stories', 'items').map((it, i) => ({
  icon: it.icon || 'heart-pulse', color: it.color || '#0891B2',
  name:      cms.li('stories', 'items', i, 'name', it),
  condition: cms.li('stories', 'items', i, 'condition', it),
  hospital:  cms.li('stories', 'items', i, 'hospital', it),
  quote:     cms.li('stories', 'items', i, 'quote', it),
  detail:    cms.li('stories', 'items', i, 'detail', it),
}));

const ctaHeading = cms.t('cta', 'heading', 'อยากแชร์ประสบการณ์ของคุณ?', 'Want to share your experience?');
const ctaSub     = cms.t('cta', 'sub', 'เรื่องราวของคุณอาจเป็นแรงบันดาลใจให้ผู้อื่นกล้าดูแลสุขภาพ', 'Your story could inspire others to take charge of their health.');
const ctaBtn     = cms.t('cta', 'btn', 'ส่งเรื่องราวของคุณ', 'Send Your Story');

const cmsScript = cms.script();
---
<Layout title="เรื่องราวผู้ป่วย | MediThai Hospital Network" description="ฟังเรื่องราวของผู้ป่วยที่ฟื้นคืนสุขภาพกลับมาได้ด้วยทีมแพทย์ MediThai"
  extraHead={`${cmsScript}<style>
  .story-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; }
  @media(max-width:1000px){ .story-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:640px){ .story-grid{grid-template-columns:1fr;} }
  .story-card { background:#fff; border-radius:20px; padding:32px; box-shadow:var(--shadow-md); display:flex; flex-direction:column; transition:transform .3s,box-shadow .3s; }
  .story-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
  .story-quote { font-size:1rem; color:var(--gray-700); line-height:1.8; font-style:italic; flex:1; margin-bottom:20px; position:relative; padding-top:24px; }
  .story-quote::before { content:'"'; position:absolute; top:-8px; left:-4px; font-size:4rem; color:var(--gray-200); font-family:Georgia,serif; line-height:1; }
  .story-author { display:flex; align-items:center; gap:12px; padding-top:16px; border-top:1px solid var(--gray-100); }
  .story-avatar { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  </style>`}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span>เรื่องราวผู้ป่วย</span></div>
    <h1 data-i18n={heroTitle.k}>{heroTitle.th}</h1>
    <p data-i18n={heroDesc.k} set:html={heroDesc.th}></p>
  </div>
</section>

<!-- Stats -->
<section style="background:#fff;padding:48px 0;border-bottom:1px solid var(--gray-100)">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center">
      {stats.map(s => (
        <div class="reveal">
          <div style="font-size:2rem;margin-bottom:8px;color:var(--secondary)"><Icon name={`fa6-solid:${s.icon}`} /></div>
          <div style="font-size:2rem;font-weight:800;color:var(--primary)">{s.num}</div>
          <div style="font-size:.875rem;color:var(--gray-600)" data-i18n={s.label.k}>{s.label.th}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Stories -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag" data-i18n={stTag.k}>{stTag.th}</span>
      <h2 data-i18n={stHeading.k}>{stHeading.th}</h2>
      <p data-i18n={stSub.k}>{stSub.th}</p>
    </div>
    <div class="story-grid">
      {stories.map((s, i) => (
        <div class={`story-card reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
          <div class="story-quote" data-i18n={s.quote.k}>{s.quote.th}</div>
          <div style="font-size:.8rem;color:var(--gray-500);margin-bottom:16px;background:var(--gray-50);border-radius:8px;padding:8px 12px" data-i18n={s.detail.k}>{s.detail.th}</div>
          <div class="story-author">
            <div class="story-avatar" style={`background:${s.color}20`}>
              <Icon name={`fa6-solid:${s.icon}`} style={`color:${s.color};width:1.2rem;height:1.2rem`} />
            </div>
            <div>
              <div style="font-weight:700;font-size:.9rem;color:var(--primary)" data-i18n={s.name.k}>{s.name.th}</div>
              <div style="font-size:.78rem;color:var(--gray-500)"><span data-i18n={s.condition.k}>{s.condition.th}</span> · <span data-i18n={s.hospital.k}>{s.hospital.th}</span></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Share your story CTA -->
<section class="section-pad-sm" style="background:var(--primary);color:#fff;text-align:center">
  <div class="container">
    <Icon name="fa6-solid:heart" style="font-size:2rem;margin-bottom:16px;color:var(--accent)" />
    <h2 style="margin-bottom:12px" data-i18n={ctaHeading.k}>{ctaHeading.th}</h2>
    <p style="opacity:.8;margin-bottom:24px" data-i18n={ctaSub.k}>{ctaSub.th}</p>
    <a href="/contact" class="btn btn-accent" data-i18n={ctaBtn.k}>{ctaBtn.th}</a>
  </div>
</section>

</Layout>
