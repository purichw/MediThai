---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('locations');
const heroTitle = cms.t('hero', 'pg_title', 'สาขาของเรา', 'Our Locations');
const heroDesc  = cms.t('hero', 'pg_desc', '6 โรงพยาบาลในเครือ ทั่วประเทศไทย', '6 hospitals in our network across Thailand');
const th = { pg_title: heroTitle.th, pg_desc: heroDesc.th };

const branches = cms.items('branches', 'items').map((it, i) => {
  const grad = (it.grad || '#0F2447,#1B3A6B').split(',');
  return {
    num: i + 1, subtitle: it.subtitle || '', badge: it.badge || '', phone: it.phone || '',
    g1: grad[0], g2: grad[1] || grad[0], maps: it.maps || 'https://maps.google.com',
    services: (it.services_th || '').split(',').map(x => x.trim()).filter(Boolean),
    name:          cms.li('branches', 'items', i, 'name', it),
    address:       cms.li('branches', 'items', i, 'address', it),
    hours:         cms.li('branches', 'items', i, 'hours', it),
    extraLabel:    cms.li('branches', 'items', i, 'extra_label', it),
    extraText:     cms.li('branches', 'items', i, 'extra_text', it),
    servicesLabel: cms.li('branches', 'items', i, 'services_label', it),
  };
});

const cmsScript = cms.script();
---
<Layout title="สาขาของเรา | MediThai Hospital Network" description="6 โรงพยาบาลในเครือ ทั่วประเทศไทย"
  extraHead={`${cmsScript}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <style>
    .loc-detail-card{background:#fff;border-radius:var(--radius-xl);box-shadow:var(--shadow-lg);overflow:hidden;border:1px solid var(--gray-200);margin-bottom:36px;scroll-margin-top:calc(var(--header-height) + 20px);}
    .loc-detail-header{background:linear-gradient(135deg,var(--primary-dark),var(--primary));padding:28px 32px;display:flex;align-items:center;gap:20px;}
    .loc-num{width:48px;height:48px;border-radius:12px;background:rgba(255,255,255,.15);color:#fff;font-family:var(--font-heading);font-size:1.4rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .loc-detail-header h2{color:#fff;font-size:1.2rem;margin-bottom:4px;}
    .loc-detail-header p{color:rgba(255,255,255,.7);font-size:.82rem;}
    .loc-detail-body{padding:28px 32px;}
    .loc-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
    @media(max-width:600px){.loc-info-grid{grid-template-columns:1fr;}}
    .loc-info-item{display:flex;gap:12px;align-items:flex-start;}
    .loc-info-item [data-icon]{color:var(--secondary);margin-top:2px;width:16px;flex-shrink:0;}
    .loc-info-item h4{font-size:.82rem;color:var(--gray-500);margin-bottom:2px;}
    .loc-info-item p{font-size:.88rem;color:var(--gray-800);font-weight:500;}
    .services-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px;}
    .services-chip{background:rgba(8,145,178,.08);color:var(--secondary);font-size:.75rem;font-weight:600;padding:4px 12px;border-radius:99px;}
    #main-map{height:500px;border-radius:var(--radius-xl);box-shadow:var(--shadow-xl);overflow:hidden;}
    </style>
  `}
  extraScripts={`
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
      if(typeof L === 'undefined') return;
      const map = L.map('main-map', { center:[13.8,100.52], zoom:10, scrollWheelZoom:false });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap © CartoDB',maxZoom:19}).addTo(map);
      L.control.zoom({position:'topright'}).addTo(map);
      const hospitals = [
        {lat:13.7328,lng:100.5308,name:'MediThai กรุงเทพ (HQ)',color:'#1B3A6B',id:'loc-1'},
        {lat:13.7563,lng:100.5018,name:'MediThai หัวใจ',color:'#EF4444',id:'loc-2'},
        {lat:13.7969,lng:100.5600,name:'MediThai มะเร็ง',color:'#8B5CF6',id:'loc-3'},
        {lat:13.7144,lng:100.4612,name:'MediThai สมองและกระดูก',color:'#0891B2',id:'loc-4'},
        {lat:13.8200,lng:100.5200,name:'MediThai เด็ก',color:'#10B981',id:'loc-5'},
        {lat:18.7883,lng:98.9853,name:'MediThai เชียงใหม่ ✨ใหม่',color:'#F59E0B',id:'loc-6'},
      ];
      hospitals.forEach(h => {
        const icon = L.divIcon({className:'',html:'<div style="width:36px;height:36px;background:'+h.color+';border:3px solid #fff;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 4px 12px rgba(0,0,0,.25);display:flex;align-items:center;justify-content:center"></div>',iconSize:[36,48],iconAnchor:[18,46],popupAnchor:[0,-48]});
        L.marker([h.lat,h.lng],{icon}).addTo(map)
          .bindPopup('<div class="map-popup"><h4>'+h.name+'</h4><a href="#'+h.id+'">ดูรายละเอียด →</a></div>');
      });
    });
    </script>
  `}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span data-i18n="nav_hospitals">โรงพยาบาล</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
  </div>
</section>

<section class="section-pad-sm" style="background:var(--gray-50)">
  <div class="container">
    <div id="main-map" class="reveal"></div>
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:20px;justify-content:center">
      <a href="#loc-1" class="btn btn-outline btn-sm"><Icon name="fa6-solid:building-columns" /> กรุงเทพ (HQ)</a>
      <a href="#loc-2" class="btn btn-outline btn-sm"><Icon name="fa6-solid:heart-pulse" style="color:#EF4444" /> หัวใจ</a>
      <a href="#loc-3" class="btn btn-outline btn-sm"><Icon name="fa6-solid:ribbon" style="color:#8B5CF6" /> มะเร็ง</a>
      <a href="#loc-4" class="btn btn-outline btn-sm"><Icon name="fa6-solid:brain" style="color:#0891B2" /> สมองฯ</a>
      <a href="#loc-5" class="btn btn-outline btn-sm"><Icon name="fa6-solid:child" style="color:#10B981" /> เด็ก</a>
      <a href="#loc-6" class="btn btn-outline btn-sm"><Icon name="fa6-solid:mountain-city" style="color:#F59E0B" /> เชียงใหม่ ใหม่!</a>
    </div>
  </div>
</section>

<section class="section-pad" style="background:#fff">
  <div class="container">

    {branches.map(b => (
      <div class="loc-detail-card reveal" id={`loc-${b.num}`}>
        <div class="loc-detail-header" style={`background:linear-gradient(135deg,${b.g1},${b.g2})`}>
          <div class="loc-num">{b.num}</div>
          <div>
            <h2><span data-i18n={b.name.k}>{b.name.th}</span>{b.badge && <span style="background:var(--accent);color:#fff;font-size:.7rem;font-weight:700;padding:3px 8px;border-radius:99px;vertical-align:middle;margin-left:8px">{b.badge}</span>}</h2>
            <p>{b.subtitle}</p>
          </div>
          <span class="open-badge" style="margin-left:auto;background:rgba(255,255,255,.2);padding:6px 14px;border-radius:99px" data-i18n="map_open">เปิดให้บริการ</span>
        </div>
        <div class="loc-detail-body">
          <div class="loc-info-grid">
            <div>
              <div class="loc-info-item"><Icon name="fa6-solid:location-dot" /><div><h4>ที่อยู่</h4><p data-i18n={b.address.k} set:html={b.address.th}></p></div></div>
              <div class="loc-info-item" style="margin-top:12px"><Icon name="fa6-solid:phone" /><div><h4>โทรศัพท์</h4><p>{b.phone}</p></div></div>
              <div class="loc-info-item" style="margin-top:12px"><Icon name="fa6-solid:clock" /><div><h4>เวลาทำการ</h4><p data-i18n={b.hours.k} set:html={b.hours.th}></p></div></div>
              {b.extraLabel.th && <div class="loc-info-item" style="margin-top:12px"><Icon name="fa6-solid:circle-info" /><div><h4 data-i18n={b.extraLabel.k}>{b.extraLabel.th}</h4><p data-i18n={b.extraText.k} set:html={b.extraText.th}></p></div></div>}
            </div>
            <div>
              <div class="loc-info-item"><Icon name="fa6-solid:stethoscope" /><div><h4 data-i18n={b.servicesLabel.k}>{b.servicesLabel.th}</h4></div></div>
              <div class="services-chips">
                {b.services.map(sv => <span class="services-chip">{sv}</span>)}
              </div>
              <div style="margin-top:20px;display:flex;gap:10px;flex-wrap:wrap">
                <a href="/appointments" class="btn btn-primary btn-sm"><Icon name="fa6-solid:calendar-check" /> นัดหมาย</a>
                <a href={b.maps} target="_blank" class="btn btn-outline btn-sm"><Icon name="fa6-solid:map-location-dot" /> ดูแผนที่</a>
                <a href={`tel:${b.phone.replace(/[\s-]/g, '')}`} class="btn btn-outline btn-sm"><Icon name="fa6-solid:phone" /> โทรหา</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}

  </div>
</section>

</Layout>
