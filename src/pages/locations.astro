    <div id="main-map" class="reveal"></div>
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:20px;justify-content:center">
      <a href="#loc-1" class="btn btn-outline btn-sm"><Icon name="fa6-solid:building-columns" /> กรุงเทพ (HQ)</a>
      <a href="#loc-2" class="btn btn-outline btn-sm"><Icon name="fa6-solid:heart-pulse" style="color:#EF4444" /> หัวใจ</a>
      <a href="#loc-3" class="btn btn-outline btn-sm"><Icon name="fa6-solid:ribbon" style="color:#8B5CF6" /> มะเร็ง</a>
      <a href="#loc-4" class="btn btn-outline btn-sm"><Icon name="fa6-solid:brain" style="color:#0891B2" /> สมองฯ</a>
      <a href="#loc-5" class="btn btn-outline btn-sm"><Icon name="fa6-solid:child" style="color:#10B981" /> เด็ก</a>
      <a href="#loc-6" class="btn btn-outline btn-sm"><Icon name="fa6-solid:mountain-city" style="color:#F59E0B" /> เชียงใหม่ ใหม่!</a>
