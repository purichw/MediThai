---
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout title="สาขาของเรา | MediThai Hospital Network" description="6 โรงพยาบาลในเครือ ทั่วประเทศไทย"
  extraHead={`
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <style>
    .loc-detail-card{background:#fff;border-radius:var(--radius-xl);box-shadow:var(--shadow-lg);overflow:hidden;border:1px solid var(--gray-200);margin-bottom:36px;scroll-margin-top:calc(var(--header-height) + 20px);}
    .loc-detail-header{background:linear-gradient(135deg,var(--primary-dark),var(--primary));padding:28px 32px;display:flex;align-items:center;gap:20px;}
    .loc-num{width:48px;height:48px;border-radius:12px;background:rgba(255,255,255,.15);color:#fff;font-family:var(--font-heading);font-size:1.4rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .loc-detail-header h2{color:#fff;font-size:1.2rem;margin-bottom:4px;}
    .loc-detail-header p{color:rgba(255,255,255,.7);font-size:.82rem;}
    .loc-detail-body{padding:28px 32px;}
    .loc-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
    @media(max-width:600px){.loc-info-grid{grid-template-columns:1fr;}}
    .loc-info-item{display:flex;gap:12px;align-items:flex-start;}
    .loc-info-item [data-icon]{color:var(--secondary);margin-top:2px;width:16px;flex-shrink:0;}
    .loc-info-item h4{font-size:.82rem;color:var(--gray-500);margin-bottom:2px;}
    .loc-info-item p{font-size:.88rem;color:var(--gray-800);font-weight:500;}
    .services-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px;}
    .services-chip{background:rgba(8,145,178,.08);color:var(--secondary);font-size:.75rem;font-weight:600;padding:4px 12px;border-radius:99px;}
    #main-map{height:500px;border-radius:var(--radius-xl);box-shadow:var(--shadow-xl);overflow:hidden;}
    </style>
  `}
  extraScripts={`
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
      if(typeof L === 'undefined') return;
      const map = L.map('main-map', { center:[13.8,100.52], zoom:10, scrollWheelZoom:false });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap © CartoDB',maxZoom:19}).addTo(map);
      L.control.zoom({position:'topright'}).addTo(map);
      const hospitals = [
        {lat:13.7328,lng:100.5308,name:'MediThai กรุงเทพ (HQ)',color:'#1B3A6B',id:'loc-1'},
        {lat:13.7563,lng:100.5018,name:'MediThai หัวใจ',color:'#EF4444',id:'loc-2'},
        {lat:13.7969,lng:100.5600,name:'MediThai มะเร็ง',color:'#8B5CF6',id:'loc-3'},
        {lat:13.7144,lng:100.4612,name:'MediThai สมองและกระดูก',color:'#0891B2',id:'loc-4'},
        {lat:13.8200,lng:100.5200,name:'MediThai เด็ก',color:'#10B981',id:'loc-5'},
        {lat:18.7883,lng:98.9853,name:'MediThai เชียงใหม่ ✨ใหม่',color:'#F59E0B',id:'loc-6'},
      ];
      hospitals.forEach(h => {
        const icon = L.divIcon({className:'',html:'<div style="width:36px;height:36px;background:'+h.color+';border:3px solid #fff;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 4px 12px rgba(0,0,0,.25);display:flex;align-items:center;justify-content:center"></div>',iconSize:[36,48],iconAnchor:[18,46],popupAnchor:[0,-48]});
        L.marker([h.lat,h.lng],{icon}).addTo(map)
          .bindPopup('<div class="map-popup"><h4>'+h.name+'</h4><a href="#'+h.id+'">ดูรายละเอียด →</a></div>');
      });
    });
    </script>
  `}
>

<section class="page-hero">
  <div class="container">
