---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { loadPageCMS } from '../lib/cmsPage';
const { th, cmsScript } = await loadPageCMS('executive-health', {
  pg_title: 'Executive Health Program',
  pg_desc: 'โปรแกรมตรวจสุขภาพเชิงลึกสำหรับผู้บริหาร ออกแบบมาเพื่อคุณโดยเฉพาะ',
  pg_title_en: 'Executive Health Program',
  pg_desc_en: 'In-depth health screening for executives, designed specifically for you',
});
---
<Layout title="Executive Health Program | MediThai" description="โปรแกรมตรวจสุขภาพ VIP สำหรับผู้บริหาร ครบถ้วน แม่นยำ เป็นส่วนตัว"
  extraHead={`${cmsScript}<style>
  .exec-package { background:#fff; border-radius:20px; overflow:hidden; box-shadow:var(--shadow-md); }
  .exec-pkg-header { padding:32px 32px 20px; }
  .exec-pkg-body { padding:0 32px 32px; }
  .check-item { display:flex; gap:10px; align-items:flex-start; padding:8px 0; border-bottom:1px solid var(--gray-50); font-size:.875rem; color:var(--gray-700); }
  .check-item:last-child { border:none; }
  .exec-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; }
  @media(max-width:900px){ .exec-grid{grid-template-columns:1fr;} }
  </style>`}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><a href="/packages">แพ็กเกจ</a><Icon name="fa6-solid:chevron-right" /><span>Executive Health</span></div>
    <h1 data-i18n="pg_title">{th.pg_title}</h1>
    <p data-i18n="pg_desc">{th.pg_desc}</p>
  </div>
</section>

<!-- Why -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div class="reveal-left">
        <span class="tag" style="margin-bottom:16px">สุขภาพที่ดีคือสินทรัพย์</span>
        <h2 style="margin-bottom:20px">ทำไมผู้บริหารต้องการ Executive Health</h2>
        <p style="color:var(--gray-700);line-height:1.8;margin-bottom:20px">สถิติชี้ว่าผู้บริหารระดับสูงมีความเสี่ยงด้านสุขภาพสูงกว่าคนทั่วไป เนื่องจากความเครียดสะสม การนอนไม่หลับ และการดูแลสุขภาพที่ไม่สม่ำเสมอ โปรแกรม Executive Health ของ MediThai ออกแบบมาเพื่อตรวจหาความเสี่ยงเหล่านี้ล่วงหน้า</p>
        {[
          'ตรวจครบถ้วนใน 1 วัน ไม่เสียเวลาทำงาน',
          'แพทย์ผู้เชี่ยวชาญ 3–5 ท่าน ดูแลเฉพาะคุณ',
          'ผลตรวจพร้อมพร้อมรายงานโดยละเอียดภายใน 2 ชั่วโมง',
          'ห้องตรวจ VIP ส่วนตัว ไม่ต้องรอคิวรวม',
          'อาหารมื้อกลางวันคุณภาพพรีเมียมระหว่างรอผล',
        ].map(p => (
          <div style="display:flex;gap:10px;align-items:center;margin-bottom:10px">
            <Icon name="fa6-solid:circle-check" style="color:var(--secondary);flex-shrink:0" />
            <span style="font-size:.9rem;color:var(--gray-700)">{p}</span>
          </div>
        ))}
      </div>
      <div class="reveal-right" style="background:linear-gradient(135deg,var(--primary-dark),var(--primary));border-radius:24px;padding:40px;color:#fff">
        <div style="font-size:3rem;margin-bottom:16px">👔</div>
        <h3 style="font-size:1.5rem;margin-bottom:16px">ตัวเลขที่น่าตกใจ</h3>
        {[
          { n:'68%', l:'ของผู้บริหารไม่ตรวจสุขภาพครบถ้วนในรอบ 2 ปี' },
          { n:'43%', l:'มีภาวะความดันโลหิตสูงโดยไม่รู้ตัว' },
          { n:'31%', l:'มีไขมันในเลือดสูงผิดปกติ' },
          { n:'1 ใน 5', l:'มีความเสี่ยงโรคหัวใจในอีก 10 ปี' },
        ].map(s => (
          <div style="display:flex;gap:16px;align-items:center;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.15)">
            <div style="font-size:1.5rem;font-weight:800;color:var(--accent);flex-shrink:0;min-width:60px">{s.n}</div>
            <div style="font-size:.875rem;opacity:.85">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Packages -->
<section class="section-pad">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:48px">
      <span class="tag">โปรแกรม</span>
      <h2>เลือกโปรแกรมที่เหมาะกับคุณ</h2>
    </div>
    <div class="exec-grid">
      {[
        { name:'Executive Essential', price:'12,900', badge:'', color:'#0891B2',
          items:['ตรวจเลือดครบ 40+ รายการ','ECG','Chest X-ray','ตรวจสายตา การได้ยิน','BMI และองค์ประกอบร่างกาย','ตรวจปัสสาวะ อุจจาระ','พบแพทย์อายุรกรรมสรุปผล'] },
        { name:'Executive Premium', price:'24,900', badge:'แนะนำ', color:'#1B3A6B',
          items:['ทุกอย่างใน Essential','CT Calcium Score (ประเมินหัวใจ)','Echocardiogram','ตรวจมะเร็งลำไส้ใหญ่ (Colonoscopy)','Tumor Markers 8 ชนิด','Brain MRI','พบแพทย์ผู้เชี่ยวชาญ 3 ท่าน','รายงานโดยละเอียด + แผนสุขภาพ 1 ปี'] },
        { name:'Executive Elite', price:'49,900', badge:'ครบที่สุด', color:'#8B5CF6',
          items:['ทุกอย่างใน Premium','Full Body MRI','Genomic Risk Assessment (DNA)','Coronary CT Angiography','Functional Medicine Panel','ปรึกษาโภชนาการ + แพลนออกกำลังกาย','ติดตามผลทุก 3 เดือนตลอด 1 ปี','บริการ Concierge ตลอด 24 ชม.'] },
      ].map((p,i) => (
        <div class={`exec-package reveal${i===1?' reveal-delay-1':i===2?' reveal-delay-2':''}`} style={i===1?`border:2px solid ${p.color}`:''}>
          <div class="exec-pkg-header" style={`background:${p.color}10`}>
            {p.badge && <span style={`background:${p.color};color:#fff;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:8px;display:inline-block`}>{p.badge}</span>}
            <h3 style={`font-size:1.1rem;font-weight:700;color:${p.color};margin-bottom:4px`}>{p.name}</h3>
            <div style="display:flex;align-items:baseline;gap:4px">
              <span style="font-size:2rem;font-weight:800;color:var(--primary)">฿{p.price}</span>
              <span style="font-size:.8rem;color:var(--gray-500)">/ท่าน</span>
            </div>
          </div>
          <div class="exec-pkg-body">
            {p.items.map(it => (
              <div class="check-item">
                <Icon name="fa6-solid:check" style={`color:${p.color};flex-shrink:0;margin-top:2px`} />
                <span>{it}</span>
              </div>
            ))}
            <a href="/appointments" class="btn btn-primary" style={`width:100%;justify-content:center;margin-top:20px;background:${p.color};border-color:${p.color}`}>
              จองโปรแกรมนี้
            </a>
          </div>
        </div>
      ))}
    </div>
    <p style="text-align:center;font-size:.875rem;color:var(--gray-500);margin-top:24px">
      * ราคารวม VAT · สามารถใช้สิทธิ์ประกันสุขภาพได้บางส่วน · โทรสอบถาม 02-310-3000
    </p>
  </div>
</section>

<!-- Corporate -->
<section class="section-pad-sm" style="background:var(--primary);color:#fff;text-align:center">
  <div class="container">
    <h2 style="margin-bottom:12px">โปรแกรมองค์กร — ดูแลทีมผู้บริหารของคุณ</h2>
    <p style="opacity:.8;margin-bottom:24px">MediThai มีแพ็กเกจพิเศษสำหรับองค์กรที่ต้องการดูแลสุขภาพพนักงานหรือผู้บริหารเป็นหมู่คณะ ราคาพิเศษสำหรับ 5 ท่านขึ้นไป</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/corporate" class="btn btn-accent">ดูโปรแกรมองค์กร</a>
      <a href="/contact" class="btn btn-outline" style="color:#fff;border-color:rgba(255,255,255,.5)">ติดต่อทีมองค์กร</a>
    </div>
  </div>
</section>

</Layout>
