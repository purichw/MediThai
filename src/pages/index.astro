---
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout
  title="MediThai Hospital Network | เครือโรงพยาบาลเมดิไทย"
  description="เครือโรงพยาบาล MediThai — ดูแลทุกชีวิต ด้วยมาตรฐานระดับโลก | MediThai Hospital Network — World-Class Care"
  extraHead={`
    <link rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  `}
  extraScripts={`
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  `}
>

<!-- HERO -->
<section class="hero">
  <div class="hero-image"></div>
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="container hero-inner">
      <!-- Left -->
      <div>
        <div class="hero-tag">
          <span></span>
          <span data-i18n="hero_tag">อันดับ 1 โรงพยาบาลไทย โดย Newsweek 2026</span>
        </div>
        <h1 class="hero-title">
          <span data-i18n="hero_title_1">ดูแลทุกชีวิต</span><br>
          <span class="accent" data-i18n="hero_title_2">ด้วยความเชี่ยวชาญ</span><br>
          <span data-i18n="hero_title_3">ระดับโลก</span>
        </h1>
        <p class="hero-desc" data-i18n="hero_desc">เครือโรงพยาบาล MediThai พร้อมทีมแพทย์ผู้เชี่ยวชาญกว่า 200 ท่าน ใน 6 สาขาทั่วประเทศ ดูแลคุณด้วยเทคโนโลยีทางการแพทย์ที่ทันสมัยที่สุด</p>
        <div class="hero-cta">
          <a href="/appointments" class="btn btn-primary btn-lg" data-i18n="hero_btn1">นัดหมายออนไลน์</a>
          <a href="/doctors" class="btn btn-secondary btn-lg" data-i18n="hero_btn2">ค้นหาแพทย์</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="num" data-i18n="hero_stat1_num">200+</div>
            <div class="label" data-i18n="hero_stat1_lbl">แพทย์เชี่ยวชาญ</div>
          </div>
          <div class="hero-stat">
            <div class="num" data-i18n="hero_stat2_num">6</div>
            <div class="label" data-i18n="hero_stat2_lbl">สาขาทั่วประเทศ</div>
          </div>
          <div class="hero-stat">
            <div class="num" data-i18n="hero_stat3_num">50K+</div>
            <div class="label" data-i18n="hero_stat3_lbl">ผู้ป่วยต่อปี</div>
          </div>
        </div>
      </div>
      <!-- Right — Quick Cards -->
      <div class="hero-cards">
        <a href="/appointments" class="hero-card">
          <div class="hero-card-icon teal"><Icon name="fa6-solid:calendar-check" /></div>
          <h4 data-i18n="qc1_title">นัดหมายออนไลน์</h4>
          <p data-i18n="qc1_desc">จองคิวได้ทันที</p>
        </a>
        <a href="/doctors" class="hero-card">
          <div class="hero-card-icon amber"><Icon name="fa6-solid:user-doctor" /></div>
          <h4 data-i18n="qc2_title">ค้นหาแพทย์</h4>
          <p data-i18n="qc2_desc">แพทย์เฉพาะทางกว่า 200 ท่าน</p>
        </a>
        <a href="/locations" class="hero-card">
          <div class="hero-card-icon green"><Icon name="fa6-solid:location-dot" /></div>
          <h4 data-i18n="qc3_title">สาขาใกล้คุณ</h4>
          <p data-i18n="qc3_desc">6 สาขาทั่วประเทศ</p>
        </a>
        <a href="/packages" class="hero-card">
          <div class="hero-card-icon purple"><Icon name="fa6-solid:tag" /></div>
          <h4 data-i18n="qc4_title">แพ็กเกจสุขภาพ</h4>
          <p data-i18n="qc4_desc">ราคาพิเศษ มีโปรโมชั่น</p>
        </a>
      </div>
    </div>
  </div>
  <div class="scroll-indicator">
    <div class="wheel"></div>
  </div>
</section>

<!-- QUICK ACTIONS BAR -->
<section class="quick-actions">
  <div class="container">
    <div class="quick-actions-inner reveal">
      <a href="/appointments" class="qa-item">
        <div class="qa-icon blue"><Icon name="fa6-solid:calendar-check" /></div>
        <div class="qa-text">
          <h4 data-i18n="qa1_title">นัดหมายแพทย์</h4>
          <p data-i18n="qa1_desc">นัดออนไลน์ 24 ชม.</p>
        </div>
      </a>
      <a href="/doctors" class="qa-item">
        <div class="qa-icon teal"><Icon name="fa6-solid:user-doctor" /></div>
        <div class="qa-text">
          <h4 data-i18n="qa2_title">ค้นหาแพทย์</h4>
          <p data-i18n="qa2_desc">เฉพาะทาง 30+ สาขา</p>
        </div>
      </a>
      <a href="/locations" class="qa-item">
        <div class="qa-icon amber"><Icon name="fa6-solid:location-dot" /></div>
        <div class="qa-text">
          <h4 data-i18n="qa3_title">สาขาใกล้ฉัน</h4>
          <p data-i18n="qa3_desc">6 โรงพยาบาลในเครือ</p>
        </div>
      </a>
      <a href="/packages" class="qa-item">
        <div class="qa-icon green"><Icon name="fa6-solid:tag" /></div>
        <div class="qa-text">
          <h4 data-i18n="qa4_title">แพ็กเกจ &amp; โปรโมชั่น</h4>
          <p data-i18n="qa4_desc">ราคาพิเศษ สิ้นสุด 31 ธ.ค.</p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <div class="stat-num"><span data-target="200" data-suffix="+">200+</span></div>
        <div class="stat-label" data-i18n="stat1_lbl">แพทย์เชี่ยวชาญ</div>
        <Icon name="fa6-solid:user-doctor" class="stat-icon" />
      </div>
      <div class="stat-item reveal reveal-delay-1">
        <div class="stat-num"><span data-target="6">6</span></div>
        <div class="stat-label" data-i18n="stat2_lbl">สาขาทั่วประเทศ</div>
        <Icon name="fa6-solid:hospital" class="stat-icon" />
      </div>
      <div class="stat-item reveal reveal-delay-2">
        <div class="stat-num"><span data-target="50000">50,000</span><span class="plus">+</span></div>
        <div class="stat-label" data-i18n="stat3_lbl">ผู้ป่วยต่อปี</div>
        <Icon name="fa6-solid:heart-pulse" class="stat-icon" />
      </div>
      <div class="stat-item reveal reveal-delay-3">
        <div class="stat-num"><span data-target="25">25</span></div>
        <div class="stat-label" data-i18n="stat4_lbl">ปีแห่งความเชี่ยวชาญ</div>
        <Icon name="fa6-solid:award" class="stat-icon" />
      </div>
    </div>
  </div>
</section>

<!-- SPECIALTIES -->
<section class="specialties-section section-pad">
  <div class="container">
    <div class="text-center reveal" style="margin-bottom:48px">
      <div class="tag"><Icon name="fa6-solid:stethoscope" /> <span data-i18n="sec_spec_tag">ศูนย์การแพทย์เฉพาะทาง</span></div>
      <h2 class="section-heading" data-i18n="sec_spec_title">บริการครบครัน ดูแลทุกความต้องการ</h2>
      <p class="section-sub" style="margin:0 auto" data-i18n="sec_spec_sub">ศูนย์การแพทย์เฉพาะทางระดับโลก พร้อมเทคโนโลยีและทีมแพทย์ผู้เชี่ยวชาญ</p>
    </div>
    <div class="specialties-grid">
      <a href="/doctors?spec=heart" class="specialty-card reveal">
        <div class="spec-icon"><Icon name="fa6-solid:heart-pulse" /></div>
        <h4 data-i18n="spec1">ศูนย์หัวใจ</h4>
        <p data-i18n="spec1d">โรคหัวใจ หลอดเลือด ผ่าตัดหัวใจ</p>
      </a>
      <a href="/doctors?spec=cancer" class="specialty-card reveal reveal-delay-1">
        <div class="spec-icon"><Icon name="fa6-solid:ribbon" /></div>
        <h4 data-i18n="spec2">ศูนย์มะเร็ง</h4>
        <p data-i18n="spec2d">วินิจฉัยและรักษาโรคมะเร็งครบวงจร</p>
      </a>
      <a href="/doctors?spec=neuro" class="specialty-card reveal reveal-delay-2">
        <div class="spec-icon"><Icon name="fa6-solid:brain" /></div>
        <h4 data-i18n="spec3">ศูนย์สมองฯ</h4>
        <p data-i18n="spec3d">ระบบประสาท สมอง กระดูกสันหลัง</p>
      </a>
      <a href="/doctors?spec=ortho" class="specialty-card reveal reveal-delay-3">
        <div class="spec-icon"><Icon name="fa6-solid:bone" /></div>
        <h4 data-i18n="spec4">ศูนย์กระดูก</h4>
        <p data-i18n="spec4d">ข้อเสื่อม กระดูกหัก กายภาพบำบัด</p>
      </a>
      <a href="/doctors?spec=peds" class="specialty-card reveal">
        <div class="spec-icon"><Icon name="fa6-solid:child-reaching" /></div>
        <h4 data-i18n="spec5">ศูนย์เด็ก</h4>
        <p data-i18n="spec5d">กุมารแพทย์ พัฒนาการเด็ก</p>
      </a>
      <a href="/doctors?spec=obgyn" class="specialty-card reveal reveal-delay-1">
        <div class="spec-icon"><Icon name="fa6-solid:venus" /></div>
        <h4 data-i18n="spec6">ศูนย์สตรี</h4>
        <p data-i18n="spec6d">สูติ-นรีเวช ฝากครรภ์ คลอด</p>
      </a>
      <a href="/doctors?spec=eye" class="specialty-card reveal reveal-delay-2">
        <div class="spec-icon"><Icon name="fa6-solid:eye" /></div>
        <h4 data-i18n="spec7">ศูนย์ตา</h4>
        <p data-i18n="spec7d">จักษุ LASIK ต้อกระจก</p>
      </a>
      <a href="/packages?cat=checkup" class="specialty-card reveal reveal-delay-3">
        <div class="spec-icon"><Icon name="fa6-solid:clipboard-list" /></div>
        <h4 data-i18n="spec8">ตรวจสุขภาพ</h4>
        <p data-i18n="spec8d">โปรแกรมตรวจสุขภาพประจำปี</p>
      </a>
    </div>
    <div class="text-center" style="margin-top:36px">
      <a href="/doctors" class="view-all-link" data-i18n="view_all">ดูทั้งหมด <Icon name="fa6-solid:arrow-right" /></a>
    </div>
  </div>
</section>

<!-- PACKAGES -->
<section class="packages-section section-pad">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:40px">
      <div class="reveal">
        <div class="tag"><Icon name="fa6-solid:tag" /> <span data-i18n="sec_pkg_tag">แพ็กเกจ &amp; โปรโมชั่น</span></div>
        <h2 class="section-heading" data-i18n="sec_pkg_title">แพ็กเกจสุขภาพราคาพิเศษ</h2>
        <p class="section-sub" data-i18n="sec_pkg_sub">ดูแลสุขภาพเชิงป้องกัน ด้วยแพ็กเกจที่ออกแบบมาเพื่อคุณโดยเฉพาะ</p>
      </div>
      <a href="/packages" class="view-all-link reveal" data-i18n="view_all">ดูทั้งหมด <Icon name="fa6-solid:arrow-right" /></a>
    </div>

    <div class="swiper packages-swiper" style="padding-bottom:48px">
      <div class="swiper-wrapper">

        <!-- Package 1 -->
        <div class="swiper-slide">
          <div class="package-card" data-cat="checkup">
            <div class="package-img" style="background:linear-gradient(135deg,#1B3A6B,#2554A0)">
              <Icon name="fa6-solid:user-tie" />
              <div class="package-badge hot">ยอดนิยม</div>
            </div>
            <div class="package-body">
              <div class="package-hospital"><Icon name="fa6-solid:hospital" /> MediThai กรุงเทพ</div>
              <div class="package-title">CEO Check-up Program ตรวจสุขภาพเชิงลึกสำหรับผู้บริหาร</div>
              <div class="package-price">
                <span class="price-current">฿129,000</span>
                <span class="price-original">฿145,000</span>
              </div>
              <div class="package-expires"><Icon name="fa6-regular:clock" /> <span data-i18n="pkg_expires">สิ้นสุด</span> 31 ธ.ค. 2569</div>
              <div class="package-footer">
                <a href="/packages" class="btn btn-outline btn-sm" data-i18n="pkg_detail">รายละเอียด</a>
                <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="pkg_buy">ซื้อเลย</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Package 2 -->
        <div class="swiper-slide">
          <div class="package-card" data-cat="cancer">
            <div class="package-img" style="background:linear-gradient(135deg,#8B5CF6,#7C3AED)">
              <Icon name="fa6-solid:microscope" />
              <div class="package-badge new">ใหม่</div>
            </div>
            <div class="package-body">
              <div class="package-hospital"><Icon name="fa6-solid:hospital" /> MediThai มะเร็ง</div>
              <div class="package-title">PET/CT Scan ตรวจคัดกรองมะเร็ง Absolute Early Detection</div>
              <div class="package-price">
                <span class="price-current">฿72,400</span>
                <span class="price-original">฿181,695</span>
              </div>
              <div class="package-expires"><Icon name="fa6-regular:clock" /> <span data-i18n="pkg_expires">สิ้นสุด</span> 31 ธ.ค. 2569</div>
              <div class="package-footer">
                <a href="/packages" class="btn btn-outline btn-sm" data-i18n="pkg_detail">รายละเอียด</a>
                <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="pkg_buy">ซื้อเลย</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Package 3 -->
        <div class="swiper-slide">
          <div class="package-card" data-cat="heart">
            <div class="package-img" style="background:linear-gradient(135deg,#EF4444,#DC2626)">
              <Icon name="fa6-solid:heart-pulse" />
            </div>
            <div class="package-body">
              <div class="package-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div>
              <div class="package-title">3 โปรแกรมตรวจหัวใจ ออกแบบเพื่อคุณโดยเฉพาะ</div>
              <div class="package-price">
                <span class="price-current">฿7,500</span>
                <span class="price-unit">เริ่มต้น</span>
              </div>
              <div class="package-expires"><Icon name="fa6-regular:clock" /> <span data-i18n="pkg_expires">สิ้นสุด</span> 31 ธ.ค. 2569</div>
              <div class="package-footer">
                <a href="/packages" class="btn btn-outline btn-sm" data-i18n="pkg_detail">รายละเอียด</a>
                <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="pkg_buy">ซื้อเลย</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Package 4 -->
        <div class="swiper-slide">
          <div class="package-card" data-cat="checkup">
            <div class="package-img" style="background:linear-gradient(135deg,#0891B2,#0E7490)">
              <Icon name="fa6-solid:dna" />
              <div class="package-badge hot">พิเศษ</div>
            </div>
            <div class="package-body">
              <div class="package-hospital"><Icon name="fa6-solid:hospital" /> MediThai สมองฯ</div>
              <div class="package-title">Integrated GenomeXplorer ตรวจสุขภาพระดับ DNA</div>
              <div class="package-price">
                <span class="price-current">฿28,000</span>
                <span class="price-original">฿30,800</span>
              </div>
              <div class="package-expires"><Icon name="fa6-regular:clock" /> <span data-i18n="pkg_expires">สิ้นสุด</span> 31 ธ.ค. 2569</div>
              <div class="package-footer">
                <a href="/packages" class="btn btn-outline btn-sm" data-i18n="pkg_detail">รายละเอียด</a>
                <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="pkg_buy">ซื้อเลย</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Package 5 -->
        <div class="swiper-slide">
          <div class="package-card" data-cat="checkup">
            <div class="package-img" style="background:linear-gradient(135deg,#10B981,#059669)">
              <Icon name="fa6-solid:lungs" />
            </div>
            <div class="package-body">
              <div class="package-hospital"><Icon name="fa6-solid:hospital" /> MediThai กรุงเทพ</div>
              <div class="package-title">Low-dose CT Scan ตรวจคัดกรองมะเร็งปอด</div>
              <div class="package-price">
                <span class="price-current">฿6,900</span>
                <span class="price-original">฿9,440</span>
              </div>
              <div class="package-expires"><Icon name="fa6-regular:clock" /> <span data-i18n="pkg_expires">สิ้นสุด</span> 31 ธ.ค. 2569</div>
              <div class="package-footer">
                <a href="/packages" class="btn btn-outline btn-sm" data-i18n="pkg_detail">รายละเอียด</a>
                <a href="/appointments" class="btn btn-primary btn-sm" data-i18n="pkg_buy">ซื้อเลย</a>
              </div>
            </div>
          </div>
        </div>

      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<!-- DOCTORS -->
<section class="doctors-section section-pad">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:40px">
      <div class="reveal">
        <div class="tag"><Icon name="fa6-solid:user-doctor" /> <span data-i18n="sec_doc_tag">ทีมแพทย์ผู้เชี่ยวชาญ</span></div>
        <h2 class="section-heading" data-i18n="sec_doc_title">พบกับแพทย์ผู้เชี่ยวชาญของเรา</h2>
        <p class="section-sub" data-i18n="sec_doc_sub">ทีมแพทย์ระดับโลก พร้อมดูแลคุณด้วยความเชี่ยวชาญและความเอาใจใส่</p>
      </div>
      <a href="/doctors" class="view-all-link reveal" data-i18n="view_all">ดูทั้งหมด <Icon name="fa6-solid:arrow-right" /></a>
    </div>

    <div class="swiper doctors-swiper" style="padding-bottom:48px">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="doctor-card" data-specialty="heart" data-hospital="heart">
            <div class="doctor-photo">
              <div class="doctor-photo-placeholder"><Icon name="fa6-solid:user-doctor" /></div>
              <div class="doctor-specialty-badge">ศูนย์หัวใจ</div>
            </div>
            <div class="doctor-name">นพ. ชาติทนง ยอดวุฒิ</div>
            <div class="doctor-title">อายุรแพทย์โรคหัวใจ และหลอดเลือด</div>
            <div class="doctor-hospital"><Icon name="fa6-solid:hospital" /> MediThai หัวใจ</div>
            <div class="doctor-tags"><span class="doctor-tag">MitraClip</span><span class="doctor-tag">Electrophysiology</span></div>
            <a href="/appointments" class="btn btn-primary btn-sm" style="width:calc(100% - 40px);justify-content:center" data-i18n="doc_appt">นัดหมาย</a>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="doctor-card" data-specialty="cancer" data-hospital="cancer">
            <div class="doctor-photo">
              <div class="doctor-photo-placeholder" style="background:linear-gradient(135deg,#F3E8FF,#EDE9FE)"><Icon name="fa6-solid:user-doctor" style="color:#8B5CF6" /></div>
              <div class="doctor-specialty-badge" style="background:#8B5CF6">ศูนย์มะเร็ง</div>
            </div>
            <div class="doctor-name">พญ. ศรัณยา งามรัศมีวงศ์</div>
            <div class="doctor-title">รังสีแพทย์วินิจฉัย (Breast Imaging)</div>
