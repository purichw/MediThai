---
export const prerender = false;
import { createAdminSupabase, createServerSupabase } from '../../lib/supabase-server';
import { CMS_PAGES, CMS_PAGES_ALL } from '../../lib/cmsSchema';
import { DEFAULT_TH, DEFAULT_EN } from '../../lib/cmsDefaults';

// Map nav item IDs → which CMS page (+ optional section filter) to load inline
const NAV_CMS_MAP: Record<string, { slug: string; filter?: string[]; title?: string }> = {
  '__global':  { slug: 'global', title: '🌐 Global (Nav, Footer, Announcement)' },
  'home':      { slug: 'home',   title: '🏠 หน้าแรก' },
  'hospitals': { slug: 'global', filter: ['nav_hospitals'], title: '🏥 โรงพยาบาล — ชื่อ Dropdown' },
  'services':  { slug: 'global', filter: ['nav_services'],  title: '⚕️ บริการ — ชื่อ Dropdown' },
  // Hospital branch pages
  'h-bkk':    { slug: 'hospital-bkk',       title: '🏥 MediThai กรุงเทพ' },
  'h-heart':  { slug: 'hospital-heart',     title: '❤️ MediThai หัวใจ' },
  'h-cancer': { slug: 'hospital-cancer',    title: '🎗️ MediThai มะเร็ง' },
  'h-spine':  { slug: 'hospital-spine',     title: '🧠 MediThai สมองและกระดูก' },
  'h-child':  { slug: 'hospital-children',  title: '👶 MediThai เด็ก' },
  'h-cm':     { slug: 'hospital-chiangmai', title: '🌸 MediThai เชียงใหม่' },
};

// === AUTH ===
const supabaseUser = createServerSupabase(Astro.request, Astro.cookies);
const { data: { user } } = await supabaseUser.auth.getUser();
if (!user) return Astro.redirect('/login');
const { data: profile } = await supabaseUser.from('profiles').select('role').eq('id', user.id).single();
if (!profile || !['admin', 'staff'].includes(profile.role)) return Astro.redirect('/');

const supabase = createAdminSupabase();

// === OVERVIEW stats ===
const [{ count: total }, { count: pending }, { count: confirmed }, { count: today }] = await Promise.all([
  supabase.from('appointments').select('*', { count: 'exact', head: true }),
  supabase.from('appointments').select('*', { count: 'exact', head: true }).eq('status', 'pending'),
  supabase.from('appointments').select('*', { count: 'exact', head: true }).eq('status', 'confirmed'),
  supabase.from('appointments').select('*', { count: 'exact', head: true }).eq('appointment_date', new Date().toISOString().split('T')[0]),
]);
const { data: recentAppts } = await supabase.from('appointments').select('*').order('created_at', { ascending: false }).limit(10);

// === ALL APPOINTMENTS ===
const { data: allAppts } = await supabase.from('appointments').select('*').order('appointment_date', { ascending: true });

// === ANALYTICS ===
const host = Astro.url.origin;
const analyticsRes = await fetch(`${host}/api/admin/analytics`, {
  headers: { cookie: Astro.request.headers.get('cookie') || '' },
});
const analytics = analyticsRes.ok ? await analyticsRes.json() : null;

// === LAYOUT ===
const homePage = CMS_PAGES.find(p => p.slug === 'home')!;
const defaultOrder = homePage.sections.map(s => s.key);
const { data: layoutRow } = await supabase.from('site_content').select('content')
  .eq('page_slug', 'home').eq('section_key', '_layout').single();
const savedOrder: string[] = layoutRow?.content?.meta?.section_order
  ? JSON.parse(layoutRow.content.meta.section_order) : defaultOrder;
const hiddenSections: string[] = layoutRow?.content?.meta?.hidden_sections
  ? JSON.parse(layoutRow.content.meta.hidden_sections) : [];
const sectionMap = Object.fromEntries(homePage.sections.map(s => [s.key, s]));
const orderedKeys = [
  ...savedOrder.filter(k => k in sectionMap),
  ...defaultOrder.filter(k => !savedOrder.includes(k)),
];

// === COMPONENTS ===
const { data: components } = await supabase.from('page_components').select('*').order('section_key').order('sort_order');

// === NAV ===
const DEFAULT_NAV = [
  { id: 'home', label_th: 'หน้าแรก', label_en: 'Home', href: '/', visible: true, children: [] },
  { id: 'hospitals', label_th: 'โรงพยาบาล', label_en: 'Hospitals', href: null, visible: true, children: [
    { id: 'h-bkk', label_th: 'MediThai กรุงเทพ', label_en: 'MediThai Bangkok', href: '/hospitals/medithai-bangkok', visible: true },
    { id: 'h-heart', label_th: 'MediThai หัวใจ', label_en: 'MediThai Heart', href: '/hospitals/medithai-heart', visible: true },
    { id: 'h-cancer', label_th: 'MediThai มะเร็ง', label_en: 'MediThai Cancer', href: '/hospitals/medithai-cancer', visible: true },
    { id: 'h-spine', label_th: 'MediThai สมองและกระดูก', label_en: 'MediThai Spine', href: '/hospitals/medithai-spine', visible: true },
    { id: 'h-child', label_th: 'MediThai เด็ก', label_en: 'MediThai Children', href: '/hospitals/medithai-children', visible: true },
    { id: 'h-cm', label_th: 'MediThai เชียงใหม่', label_en: 'MediThai Chiang Mai', href: '/hospitals/medithai-chiangmai', visible: true },
  ]},
  { id: 'services', label_th: 'บริการ', label_en: 'Services', href: null, visible: true, children: [
    { id: 's-appt', label_th: 'นัดหมายแพทย์', label_en: 'Book Appointment', href: '/appointments', visible: true },
    { id: 's-tele', label_th: 'พบแพทย์ออนไลน์', label_en: 'Telehealth', href: '/telehealth', visible: true },
    { id: 's-sym', label_th: 'ตรวจสอบอาการ', label_en: 'Symptom Checker', href: '/symptoms', visible: true },
    { id: 's-rec', label_th: 'ขอเวชระเบียน', label_en: 'Medical Records', href: '/medical-records', visible: true },
    { id: 's-bill', label_th: 'ชำระค่าบริการ', label_en: 'Bill Payment', href: '/bill-payment', visible: true },
    { id: 's-exec', label_th: 'Executive Health', label_en: 'Executive Health', href: '/executive-health', visible: true },
  ]},
  { id: 'doctors', label_th: 'แพทย์', label_en: 'Doctors', href: '/doctors', visible: true, children: [] },
  { id: 'packages', label_th: 'แพ็กเกจ', label_en: 'Packages', href: null, visible: true, children: [
    { id: 'p-pkg', label_th: 'แพ็กเกจสุขภาพ', label_en: 'Health Packages', href: '/packages', visible: true },
    { id: 'p-exec', label_th: 'Executive Health', label_en: 'Executive Health', href: '/executive-health', visible: true },
    { id: 'p-card', label_th: 'MediThai Card', label_en: 'MediThai Card', href: '/loyalty', visible: true },
    { id: 'p-corp', label_th: 'บริการองค์กร', label_en: 'Corporate', href: '/corporate', visible: true },
  ]},
  { id: 'health', label_th: 'สุขภาพน่ารู้', label_en: 'Health Info', href: null, visible: true, children: [
    { id: 'hl-lib', label_th: 'คลังความรู้', label_en: 'Health Library', href: '/health-library', visible: true },
    { id: 'hl-sym', label_th: 'ตรวจสอบอาการ', label_en: 'Symptom Checker', href: '/symptoms', visible: true },
    { id: 'hl-calc', label_th: 'โปรแกรมคำนวณ', label_en: 'Calculators', href: '/calculators', visible: true },
    { id: 'hl-story', label_th: 'เรื่องราวผู้ป่วย', label_en: 'Patient Stories', href: '/patient-stories', visible: true },
  ]},
  { id: 'about', label_th: 'เกี่ยวกับเรา', label_en: 'About', href: null, visible: true, children: [
    { id: 'a-about', label_th: 'เกี่ยวกับเรา', label_en: 'About Us', href: '/about', visible: true },
    { id: 'a-expat', label_th: 'Expat Hub', label_en: 'Expat Hub', href: '/expat-hub', visible: true },
    { id: 'a-career', label_th: 'ร่วมงานกับเรา', label_en: 'Careers', href: '/careers', visible: true },
    { id: 'a-give', label_th: 'ร่วมสนับสนุน', label_en: 'Giving', href: '/giving', visible: true },
  ]},
];
const { data: navRow } = await supabase.from('site_content').select('content')
  .eq('page_slug', 'global').eq('section_key', '_nav_config').single();
const savedNav = navRow?.content?.meta?.nav_items
  ? JSON.parse(navRow.content.meta.nav_items) : DEFAULT_NAV;
const { data: navCustomPages } = await supabase.from('custom_pages')
  .select('id, slug, title_th, title_en, nav_label_th, nav_label_en, nav_parent, show_in_nav, visible')
  .eq('show_in_nav', true).eq('visible', true);

// === CUSTOM PAGES ===
const { data: customPages } = await supabase.from('custom_pages').select('*').order('sort_order', { ascending: true });

// === CMS CONTENT meta ===
const { data: contentMeta } = await supabase.from('site_content')
  .select('page_slug, updated_at').order('updated_at', { ascending: false });
const lastModified: Record<string, string> = {};
const sectionCount: Record<string, number> = {};
for (const row of contentMeta ?? []) {
  if (!lastModified[row.page_slug]) lastModified[row.page_slug] = row.updated_at;
  sectionCount[row.page_slug] = (sectionCount[row.page_slug] ?? 0) + 1;
}

const statusLabel: Record<string, string> = { pending: 'รอยืนยัน', confirmed: 'ยืนยัน', cancelled: 'ยกเลิก', completed: 'เสร็จ' };

// Serialized for inline JS
const navCmsMapJson = JSON.stringify(NAV_CMS_MAP);
const cmsPageDefsJson = JSON.stringify(
  Object.fromEntries(CMS_PAGES_ALL.map(p => [p.slug, p.sections]))
);
const cmsDefaultThJson = JSON.stringify(DEFAULT_TH);
const cmsDefaultEnJson = JSON.stringify(DEFAULT_EN);

const COMP_TYPES = [
  { type: 'specialty_card', label: 'ศูนย์เฉพาะทาง', section: 'specialties', icon: '🏥', fields: [
    { key: 'icon', label: 'Icon/Emoji', mono: true },
    { key: 'name', label: 'ชื่อศูนย์', bilingual: true },
    { key: 'desc', label: 'คำอธิบาย', bilingual: true },
    { key: 'href', label: 'ลิงก์ (path)', mono: true },
  ]},
  { type: 'quick_card', label: 'Quick Card (Hero)', section: 'hero', icon: '⚡', fields: [
    { key: 'icon', label: 'Icon/Emoji', mono: true },
    { key: 'color', label: 'สี (teal/amber/green/purple)', mono: true },
    { key: 'title', label: 'หัวข้อ', bilingual: true },
    { key: 'desc', label: 'คำอธิบาย', bilingual: true },
    { key: 'href', label: 'ลิงก์ (path)', mono: true },
  ]},
  { type: 'trust_point', label: 'จุดแข็ง (Why MediThai)', section: 'trust', icon: '🏆', fields: [
    { key: 'icon', label: 'Icon/Emoji', mono: true },
    { key: 'title', label: 'หัวข้อ', bilingual: true },
    { key: 'desc', label: 'รายละเอียด', bilingual: true },
  ]},
  { type: 'testimonial', label: 'รีวิวผู้ป่วย', section: 'testimonials', icon: '💬', fields: [
    { key: 'author', label: 'ชื่อผู้รีวิว', mono: true },
    { key: 'detail', label: 'รายละเอียด (อายุ/แผนก)', bilingual: true },
    { key: 'text', label: 'รีวิว', bilingual: true },
    { key: 'rating', label: 'คะแนน (1-5)', mono: true },
    { key: 'avatar', label: 'ตัวอักษร Avatar', mono: true },
  ]},
  { type: 'stat_counter', label: 'สถิติตัวเลข', section: 'stats', icon: '📊', fields: [
    { key: 'number', label: 'ตัวเลข', mono: true },
    { key: 'suffix', label: 'หน่วย (+, K, %, ฯ)', mono: true },
    { key: 'label', label: 'ป้ายกำกับ', bilingual: true },
    { key: 'icon', label: 'Icon/Emoji', mono: true },
  ]},
];
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Portal | MediThai</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    .admin-panel { display: none; }
    .admin-panel.active { display: block; }

    /* ── Overview ── */
    .admin-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    @media (max-width: 900px) { .admin-stats { grid-template-columns: repeat(2, 1fr); } }
    .admin-stat-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:20px 22px; }
    .stat-number { font-size:2.4rem; font-weight:800; color:#1e293b; line-height:1; }
    .stat-label { font-size:.8rem; color:#64748b; margin-top:4px; }
    .admin-stat-card.stat-warning .stat-number { color:#f59e0b; }
    .admin-stat-card.stat-success .stat-number { color:#22c55e; }
    .admin-stat-card.stat-info .stat-number { color:#3b82f6; }

    /* ── Appointments tab filter ── */
    .appt-filter { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }
    .appt-chip { padding:6px 14px; border-radius:20px; border:1.5px solid #e2e8f0;
      cursor:pointer; background:#fff; font-size:.84rem; transition:all .15s; }
    .appt-chip.active { background:var(--primary); color:#fff; border-color:var(--primary); }

    /* ── Analytics ── */
    .analytics-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:28px; }
    @media (max-width:768px) { .analytics-grid { grid-template-columns:1fr 1fr; } }
    .stat-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:20px 22px; }
    .stat-card-label { font-size:.78rem; color:#64748b; font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
    .stat-card-value { font-size:2.2rem; font-weight:800; color:#1e293b; line-height:1; }
    .stat-card-sub { font-size:.8rem; color:#94a3b8; margin-top:6px; }
    .stat-card.highlight { background:linear-gradient(135deg,#1a56db 0%,#1e40af 100%); border-color:transparent; }
    .stat-card.highlight .stat-card-label,.stat-card.highlight .stat-card-value,.stat-card.highlight .stat-card-sub { color:#fff; }
    .analytics-panels { display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-bottom:28px; }
    @media (max-width:900px) { .analytics-panels { grid-template-columns:1fr; } }
    .panel { background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:20px 22px; }
    .panel-title { font-weight:700; font-size:.95rem; margin-bottom:16px; color:#1e293b; }
    .chart-wrap { position:relative; height:220px; }
    .top-pages-list { display:flex; flex-direction:column; gap:10px; }
    .top-page-row { display:flex; align-items:center; gap:10px; }
    .top-page-path { flex:1; font-size:.85rem; color:#374151; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .top-page-bar-wrap { width:80px; height:8px; background:#f1f5f9; border-radius:4px; overflow:hidden; }
    .top-page-bar { height:100%; background:#3b82f6; border-radius:4px; }
    .top-page-count { font-size:.8rem; color:#64748b; width:40px; text-align:right; }
    .breakdown-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .donut-wrap { position:relative; height:160px; display:flex; align-items:center; justify-content:center; }
    .legend { display:flex; flex-direction:column; gap:6px; margin-top:12px; }
    .legend-item { display:flex; align-items:center; gap:8px; font-size:.82rem; color:#374151; }
    .legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

    /* ── Layout ── */
    .layout-list { display:flex; flex-direction:column; gap:8px; max-width:600px; }
    .layout-item { display:flex; align-items:center; gap:12px; background:#fff; border:1px solid #e2e8f0;
      border-radius:10px; padding:12px 16px; cursor:grab; user-select:none; transition:box-shadow .15s,opacity .15s; }
    .layout-item.dragging { opacity:.4; }
    .layout-item.drag-over { border-color:#3b82f6; box-shadow:0 0 0 2px #bfdbfe; }
    .layout-item.hidden-section { opacity:.5; background:#f8fafc; }
    .drag-handle { color:#94a3b8; font-size:18px; cursor:grab; }
    .layout-item-label { flex:1; font-weight:600; font-size:.9rem; color:#1e293b; }
    .layout-item-key { font-size:.72rem; color:#94a3b8; }
    .toggle-btn { background:none; border:none; cursor:pointer; font-size:18px; padding:4px; color:#64748b; transition:color .15s; }
    .toggle-btn.active { color:#22c55e; }
    .toggle-btn.inactive { color:#cbd5e1; }
    .hero-locked { font-size:.75rem; color:#94a3b8; margin-left:4px; }
    .layout-actions { display:flex; gap:12px; margin-top:24px; }

    /* ── Components ── */
    .comp-type-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px; }
    .comp-tab { padding:8px 16px; border-radius:20px; border:1.5px solid #e2e8f0;
      cursor:pointer; background:#fff; font-size:.85rem; transition:all .15s; }
    .comp-tab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
    .comp-list-inner { display:flex; flex-direction:column; gap:12px; }
    .comp-item { background:#fff; border:1px solid #e2e8f0; border-radius:12px; overflow:hidden; }
    .comp-item-header { display:flex; align-items:center; gap:12px; padding:14px 16px; cursor:pointer; background:#f8fafc; }
    .comp-item-header:hover { background:#f1f5f9; }
    .comp-item-num { font-weight:700; color:#64748b; min-width:24px; }
    .comp-item-title { flex:1; font-weight:600; }
    .comp-item-actions { display:flex; gap:8px; }
    .comp-item-body { padding:16px; border-top:1px solid #e2e8f0; display:none; }
    .comp-item.open .comp-item-body { display:block; }
    .comp-fields { display:grid; gap:12px; }
    .comp-field label { display:block; font-size:.8rem; font-weight:600; color:#64748b; margin-bottom:4px; }
    .comp-field input,.comp-field textarea { width:100%; border:1px solid #e2e8f0; border-radius:8px;
      padding:8px 12px; font-size:.9rem; outline:none; transition:border-color .15s; box-sizing:border-box; }
    .comp-field input:focus,.comp-field textarea:focus { border-color:var(--primary); }
    .comp-bilingual { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .lang-tag { font-size:.7rem; padding:2px 6px; border-radius:4px; font-weight:700; display:inline-block; margin-bottom:4px; }
    .lang-th { background:#fef3c7; color:#92400e; }
    .lang-en { background:#dbeafe; color:#1e40af; }
    .visibility-dot { width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:6px; }
    .vis-on { background:#22c55e; }
    .vis-off { background:#e2e8f0; }
    .add-comp-panel { background:#f8fafc; border:2px dashed #e2e8f0; border-radius:12px;
      padding:24px; text-align:center; margin-top:16px; }
    .add-comp-panel select { padding:8px 12px; border-radius:8px; border:1px solid #e2e8f0;
      font-size:.9rem; margin-right:8px; }

    /* ── Page-tree sidebar ── */
    .cms-nav-page-group { display:flex; flex-direction:column; }
    .cms-page-no-cms { opacity:.6; }
    .cms-page-no-cms:hover { opacity:1; }
    .cms-nav-subtree { padding-left:14px; margin-left:18px; border-left:2px solid #e2e8f0;
      display:flex; flex-direction:column; gap:1px; margin-bottom:2px; }
    .cms-nav-subitem { display:flex; align-items:center; gap:6px; padding:2px 6px;
      font-size:.76rem; color:#94a3b8; }
    .cms-nav-subitem-label { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .cms-nav-subitem-no-cms { opacity:.55; font-style:italic; }
    .cms-nav-subitem-btn { background:none; border:none; cursor:pointer; padding:3px 7px;
      font-size:.76rem; color:#334155; border-radius:5px; text-align:left; white-space:nowrap;
      overflow:hidden; text-overflow:ellipsis; transition:background .12s,color .12s; }
    .cms-nav-subitem-btn:hover { background:#e0f2fe; color:#0891b2; }
    .cms-nav-subitem-btn.active { background:#0891b2; color:#fff; font-weight:600; }

    /* ── Inline page CMS editor ── */
    .cms-no-cms-placeholder { text-align:center; padding:80px 24px; color:#94a3b8; }
    .cms-no-cms-placeholder-icon { font-size:48px; margin-bottom:16px; }

    /* ── Pages (custom) ── */
    .pages-list-inner { display:flex; flex-direction:column; gap:10px; max-width:800px; }
    .page-row { background:#fff; border:1px solid #e2e8f0; border-radius:12px;
      padding:14px 18px; display:flex; align-items:center; gap:14px; }
    .page-row-icon { font-size:20px; }
    .page-row-body { flex:1; }
    .page-row-title { font-weight:700; font-size:.92rem; color:#1e293b; }
    .page-row-meta { font-size:.75rem; color:#94a3b8; margin-top:2px; }
    .nav-badge { font-size:.7rem; background:#dcfce7; color:#15803d; padding:2px 7px; border-radius:4px; }
    .hidden-badge { font-size:.7rem; background:#fee2e2; color:#991b1b; padding:2px 7px; border-radius:4px; }
    .page-row-actions { display:flex; gap:8px; }
    .btn-sm { font-size:.78rem; padding:5px 12px; border-radius:7px; border:1px solid #e2e8f0;
      background:#f8fafc; cursor:pointer; transition:background .15s; }
    .btn-sm:hover { background:#f1f5f9; }
    .btn-sm.danger { color:#ef4444; border-color:#fecaca; }
    .btn-sm.danger:hover { background:#fef2f2; }
    .empty-state { text-align:center; padding:40px 20px; color:#94a3b8; }
    .empty-state-icon { font-size:40px; margin-bottom:12px; }
    /* Page modal */
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000;
      display:none; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff; border-radius:16px; width:760px; max-width:95vw;
      max-height:90vh; overflow-y:auto; display:flex; flex-direction:column; }
    .modal-header { display:flex; align-items:center; justify-content:space-between;
      padding:18px 24px; border-bottom:1px solid #f1f5f9; }
    .modal-title { font-size:1.1rem; font-weight:700; }
    .modal-close { font-size:20px; background:none; border:none; cursor:pointer; color:#94a3b8; }
    .modal-body { padding:20px 24px; display:flex; flex-direction:column; gap:16px; }
    .modal-footer { padding:16px 24px; border-top:1px solid #f1f5f9; display:flex; gap:10px; justify-content:flex-end; }
    .field-group { display:flex; flex-direction:column; gap:6px; }
    .field-label { font-size:.83rem; font-weight:600; color:#374151; }
    .field-input { border:1px solid #e2e8f0; border-radius:8px; padding:9px 12px; font-size:.9rem; width:100%; box-sizing:border-box; }
    .field-input:focus { outline:none; border-color:#3b82f6; }
    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .editor-wrap { border:1px solid #e2e8f0; border-radius:8px; overflow:hidden; }
    .quill-editor { min-height:180px; }
    .toggle-row { display:flex; align-items:center; gap:10px; }
    .toggle-label { font-size:.88rem; color:#374151; }
    .nav-parent-select { border:1px solid #e2e8f0; border-radius:8px; padding:9px 12px;
      font-size:.9rem; width:100%; box-sizing:border-box; }

    /* ── CMS content cards ── */
    .cms-cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; }
    .cms-page-card { display:flex; align-items:center; gap:14px; background:#fff;
      border:1px solid #e2e8f0; border-radius:14px; padding:18px; text-decoration:none;
      transition:all .15s; cursor:pointer; }
    .cms-page-card:hover { border-color:#3b82f6; box-shadow:0 4px 12px rgba(59,130,246,.12); transform:translateY(-1px); }
    .cms-page-card-icon { font-size:28px; }
    .cms-page-card-body { flex:1; }
    .cms-page-card-title { font-weight:700; font-size:.95rem; color:#1e293b; }
    .cms-page-card-desc { font-size:.8rem; color:#64748b; margin-top:2px; }
    .cms-page-card-meta { display:flex; align-items:center; gap:8px; margin-top:6px; }
    .cms-status-badge { font-size:.72rem; padding:2px 8px; border-radius:4px; font-weight:600; }
    .cms-status-badge.has-overrides { background:#dcfce7; color:#15803d; }
    .cms-status-badge.default { background:#f1f5f9; color:#64748b; }
    .cms-page-card-date { font-size:.72rem; color:#94a3b8; }
    .cms-page-card-arrow { color:#94a3b8; font-size:18px; }

    /* ── Shared table ── */
    .no-data { text-align:center; padding:40px; color:#94a3b8; font-size:.9rem; }
  </style>
</head>
<body>
<div class="cms-shell">

  <!-- ─── Sidebar ──────────────────────────────────────────── -->
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div><div class="cms-logo-name">MediThai</div><div class="cms-logo-sub">Admin Portal</div></div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">จัดการ</div>
      <button class="cms-nav-item" data-tab="overview" onclick="switchTab('overview')"><span class="cms-nav-icon">📊</span> ภาพรวม</button>
      <button class="cms-nav-item" data-tab="appointments" onclick="switchTab('appointments')"><span class="cms-nav-icon">📅</span> นัดหมาย</button>
      <button class="cms-nav-item" data-tab="analytics" onclick="switchTab('analytics')"><span class="cms-nav-icon">📈</span> Analytics</button>
      <div class="cms-nav-group-label">PAGES</div>

      <!-- Global — always first -->
      <button class="cms-nav-item cms-page-item" data-page="__global" onclick="switchToPage('__global')">
        <span class="cms-nav-icon">🌐</span> Global (Nav &amp; Footer)
      </button>

      <!-- Website nav tree from savedNav -->
      {savedNav.map(tab => (
        <div class="cms-nav-page-group">
          <button
            class={`cms-nav-item cms-page-item${!NAV_CMS_MAP[tab.id] ? ' cms-page-no-cms' : ''}`}
            data-page={tab.id}
            onclick={`switchToPage('${tab.id}')`}>
            <span class="cms-nav-icon">{tab.children?.length ? '📂' : '📄'}</span>
            {tab.label_th}
          </button>
          {tab.children && tab.children.length > 0 && (
            <div class="cms-nav-subtree">
              {tab.children.map((child: any) => (
                <div class="cms-nav-subitem">
                  <span class="cms-nav-subitem-line"></span>
                  <span class="cms-nav-subitem-dot"></span>
                  {NAV_CMS_MAP[child.id] ? (
                    <button
                      class="cms-nav-subitem-btn cms-page-item"
                      data-page={child.id}
                      onclick={`switchToPage('${child.id}')`}>
                      {child.label_th}
                    </button>
                  ) : (
                    <span class="cms-nav-subitem-label cms-nav-subitem-no-cms">{child.label_th}</span>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      ))}

      <div class="cms-nav-group-label" style="margin-top:8px">ตั้งค่า</div>
      <button class="cms-nav-item" data-tab="layout" onclick="switchTab('layout')"><span class="cms-nav-icon">📐</span> Layout & Sections</button>
      <button class="cms-nav-item" data-tab="components" onclick="switchTab('components')"><span class="cms-nav-icon">🧩</span> Components</button>
      <button class="cms-nav-item" data-tab="nav" onclick="switchTab('nav')"><span class="cms-nav-icon">🔗</span> Nav Labels</button>
      <button class="cms-nav-item" data-tab="pages" onclick="switchTab('pages')"><span class="cms-nav-icon">📝</span> Custom Pages</button>
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item"><span class="cms-nav-icon">🌐</span> ดูเว็บไซต์</a>
      <form method="POST" action="/logout">
        <button type="submit" class="cms-nav-item cms-nav-logout"><span class="cms-nav-icon">🚪</span> ออกจากระบบ</button>
      </form>
    </nav>
  </aside>

  <!-- ─── Main ─────────────────────────────────────────────── -->
  <main class="cms-main">

    <!-- Shared save bar -->
    <div id="admin-save-bar" class="cms-save-bar" style="display:none">
      <span id="admin-save-msg"></span>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: ภาพรวม                                          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-overview" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">📊 ภาพรวม</h1>
          <p class="cms-page-sub">สรุประบบนัดหมายวันนี้</p>
        </div>
        <button class="cms-btn cms-btn-ghost" onclick="location.reload()">↺ รีเฟรช</button>
      </div>

      <div class="admin-stats">
        <div class="admin-stat-card">
          <div class="stat-number">{total ?? 0}</div>
          <div class="stat-label">นัดหมายทั้งหมด</div>
        </div>
        <div class="admin-stat-card stat-warning">
          <div class="stat-number">{pending ?? 0}</div>
          <div class="stat-label">รอยืนยัน</div>
        </div>
        <div class="admin-stat-card stat-success">
          <div class="stat-number">{confirmed ?? 0}</div>
          <div class="stat-label">ยืนยันแล้ว</div>
        </div>
        <div class="admin-stat-card stat-info">
          <div class="stat-number">{today ?? 0}</div>
          <div class="stat-label">นัดหมายวันนี้</div>
        </div>
      </div>

      <h2 class="cms-section-group-title" style="margin-top:0">นัดหมายล่าสุด</h2>
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ชื่อผู้ป่วย</th><th>โรงพยาบาล</th><th>แผนก</th>
              <th>วันที่นัด</th><th>เวลา</th><th>สถานะ</th><th>จัดการ</th>
            </tr>
          </thead>
          <tbody>
            {recentAppts?.map(appt => (
              <tr>
                <td>
                  <div>{appt.patient_name}</div>
                  <div style="font-size:.8rem;color:var(--gray-500)">{appt.patient_phone}</div>
                </td>
                <td>{appt.hospital}</td>
                <td>{appt.specialty}</td>
                <td>{new Date(appt.appointment_date).toLocaleDateString('th-TH')}</td>
                <td>{appt.appointment_time}</td>
                <td><span class={`appt-badge appt-badge--${appt.status}`}>{statusLabel[appt.status]}</span></td>
                <td><a href={`/admin/appointments/${appt.id}`} class="btn btn-sm btn-secondary">ดู</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: นัดหมาย                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-appointments" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">📅 นัดหมายทั้งหมด</h1>
          <p class="cms-page-sub">{allAppts?.length ?? 0} รายการ</p>
        </div>
      </div>

      <div class="appt-filter">
        {['', 'pending', 'confirmed', 'cancelled', 'completed'].map(s => (
          <button class={`appt-chip ${s === '' ? 'active' : ''}`}
                  onclick={`filterAppts('${s}', this)`}>
            {s === '' ? 'ทั้งหมด' : statusLabel[s]}
          </button>
        ))}
      </div>

      <div class="admin-table-wrapper">
        <table class="admin-table" id="appts-table">
          <thead>
            <tr>
              <th>ผู้ป่วย</th><th>โรงพยาบาล</th><th>แผนก</th>
              <th>วันที่</th><th>เวลา</th><th>สถานะ</th><th>จัดการ</th>
            </tr>
          </thead>
          <tbody id="appts-tbody">
            {allAppts?.map(appt => (
              <tr data-status={appt.status}>
                <td>
                  <div style="font-weight:500">{appt.patient_name}</div>
                  <div style="font-size:.8rem;color:var(--gray-500)">{appt.patient_phone}</div>
                </td>
                <td>{appt.hospital}</td>
                <td>{appt.specialty}</td>
                <td style="white-space:nowrap">{new Date(appt.appointment_date).toLocaleDateString('th-TH')}</td>
                <td>{appt.appointment_time}</td>
                <td><span class={`appt-badge appt-badge--${appt.status}`}>{statusLabel[appt.status]}</span></td>
                <td><a href={`/admin/appointments/${appt.id}`} class="btn btn-sm btn-secondary">จัดการ</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: Analytics                                       -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-analytics" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">📈 Analytics</h1>
          <p class="cms-page-sub">สถิติการเข้าชมเว็บไซต์</p>
        </div>
        <button class="cms-btn cms-btn-ghost" onclick="location.reload()">↺ รีเฟรช</button>
      </div>

      {!analytics ? (
        <div class="no-data">ไม่สามารถโหลดข้อมูล Analytics ได้</div>
      ) : (
        <>
          <div class="analytics-grid">
            <div class="stat-card highlight">
              <div class="stat-card-label">วันนี้</div>
              <div class="stat-card-value">{(analytics.summary?.viewsToday ?? 0).toLocaleString()}</div>
              <div class="stat-card-sub">Page views</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">7 วันที่ผ่านมา</div>
              <div class="stat-card-value">{(analytics.summary?.views7 ?? 0).toLocaleString()}</div>
              <div class="stat-card-sub">Page views</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">30 วันที่ผ่านมา</div>
              <div class="stat-card-value">{(analytics.summary?.views30 ?? 0).toLocaleString()}</div>
              <div class="stat-card-sub">Page views</div>
            </div>
          </div>

          <div class="analytics-panels">
            <div class="panel">
              <div class="panel-title">📅 Page Views 14 วันย้อนหลัง</div>
              <div class="chart-wrap"><canvas id="chart-daily"></canvas></div>
            </div>
            <div class="panel">
              <div class="panel-title">🏆 หน้าที่เข้าชมมากสุด</div>
              <div class="top-pages-list" id="top-pages"></div>
            </div>
          </div>

          <div class="breakdown-grid">
            <div class="panel">
              <div class="panel-title">📱 อุปกรณ์</div>
              <div class="donut-wrap"><canvas id="chart-device"></canvas></div>
              <div class="legend" id="device-legend"></div>
            </div>
            <div class="panel">
              <div class="panel-title">🌐 ภาษา</div>
              <div class="donut-wrap"><canvas id="chart-lang"></canvas></div>
              <div class="legend" id="lang-legend"></div>
            </div>
          </div>
        </>
      )}
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: Page CMS (inline editor — driven by JS)         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-pagecms" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title" id="pagecms-title">เลือกหน้าจากแถบซ้าย</h1>
          <p class="cms-page-sub" id="pagecms-sub">คลิกชื่อหน้าใน PAGES เพื่อแก้ไขเนื้อหา</p>
        </div>
        <a href="/" target="_blank" class="cms-btn cms-btn-outline">Preview ↗</a>
      </div>
      <div id="pagecms-sections" class="cms-sections"></div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: จัดเรียง Sections                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-layout" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">📐 จัดเรียง Sections</h1>
          <p class="cms-page-sub">ลากเพื่อเรียงลำดับ หรือกดปุ่มซ่อน/แสดง section</p>
        </div>
      </div>

      <div id="layout-list" class="layout-list">
        {orderedKeys.map((key) => {
          const sec = sectionMap[key];
          if (!sec) return null;
          const isHidden = hiddenSections.includes(key);
          const isHero = key === 'hero';
          return (
            <div class={`layout-item ${isHidden ? 'hidden-section' : ''}`}
                 data-key={key} draggable={isHero ? 'false' : 'true'}>
              <span class="drag-handle">{isHero ? '🔒' : '⣿'}</span>
              <span style="font-size:20px;width:28px;text-align:center">{sec.icon}</span>
              <div style="flex:1">
                <div class="layout-item-label">{sec.label} {isHero && <span class="hero-locked">(ล็อก)</span>}</div>
                <div class="layout-item-key">{key}</div>
              </div>
              {!isHero && (
                <button class={`toggle-btn ${isHidden ? 'inactive' : 'active'}`}
                        onclick={`toggleSection('${key}', this)`}
                        title={isHidden ? 'แสดง section' : 'ซ่อน section'}>
                  {isHidden ? '👁️‍🗨️' : '👁️'}
                </button>
              )}
            </div>
          );
        })}
      </div>

      <div class="layout-actions">
        <button class="cms-btn cms-btn-primary" onclick="saveLayout()">💾 บันทึกการจัดเรียง</button>
        <button class="cms-btn cms-btn-ghost" onclick="resetLayout()">↺ รีเซ็ต</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: Components                                      -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-components" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">🧩 Components</h1>
          <p class="cms-page-sub">เพิ่ม/แก้ไข/ลบ cards ที่แสดงในแต่ละ section</p>
        </div>
      </div>

      <div class="comp-type-tabs" id="comp-type-tabs">
        <button class="comp-tab active" onclick="filterCompType('all', this)">ทั้งหมด ({(components ?? []).length})</button>
        {COMP_TYPES.map(ct => (
          <button class="comp-tab" onclick={`filterCompType('${ct.type}', this)`}>
            {ct.icon} {ct.label}
          </button>
        ))}
      </div>

      <div id="comp-list" class="comp-list-inner"
           data-comps={JSON.stringify(components ?? [])}
           data-types={JSON.stringify(COMP_TYPES)}>
      </div>

      <div class="add-comp-panel">
        <p style="color:#64748b;margin-bottom:12px">เพิ่ม component ใหม่</p>
        <select id="new-comp-type">
          {COMP_TYPES.map(ct => <option value={ct.type}>{ct.icon} {ct.label}</option>)}
        </select>
        <button class="cms-btn cms-btn-primary" onclick="addComponent()">+ เพิ่ม</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: Navigation                                      -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-nav" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">🔗 Navigation</h1>
          <p class="cms-page-sub">ซ่อน/แสดง tab และ dropdown items แก้ชื่อ nav</p>
        </div>
      </div>

      <div class="nav-tree-inner" id="nav-tree"
           data-nav={JSON.stringify(savedNav)}
           data-custom={JSON.stringify(navCustomPages ?? [])}>
      </div>

      <div class="save-nav-bar">
        <button class="cms-btn cms-btn-primary" onclick="saveNav()">💾 บันทึก Navigation</button>
        <button class="cms-btn cms-btn-ghost" onclick="resetNav()">↺ รีเซ็ต</button>
      </div>

      <div class="cms-info-box" style="margin-top:24px">
        💡 Custom pages ที่เปิด "แสดงใน Nav" จะปรากฏใน dropdown ที่เลือกไว้ — จัดการได้ที่แท็บ <strong>หน้าเว็บ</strong>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- PANEL: หน้าเว็บ (custom pages)                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="panel-pages" class="admin-panel">
      <div class="cms-topbar">
        <div>
          <h1 class="cms-page-title">📄 หน้าเว็บ</h1>
          <p class="cms-page-sub">สร้าง แก้ไข และลบ custom pages — เพิ่มใน nav ได้</p>
        </div>
        <button class="cms-btn cms-btn-primary" onclick="openCreatePage()">+ สร้างหน้าใหม่</button>
      </div>

      <div class="pages-list-inner" id="pages-list"
           data-pages={JSON.stringify(customPages ?? [])}>
      </div>
    </div>

  </main>
</div>

<!-- ══ Custom page Create/Edit Modal ══════════════════════════ -->
<div class="modal-overlay" id="page-modal">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">สร้างหน้าใหม่</div>
      <button class="modal-close" onclick="closePageModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id" value="" />
      <div class="field-row">
        <div class="field-group">
          <label class="field-label">ชื่อหน้า (ไทย) *</label>
          <input class="field-input" id="f-title-th" placeholder="เช่น โปรโมชัน" />
        </div>
        <div class="field-group">
          <label class="field-label">Page title (English) *</label>
          <input class="field-input" id="f-title-en" placeholder="e.g. Promotions" />
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">URL Slug * <span style="color:#94a3b8;font-weight:400">(a-z, 0-9, - เท่านั้น)</span></label>
        <input class="field-input" id="f-slug" placeholder="promotions" />
      </div>
      <div class="field-group">
        <label class="field-label">เนื้อหา (ภาษาไทย)</label>
        <div class="editor-wrap"><div class="quill-editor" id="editor-th"></div></div>
      </div>
      <div class="field-group">
        <label class="field-label">Content (English)</label>
        <div class="editor-wrap"><div class="quill-editor" id="editor-en"></div></div>
      </div>
      <div style="border-top:1px solid #f1f5f9;padding-top:16px">
        <div class="field-label" style="margin-bottom:12px">⚙️ ตั้งค่า</div>
        <div class="toggle-row" style="margin-bottom:10px">
          <label class="vis-switch">
            <input type="checkbox" id="f-visible" checked />
            <span class="vis-slider"></span>
          </label>
