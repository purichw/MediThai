<script is:inline>
// ── Tab switching ─────────────────────────────────────────────
const TABS = ['overview','appointments','analytics','layout','components','nav','pages'];

function switchTab(tabId) {
  if (!TABS.includes(tabId)) tabId = 'overview';
  // Deactivate all page-tree items and hide pagecms panel
  document.querySelectorAll('.cms-page-item').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-pagecms')?.classList.remove('active');
  TABS.forEach(t => {
    const panel = document.getElementById('panel-' + t);
    const btn = document.querySelector(`[data-tab="${t}"]`);
    if (panel) panel.classList.toggle('active', t === tabId);
    if (btn) btn.classList.toggle('active', t === tabId);
  });
  history.replaceState(null, '', '#' + tabId);
  if (tabId === 'analytics' && !window._chartsInited) {
    window._chartsInited = true;
    initAnalyticsCharts();
  }
  if (tabId === 'components' && !window._compsRendered) {
    window._compsRendered = true;
    renderCompList();
  }
  if (tabId === 'nav' && !window._navRendered) {
    window._navRendered = true;
    renderNav();
  }
  if (tabId === 'pages' && !window._pagesRendered) {
    window._pagesRendered = true;
    renderPagesList();
  }
}

// Restore tab/page from hash on load
document.addEventListener('DOMContentLoaded', () => {
  const hash = location.hash.slice(1);
  if (hash.startsWith('page-')) {
    switchToPage(hash.replace('page-', ''));
  } else {
    switchTab(TABS.includes(hash) ? hash : 'overview');
  }
  initQuill();
});

// ── Shared save bar ───────────────────────────────────────────
let _saveBarTimer;
function showSaveBar(msg, type) {
  const bar = document.getElementById('admin-save-bar');
  const m = document.getElementById('admin-save-msg');
  if (!bar || !m) return;
  m.textContent = msg;
  bar.style.display = 'flex';
  bar.className = `cms-save-bar cms-save-bar--${type}`;
  clearTimeout(_saveBarTimer);
  if (type !== 'saving') _saveBarTimer = setTimeout(() => { bar.style.display = 'none'; }, 3500);
}

// ── Appointments filter ───────────────────────────────────────
function filterAppts(status, btn) {
  document.querySelectorAll('.appt-chip').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#appts-tbody tr').forEach(row => {
    row.style.display = (!status || row.dataset.status === status) ? '' : 'none';
  });
}

// ── Analytics charts ──────────────────────────────────────────
</script>

{analytics && (
  <script is:inline define:vars={{ analytics }}>
  function initAnalyticsCharts() {
    const daily = analytics.daily || [];
    new Chart(document.getElementById('chart-daily'), {
      type: 'line',
      data: {
        labels: daily.map(d => {
          const dt = new Date(d.date || d.day);
          return dt.toLocaleDateString('th-TH', { day:'numeric', month:'short' });
        }),
        datasets: [{
          label: 'Views', data: daily.map(d => d.count),
          borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,.12)',
          tension: .3, fill: true, pointRadius: 3,
        }]
      },
      options: { responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{display:false} },
        scales:{ y:{ beginAtZero:true, ticks:{ precision:0 } } } }
    });

    const topPages = analytics.topPages || [];
    const maxPV = topPages[0]?.count || 1;
    document.getElementById('top-pages').innerHTML = topPages.map(p => `
      <div class="top-page-row">
        <div class="top-page-path" title="${p.path||p.page_path}">${p.path||p.page_path}</div>
        <div class="top-page-bar-wrap"><div class="top-page-bar" style="width:${Math.round(p.count/maxPV*100)}%"></div></div>
        <div class="top-page-count">${p.count}</div>
      </div>
    `).join('') || '<div style="color:#94a3b8;font-size:.85rem">ยังไม่มีข้อมูล</div>';

    const devRaw = analytics.devices || {};
    const deviceData = Object.entries(devRaw).filter(([,v]) => v > 0).map(([k,v]) => ({ device_type:k, count:v }));
    const devColors = ['#3b82f6','#22c55e','#f59e0b','#ef4444'];
    if (deviceData.length) {
      new Chart(document.getElementById('chart-device'), {
        type:'doughnut',
        data:{ labels:deviceData.map(d=>d.device_type), datasets:[{ data:deviceData.map(d=>d.count), backgroundColor:devColors, borderWidth:2 }] },
        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false} } }
      });
    }
    document.getElementById('device-legend').innerHTML = deviceData.map((d,i) =>
      `<div class="legend-item"><div class="legend-dot" style="background:${devColors[i]}"></div>${d.device_type}: ${d.count}</div>`
    ).join('') || '<div style="color:#94a3b8;font-size:.82rem">ยังไม่มีข้อมูล</div>';

    const langRaw = analytics.langs || {};
    const langData = Object.entries(langRaw).filter(([,v]) => v > 0).map(([k,v]) => ({ lang:k, count:v }));
    const langColors = ['#8b5cf6','#f97316','#06b6d4','#84cc16'];
    if (langData.length) {
      new Chart(document.getElementById('chart-lang'), {
        type:'doughnut',
        data:{ labels:langData.map(d=>d.lang==='th'?'ภาษาไทย':'English'), datasets:[{ data:langData.map(d=>d.count), backgroundColor:langColors, borderWidth:2 }] },
        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false} } }
      });
    }
    document.getElementById('lang-legend').innerHTML = langData.map((d,i) =>
      `<div class="legend-item"><div class="legend-dot" style="background:${langColors[i]}"></div>${d.lang==='th'?'ภาษาไทย':'English'}: ${d.count}</div>`
    ).join('') || '<div style="color:#94a3b8;font-size:.82rem">ยังไม่มีข้อมูล</div>';
  }
  </script>
)}

{!analytics && (
  <script is:inline>function initAnalyticsCharts() {}</script>
)}

<script is:inline>
// ── Layout (section drag-and-drop) ────────────────────────────
const layoutListEl = document.getElementById('layout-list');
let layoutDragEl = null;

if (layoutListEl) {
  layoutListEl.addEventListener('dragstart', e => {
    layoutDragEl = e.target.closest('.layout-item');
    if (!layoutDragEl || layoutDragEl.dataset.key === 'hero') { e.preventDefault(); return; }
    layoutDragEl.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
  });
  layoutListEl.addEventListener('dragend', () => {
    if (layoutDragEl) layoutDragEl.classList.remove('dragging');
    layoutDragEl = null;
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
  });
  layoutListEl.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.layout-item');
    if (target && target !== layoutDragEl && target.dataset.key !== 'hero') {
      document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
      target.classList.add('drag-over');
    }
  });
  layoutListEl.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('.layout-item');
    if (!target || target === layoutDragEl || target.dataset.key === 'hero') return;
    target.classList.remove('drag-over');
    const rect = target.getBoundingClientRect();
    if (e.clientY > rect.top + rect.height / 2) target.after(layoutDragEl);
    else target.before(layoutDragEl);
  });
}

function toggleSection(key, btn) {
  const item = btn.closest('.layout-item');
  const isHidden = item.classList.toggle('hidden-section');
  btn.classList.toggle('active', !isHidden);
  btn.classList.toggle('inactive', isHidden);
  btn.textContent = isHidden ? '👁️‍🗨️' : '👁️';
  btn.title = isHidden ? 'แสดง section' : 'ซ่อน section';
}

async function saveLayout() {
  const items = [...document.querySelectorAll('.layout-item')];
  const order = items.map(el => el.dataset.key);
  const hidden = items.filter(el => el.classList.contains('hidden-section')).map(el => el.dataset.key);
  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/content', {
    method:'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({ page_slug:'home', section_key:'_layout',
      content:{ meta:{ section_order:JSON.stringify(order), hidden_sections:JSON.stringify(hidden) } } }),
  });
  const d = await res.json();
  showSaveBar(res.ok ? '✓ บันทึกสำเร็จ' : '❌ ' + d.error, res.ok ? 'success' : 'error');
}

async function resetLayout() {
  if (!confirm('รีเซ็ตการจัดเรียงทั้งหมดกลับเป็นค่าเริ่มต้น?')) return;
  const res = await fetch('/api/admin/content?page=home&section=_layout', { method:'DELETE', credentials:'include' });
  if (res.ok) { showSaveBar('✓ รีเซ็ตแล้ว', 'success'); setTimeout(() => location.reload(), 1200); }
}

// ── Components ────────────────────────────────────────────────
let localComps = [];
let compCurrentFilter = 'all';
let COMP_TYPES_JS = [];

function renderCompList() {
  const listEl = document.getElementById('comp-list');
  if (!listEl) return;
  localComps = JSON.parse(listEl.dataset.comps || '[]');
  COMP_TYPES_JS = JSON.parse(listEl.dataset.types || '[]');

  const filtered = compCurrentFilter === 'all' ? localComps
    : localComps.filter(c => c.comp_type === compCurrentFilter);

  if (filtered.length === 0) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8">ยังไม่มี components — กดเพิ่มด้านล่าง</div>';
    return;
  }

  const typeMap = Object.fromEntries(COMP_TYPES_JS.map(t => [t.type, t]));
  listEl.innerHTML = filtered.map((comp, idx) => {
    const typeDef = typeMap[comp.comp_type] || { label:comp.comp_type, icon:'🔲', fields:[] };
    const nameVal = comp.content?.name_th || comp.content?.title_th || comp.content?.author || comp.comp_type;
    return `
    <div class="comp-item" id="comp-${comp.id}" data-id="${comp.id}">
      <div class="comp-item-header" onclick="toggleCompItem('${comp.id}')">
        <span style="color:#cbd5e1;cursor:grab;font-size:16px">⣿</span>
        <span class="comp-item-num">${idx+1}</span>
        <span class="visibility-dot ${comp.visible ? 'vis-on' : 'vis-off'}"></span>
        <span style="font-size:18px">${typeDef.icon}</span>
        <div class="comp-item-title">
          <div>${nameVal || '(ไม่มีชื่อ)'}</div>
          <div style="font-size:.75rem;color:#94a3b8">${typeDef.label}</div>
        </div>
        <div class="comp-item-actions" onclick="event.stopPropagation()">
          <button class="cms-btn cms-btn-sm cms-btn-ghost" onclick="toggleCompVisible('${comp.id}',${comp.visible})">${comp.visible?'👁️':'👁️‍🗨️'}</button>
          <button class="cms-btn cms-btn-sm cms-btn-ghost" style="color:#ef4444" onclick="deleteComp('${comp.id}')">🗑️</button>
        </div>
      </div>
      <div class="comp-item-body">
        ${renderCompFields(comp, typeDef)}
        <div style="display:flex;gap:8px;margin-top:16px">
          <button class="cms-btn cms-btn-primary" onclick="saveComp('${comp.id}')">💾 บันทึก</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function renderCompFields(comp, typeDef) {
  return (typeDef.fields || []).map(f => {
    if (f.bilingual) {
      const thVal = comp.content[f.key+'_th'] || '';
      const enVal = comp.content[f.key+'_en'] || '';
      return `<div class="comp-field"><label>${f.label}</label>
        <div class="comp-bilingual">
          <div><span class="lang-tag lang-th">TH</span><input type="text" data-field="${f.key}_th" value="${escH(thVal)}" placeholder="ภาษาไทย" /></div>
          <div><span class="lang-tag lang-en">EN</span><input type="text" data-field="${f.key}_en" value="${escH(enVal)}" placeholder="English" /></div>
        </div></div>`;
    } else {
      const val = comp.content[f.key] || '';
      return `<div class="comp-field"><label>${f.label}</label><input type="text" data-field="${f.key}" value="${escH(val)}" /></div>`;
    }
  }).join('');
}

function toggleCompItem(id) {
  document.getElementById('comp-' + id)?.classList.toggle('open');
}

function filterCompType(type, btn) {
  compCurrentFilter = type;
  document.querySelectorAll('.comp-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderCompList();
}

async function saveComp(id) {
  const el = document.getElementById('comp-' + id);
  const content = {};
  el.querySelectorAll('[data-field]').forEach(inp => { content[inp.dataset.field] = inp.value; });
  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/components', {
    method:'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({ id, content }),
  });
  const d = await res.json();
  if (res.ok) {
    const i = localComps.findIndex(c => c.id === id);
    if (i >= 0) { localComps[i] = d; document.getElementById('comp-list').dataset.comps = JSON.stringify(localComps); }
    showSaveBar('✓ บันทึกสำเร็จ', 'success');
    renderCompList();
  } else showSaveBar('❌ ' + d.error, 'error');
}

async function toggleCompVisible(id, current) {
  const res = await fetch('/api/admin/components', {
    method:'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({ id, visible: !current }),
  });
  const d = await res.json();
  if (res.ok) {
    const i = localComps.findIndex(c => c.id === id);
    if (i >= 0) { localComps[i] = d; document.getElementById('comp-list').dataset.comps = JSON.stringify(localComps); }
    renderCompList();
  }
}

async function deleteComp(id) {
  if (!confirm('ลบ component นี้?')) return;
  const res = await fetch(`/api/admin/components?id=${id}`, { method:'DELETE', credentials:'include' });
  if (res.ok) {
    localComps = localComps.filter(c => c.id !== id);
    document.getElementById('comp-list').dataset.comps = JSON.stringify(localComps);
    showSaveBar('✓ ลบแล้ว', 'success');
    renderCompList();
  }
}

async function addComponent() {
  const compType = document.getElementById('new-comp-type').value;
  const typeDef = COMP_TYPES_JS.find(t => t.type === compType);
  showSaveBar('กำลังสร้าง...', 'saving');
  const res = await fetch('/api/admin/components', {
    method:'POST', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({
      page_slug:'home', section_key: typeDef?.section || compType,
      comp_type: compType,
      sort_order: localComps.filter(c => c.comp_type === compType).length,
    }),
  });
  const d = await res.json();
  if (res.ok) {
    localComps.push(d);
    document.getElementById('comp-list').dataset.comps = JSON.stringify(localComps);
    showSaveBar('✓ สร้างแล้ว — กรอกข้อมูลแล้วกดบันทึก', 'success');
    renderCompList();
    setTimeout(() => document.getElementById('comp-' + d.id)?.classList.add('open'), 100);
  } else showSaveBar('❌ ' + d.error, 'error');
}

// ── Navigation editor ─────────────────────────────────────────
let navData = [];

function renderNav() {
  const treeEl = document.getElementById('nav-tree');
  if (!treeEl) return;
  navData = JSON.parse(treeEl.dataset.nav || '[]');
  const customPages = JSON.parse(treeEl.dataset.custom || '[]');

  treeEl.innerHTML = navData.map((tab, ti) => {
    const children  = tab.children || [];
    const customs   = customPages.filter(p => p.nav_parent === tab.id);
    const hasKids   = children.length > 0 || customs.length > 0;
    const allKids   = [...children, ...customs];

    const childrenHtml = hasKids ? `
      <div class="nav-node-children" style="display:none">
        ${children.map((child, ci) => `
        <div class="nav-child-row ${child.visible ? '' : 'nav-child-dimmed'}">
          <div class="nav-child-vline"></div>
          <div class="nav-child-hline"></div>
          <div class="nav-child-inputs">
            <div class="nav-child-labels">
              <span class="nav-child-lang">TH</span>
              <input class="nav-label-edit" data-path="${ti}.children.${ci}.label_th"
                value="${escH(child.label_th)}" placeholder="ชื่อไทย" />
            </div>
            <div class="nav-child-labels">
              <span class="nav-child-lang nav-child-lang-en">EN</span>
              <input class="nav-label-edit" data-path="${ti}.children.${ci}.label_en"
                value="${escH(child.label_en)}" placeholder="English" />
            </div>
          </div>
          <code class="nav-node-href">${child.href || ''}</code>
          <label class="vis-switch">
            <input type="checkbox" ${child.visible?'checked':''} onchange="setNavPath('${ti}.children.${ci}.visible',this.checked)" />
            <span class="vis-slider"></span>
          </label>
        </div>`).join('')}
        ${customs.map(p => `
        <div class="nav-child-row is-custom">
          <div class="nav-child-vline"></div>
          <div class="nav-child-hline"></div>
          <span class="nav-child-icon">⭐</span>
          <span class="custom-page-badge">Custom</span>
          <span style="flex:1;font-size:.84rem;color:#1e293b">
            ${escH(p.nav_label_th||p.title_th)}
            <span style="color:#94a3b8"> / ${escH(p.nav_label_en||p.title_en)}</span>
          </span>
          <code class="nav-node-href">/p/${p.slug}</code>
          <span class="nav-live-tag">✓ Live</span>
        </div>`).join('')}
      </div>` : '';

    return `
    <div class="nav-tree-node" data-ntab="${tab.id}">
      <div class="nav-node-header" onclick="toggleNavTab('${tab.id}')">
        <div class="nav-node-left">
          <span class="nav-node-icon">${hasKids ? '📂' : '📄'}</span>
          <div class="nav-node-name">
            <input class="nav-label-edit nav-label-th" data-path="${ti}.label_th"
              value="${escH(tab.label_th)}" placeholder="ชื่อไทย" onclick="event.stopPropagation()" />
            <input class="nav-label-edit nav-label-en" data-path="${ti}.label_en"
              value="${escH(tab.label_en)}" placeholder="English" onclick="event.stopPropagation()" />
          </div>
        </div>
        <div class="nav-node-right">
          ${tab.href
            ? `<code class="nav-node-href">${tab.href}</code>`
            : `<span class="nav-dropdown-tag">dropdown</span>`}
          ${hasKids ? `<span class="nav-child-count">${allKids.length} items</span>` : ''}
          <label class="vis-switch" onclick="event.stopPropagation()">
            <input type="checkbox" ${tab.visible?'checked':''} onchange="setNavPath('${ti}.visible',this.checked)" />
            <span class="vis-slider"></span>
          </label>
          ${hasKids ? `<span class="nav-node-chevron">▸</span>` : ''}
        </div>
      </div>
      ${childrenHtml}
    </div>`;
  }).join('');

  treeEl.querySelectorAll('[data-path]').forEach(inp => {
    inp.addEventListener('input', () => setNavPath(inp.dataset.path, inp.value));
  });
}

function toggleNavTab(id) {
  const node = document.querySelector(`[data-ntab="${id}"]`);
  if (!node) return;
  const isExpanded = node.classList.toggle('expanded');
  const children = node.querySelector('.nav-node-children');
  if (children) children.style.display = isExpanded ? 'block' : 'none';
}

function setNavPath(path, value) {
  const parts = path.split('.');
  let obj = navData;
  for (let i = 0; i < parts.length - 1; i++) obj = obj[parts[i]];
  obj[parts[parts.length - 1]] = value;
}

async function saveNav() {
  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/content', {
    method:'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({ page_slug:'global', section_key:'_nav_config',
      content:{ meta:{ nav_items: JSON.stringify(navData) } } }),
  });
  const d = await res.json();
  showSaveBar(res.ok ? '✓ บันทึกแล้ว — nav จะอัปเดตทันที' : '❌ ' + d.error, res.ok ? 'success' : 'error');
}

async function resetNav() {
  if (!confirm('รีเซ็ต nav กลับค่าเริ่มต้น?')) return;
  await fetch('/api/admin/content?page=global&section=_nav_config', { method:'DELETE', credentials:'include' });
  showSaveBar('✓ รีเซ็ตแล้ว', 'success');
  setTimeout(() => location.reload(), 1200);
}

// ── Custom Pages ──────────────────────────────────────────────
let pagesList = [];
let quillTh, quillEn;

function initQuill() {
  const opts = { theme:'snow', modules:{ toolbar:[
    ['bold','italic','underline'],
    [{ header:[2,3,false] }],
    [{ list:'ordered' },{ list:'bullet' }],
    ['link'],['clean']
  ]}};
  quillTh = new Quill('#editor-th', opts);
  quillEn = new Quill('#editor-en', opts);
}

function renderPagesList() {
  const listEl = document.getElementById('pages-list');
  if (!listEl) return;
  pagesList = JSON.parse(listEl.dataset.pages || '[]');

  if (!pagesList.length) {
    listEl.innerHTML = `<div class="empty-state">
      <div class="empty-state-icon">📄</div>
      <div>ยังไม่มีหน้าเว็บ กด "สร้างหน้าใหม่" เพื่อเริ่ม</div>
    </div>`;
    return;
  }
  listEl.innerHTML = pagesList.map(p => `
    <div class="page-row" data-id="${p.id}">
      <div class="page-row-icon">📄</div>
      <div class="page-row-body">
        <div class="page-row-title">${escH(p.title_th)} / ${escH(p.title_en)}</div>
        <div class="page-row-meta">
          /${escH(p.slug)}
          ${p.show_in_nav ? `<span class="nav-badge" style="margin-left:6px">Nav: ${escH(p.nav_parent||'top')}</span>` : ''}
          ${!p.visible ? `<span class="hidden-badge" style="margin-left:6px">ซ่อน</span>` : ''}
        </div>
      </div>
      <div class="page-row-actions">
        <a href="/p/${escH(p.slug)}" target="_blank" class="btn-sm">🌐 ดู</a>
        <button class="btn-sm" onclick="openEditPage('${p.id}')">✏️ แก้ไข</button>
        <button class="btn-sm danger" onclick="deletePage('${p.id}')">🗑️</button>
      </div>
    </div>
  `).join('');
}

function openCreatePage() {
  document.getElementById('modal-title').textContent = 'สร้างหน้าใหม่';
  document.getElementById('edit-id').value = '';
  document.getElementById('f-title-th').value = '';
  document.getElementById('f-title-en').value = '';
  document.getElementById('f-slug').value = '';
  document.getElementById('f-slug').disabled = false;
  quillTh?.setContents([]);
  quillEn?.setContents([]);
  document.getElementById('f-visible').checked = true;
  document.getElementById('f-show-nav').checked = false;
  document.getElementById('f-nav-th').value = '';
  document.getElementById('f-nav-en').value = '';
  document.getElementById('f-nav-parent').value = '';
  document.getElementById('nav-fields').style.display = 'none';
  document.getElementById('page-modal').classList.add('open');
}

function openEditPage(id) {
  const p = pagesList.find(x => x.id === id);
  if (!p) return;
  document.getElementById('modal-title').textContent = 'แก้ไขหน้า';
  document.getElementById('edit-id').value = p.id;
  document.getElementById('f-title-th').value = p.title_th || '';
  document.getElementById('f-title-en').value = p.title_en || '';
  document.getElementById('f-slug').value = p.slug || '';
  document.getElementById('f-slug').disabled = true;
  quillTh?.clipboard.dangerouslyPasteHTML(p.content_th || '');
  quillEn?.clipboard.dangerouslyPasteHTML(p.content_en || '');
  document.getElementById('f-visible').checked = p.visible !== false;
  document.getElementById('f-show-nav').checked = !!p.show_in_nav;
  document.getElementById('f-nav-th').value = p.nav_label_th || '';
  document.getElementById('f-nav-en').value = p.nav_label_en || '';
  document.getElementById('f-nav-parent').value = p.nav_parent || '';
  document.getElementById('nav-fields').style.display = p.show_in_nav ? 'block' : 'none';
  document.getElementById('page-modal').classList.add('open');
}

function closePageModal() {
  document.getElementById('page-modal').classList.remove('open');
}

function toggleNavFields(cb) {
  document.getElementById('nav-fields').style.display = cb.checked ? 'block' : 'none';
}

async function savePage() {
  const id = document.getElementById('edit-id').value;
  const isCreate = !id;
  const slug = document.getElementById('f-slug').value.trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
  const title_th = document.getElementById('f-title-th').value.trim();
  const title_en = document.getElementById('f-title-en').value.trim();
  if (!slug || !title_th || !title_en) { alert('กรุณากรอก slug, ชื่อไทย และชื่ออังกฤษ'); return; }

  const body = {
    ...(id && { id }), slug, title_th, title_en,
    content_th: quillTh?.root.innerHTML || '',
    content_en: quillEn?.root.innerHTML || '',
    visible: document.getElementById('f-visible').checked,
    show_in_nav: document.getElementById('f-show-nav').checked,
    nav_label_th: document.getElementById('f-nav-th').value.trim(),
    nav_label_en: document.getElementById('f-nav-en').value.trim(),
    nav_parent: document.getElementById('f-nav-parent').value,
  };

  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/pages', {
    method: isCreate ? 'POST' : 'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify(body),
  });
  const d = await res.json();
  if (!res.ok) { showSaveBar('❌ ' + d.error, 'error'); return; }

  if (isCreate) pagesList.unshift(d.page);
  else { const idx = pagesList.findIndex(p => p.id === id); if (idx >= 0) pagesList[idx] = d.page; }
  document.getElementById('pages-list').dataset.pages = JSON.stringify(pagesList);
  closePageModal();
  renderPagesList();
  showSaveBar('✓ บันทึกแล้ว', 'success');
}

async function deletePage(id) {
  if (!confirm('ลบหน้านี้? ไม่สามารถกู้คืนได้')) return;
  const res = await fetch(`/api/admin/pages?id=${id}`, { method:'DELETE', credentials:'include' });
  const d = await res.json();
  if (!res.ok) { showSaveBar('❌ ' + d.error, 'error'); return; }
  pagesList = pagesList.filter(p => p.id !== id);
  document.getElementById('pages-list').dataset.pages = JSON.stringify(pagesList);
  renderPagesList();
  showSaveBar('✓ ลบแล้ว', 'success');
}

// ── Utility ───────────────────────────────────────────────────
function escH(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>

<!-- ══ Inline page CMS data + functions ════════════════════════ -->
<script is:inline define:vars={{ navCmsMapJson, cmsPageDefsJson, cmsDefaultThJson, cmsDefaultEnJson }}>
// Data — local to the IIFE so closures below can access them
const _NAV_CMS_MAP  = JSON.parse(navCmsMapJson);
const _CMS_PAGE_DEFS = JSON.parse(cmsPageDefsJson);  // { home:[...sections], global:[...sections] }
const _CMS_DEF_TH   = JSON.parse(cmsDefaultThJson);
const _CMS_DEF_EN   = JSON.parse(cmsDefaultEnJson);

// ── Switch to a page in the sidebar ──────────────────────────
const switchToPage = window.switchToPage = async function(navId) {
  // Deactivate all tabs
  TABS.forEach(t => {
    document.getElementById('panel-' + t)?.classList.remove('active');
    document.querySelector(`[data-tab="${t}"]`)?.classList.remove('active');
  });
  // Activate the clicked sidebar item
  document.querySelectorAll('.cms-page-item').forEach(b => {
    b.classList.toggle('active', b.dataset.page === navId);
  });
  // Show the pagecms panel
  const panel = document.getElementById('panel-pagecms');
  if (panel) panel.classList.add('active');
  history.replaceState(null, '', '#page-' + navId);
  // Render content
  await renderPageCMS(navId);
}

// ── Render inline CMS for a nav ID ───────────────────────────
const renderPageCMS = window.renderPageCMS = async function(navId) {
  const map = _NAV_CMS_MAP[navId];
  const titleEl = document.getElementById('pagecms-title');
  const subEl   = document.getElementById('pagecms-sub');
  const sectEl  = document.getElementById('pagecms-sections');
  if (!titleEl || !sectEl) return;

  titleEl.textContent = map?.title || navId;

  if (!map) {
    subEl.textContent = 'หน้านี้ยังไม่มี CMS — เนื้อหา hard-coded ในโค้ด';
    sectEl.innerHTML = `<div class="cms-no-cms-placeholder">
      <div class="cms-no-cms-placeholder-icon">🚧</div>
      <div style="font-size:1rem;font-weight:600;color:#475569;margin-bottom:8px">ยังไม่มีเนื้อหาที่แก้ไขได้สำหรับหน้านี้</div>
      <div style="font-size:.85rem">หน้านี้ใช้ข้อมูล static — จะเพิ่ม CMS ในอนาคต</div>
    </div>`;
    return;
  }

  subEl.textContent = 'กำลังโหลด...';
  sectEl.innerHTML = '<div style="padding:32px 24px;color:#64748b;font-size:.9rem">⏳ กำลังโหลด...</div>';

  // Fetch current DB overrides (8s timeout — renders defaults if slow)
  let dbSections = {};
  try {
    const ctrl = new AbortController();
    const tid = setTimeout(() => ctrl.abort(), 8000);
    const res = await fetch('/api/admin/page-content?slug=' + encodeURIComponent(map.slug),
      { credentials:'include', signal: ctrl.signal });
    clearTimeout(tid);
    if (res.ok) { const j = await res.json(); dbSections = j.sections || {}; }
  } catch {}

  // Get page section definitions
  const allSections = _CMS_PAGE_DEFS[map.slug] || [];
  const sections = map.filter ? allSections.filter(s => map.filter.includes(s.key)) : allSections;

  if (!sections.length) {
    subEl.textContent = '❌ ไม่พบ section definitions';
    sectEl.innerHTML = '<div class="cms-no-cms-placeholder"><div>ไม่พบ section สำหรับ ' + escH(map.slug) + '</div></div>';
    return;
  }

  subEl.textContent = sections.length + ' sections';
  sectEl.innerHTML = sections.map(sec => renderCMSSection(map.slug, sec, dbSections[sec.key] || null)).join('');
}

// ── Render a single CMS section accordion ────────────────────
const renderCMSSection = window.renderCMSSection = function(pageSlug, sec, dbData) {
  const isCustomized = !!dbData;
  const updatedAt = dbData?.updated_at
    ? new Date(dbData.updated_at).toLocaleDateString('th-TH', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})
    : '';

  const fieldsHtml = (sec.fields || []).map(f => {
    const thVal  = dbData?.th?.[f.key]   || '';
    const enVal  = dbData?.en?.[f.key]   || '';
    const metaVal = dbData?.meta?.[f.key] || '';
    const defTh  = _CMS_DEF_TH[f.key] || '';
    const defEn  = _CMS_DEF_EN[f.key] || '';
    const rows   = (f.type === 'number') ? 1 : 2;

    if (f.bilingual) {
      return `<div class="cms-field cms-field-bilingual" data-key="${f.key}">
        <div class="cms-field-label">${escH(f.label)}</div>
        <div class="cms-field-key-hint">${f.key}</div>
        <div class="cms-field-langs">
          <div class="cms-lang-group">
            <div class="cms-lang-badge cms-lang-th">TH</div>
            <textarea class="cms-textarea" data-lang="th" data-field="${f.key}" rows="${rows}" placeholder="${escH(defTh)}">${escH(thVal)}</textarea>
          </div>
          <div class="cms-lang-group">
            <div class="cms-lang-badge cms-lang-en">EN</div>
            <textarea class="cms-textarea" data-lang="en" data-field="${f.key}" rows="${rows}" placeholder="${escH(defEn)}">${escH(enVal)}</textarea>
          </div>
        </div>
      </div>`;
    } else {
      const val = metaVal || thVal;
      return `<div class="cms-field cms-field-mono" data-key="${f.key}">
        <div class="cms-field-label">${escH(f.label)}</div>
        <div class="cms-field-key-hint">${f.key}</div>
        <div class="cms-field-mono-wrap">
          <textarea class="cms-textarea cms-textarea-full" data-lang="meta" data-field="${f.key}" rows="${rows}" placeholder="${escH(defTh)}">${escH(val)}</textarea>
        </div>
      </div>`;
    }
  }).join('');

  const resetBtn = isCustomized
    ? `<button class="cms-btn cms-btn-ghost" onclick="inlineResetSec('${pageSlug}','${sec.key}')">↺ Reset</button>`
    : '';

  return `
  <div class="cms-section" id="inline-sec-${sec.key}" data-section="${sec.key}" data-slug="${pageSlug}">
    <div class="cms-section-header" onclick="inlineToggleSec('${sec.key}')">
      <div class="cms-section-header-left">
        <span class="cms-section-chevron" id="inline-chev-${sec.key}">▶</span>
        <span class="cms-section-icon">${sec.icon || '📝'}</span>
        <span class="cms-section-label">${escH(sec.label)}</span>
        ${isCustomized ? '<span class="cms-section-badge">แก้ไขแล้ว</span>' : ''}
      </div>
      <div class="cms-section-header-right">
        ${updatedAt ? `<span class="cms-section-date">${updatedAt}</span>` : ''}
      </div>
    </div>
    <div class="cms-section-body" id="inline-body-${sec.key}" style="display:none">
      <div class="cms-fields-grid">${fieldsHtml}</div>
      <div class="cms-section-actions">
        ${resetBtn}
        <button class="cms-btn cms-btn-primary" id="inline-save-${sec.key}"
          onclick="inlineSaveSec('${pageSlug}','${sec.key}')">💾 บันทึก ${escH(sec.label)}</button>
      </div>
    </div>
  </div>`;
}

// ── Toggle section accordion open/closed ─────────────────────
const inlineToggleSec = window.inlineToggleSec = function(key) {
  const body = document.getElementById('inline-body-' + key);
  const chev = document.getElementById('inline-chev-' + key);
  if (!body) return;
  const open = body.style.display === 'none';
  body.style.display = open ? 'block' : 'none';
  const secEl = document.getElementById('inline-sec-' + key);
  if (secEl) secEl.classList.toggle('open', open);
  if (chev) chev.textContent = open ? '▼' : '▶';
}

// ── Save a section ────────────────────────────────────────────
const inlineSaveSec = window.inlineSaveSec = async function(pageSlug, sectionKey) {
  const bodyEl = document.getElementById('inline-body-' + sectionKey);
  if (!bodyEl) return;

  const content = { th: {}, en: {}, meta: {} };
  bodyEl.querySelectorAll('textarea[data-field][data-lang]').forEach(el => {
    const lang  = el.dataset.lang;
    const field = el.dataset.field;
    if (lang && field) content[lang][field] = el.value;
  });

  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/content', {
    method:'PUT', credentials:'include',
    headers:{ 'Content-Type':'application/json' },
    body: JSON.stringify({ page_slug:pageSlug, section_key:sectionKey, content }),
  });
  const d = await res.json();
  showSaveBar(res.ok ? '✓ บันทึกสำเร็จ — ผลจะแสดงบนเว็บทันที' : '❌ ' + d.error, res.ok ? 'success' : 'error');
  if (res.ok) {
    // Mark section as customized
    const badge = document.querySelector(`#inline-sec-${sectionKey} .cms-section-badge`);
    if (!badge) {
      const labelEl = document.querySelector(`#inline-sec-${sectionKey} .cms-section-label`);
      labelEl?.insertAdjacentHTML('afterend', '<span class="cms-section-badge">แก้ไขแล้ว</span>');
    }
  }
}

// ── Reset a section back to defaults ─────────────────────────
const inlineResetSec = window.inlineResetSec = async function(pageSlug, sectionKey) {
  if (!confirm('Reset section นี้กลับเป็นค่าเริ่มต้น?')) return;
  showSaveBar('กำลัง reset...', 'saving');
  const res = await fetch(`/api/admin/content?page=${encodeURIComponent(pageSlug)}&section=${encodeURIComponent(sectionKey)}`, {
    method:'DELETE', credentials:'include',
  });
  if (res.ok) {
    showSaveBar('✓ Reset แล้ว', 'success');
    // Re-render the current page
    const navId = location.hash.replace('#page-', '');
    if (navId) await renderPageCMS(navId);
  } else {
    const d = await res.json();
    showSaveBar('❌ ' + (d.error || 'ไม่สามารถ reset ได้'), 'error');
  }
}
</script>
</body>
</html>
