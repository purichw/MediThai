---
export const prerender = false;
import Layout from '../../components/Layout.astro';
import { createServerSupabase } from '../../lib/supabase-server';

const supabase = createServerSupabase(Astro.request, Astro.cookies);
const statusFilter = Astro.url.searchParams.get('status') || '';

let query = supabase.from('appointments').select('*').order('appointment_date', { ascending: true });
if (statusFilter) query = query.eq('status', statusFilter);
const { data: appointments } = await query;

const statusLabel: Record<string, string> = { pending: 'รอยืนยัน', confirmed: 'ยืนยัน', cancelled: 'ยกเลิก', completed: 'เสร็จ' };
---
<Layout title="จัดการนัดหมาย | Admin">
  <main class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-logo">MediThai Admin</div>
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link">📊 ภาพรวม</a>
        <a href="/admin/appointments" class="admin-nav-link active">📅 นัดหมายทั้งหมด</a>
        <a href="/" class="admin-nav-link">🌐 ดูเว็บ</a>
      </nav>
      <form method="POST" action="/logout" style="margin-top:auto">
        <button type="submit" class="admin-nav-link" style="width:100%;text-align:left;background:none;border:none;cursor:pointer">🚪 ออกจากระบบ</button>
      </form>
    </aside>

    <div class="admin-content">
      <h1 class="admin-page-title">นัดหมายทั้งหมด</h1>

      <div class="filter-tabs" style="margin-bottom:1.5rem">
        {['', 'pending', 'confirmed', 'cancelled', 'completed'].map(s => (
          <a href={s ? `/admin/appointments?status=${s}` : '/admin/appointments'}
             class={`tab-chip ${statusFilter === s ? 'active' : ''}`}>
            {s === '' ? 'ทั้งหมด' : statusLabel[s]}
          </a>
        ))}
      </div>

      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead>
            <tr><th>ผู้ป่วย</th><th>โรงพยาบาล</th><th>แผนก</th><th>วันที่</th><th>เวลา</th><th>สถานะ</th><th>จัดการ</th></tr>
          </thead>
          <tbody>
            {appointments?.map(appt => (
              <tr>
                <td>
                  <div style="font-weight:500">{appt.patient_name}</div>
                  <div style="font-size:.8rem;color:var(--gray-500)">{appt.patient_phone}</div>
                </td>
                <td style="font-size:.9rem">{appt.hospital}</td>
                <td style="font-size:.9rem">{appt.specialty}</td>
                <td style="white-space:nowrap">{new Date(appt.appointment_date).toLocaleDateString('th-TH')}</td>
                <td>{appt.appointment_time}</td>
                <td><span class={`appt-badge appt-badge--${appt.status}`}>{statusLabel[appt.status]}</span></td>
                <td>
                  <a href={`/admin/appointments/${appt.id}`} class="btn btn-sm btn-secondary">จัดการ</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>
