---
export const prerender = false;
import { createAdminSupabase } from '../../../lib/supabase-server';

const supabase = createAdminSupabase();
const { data: pages } = await supabase
  .from('custom_pages')
  .select('*')
  .order('sort_order', { ascending: true });
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>หน้าเว็บ | MediThai Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
  <link rel="stylesheet" href="https://cdn.quilljs.com/1.3.7/quill.snow.css" />
  <style>
    .pages-list { display: flex; flex-direction: column; gap: 10px; max-width: 800px; }
    .page-row { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px;
      padding: 14px 18px; display: flex; align-items: center; gap: 14px; }
    .page-row-icon { font-size: 20px; }
    .page-row-body { flex: 1; }
    .page-row-title { font-weight: 700; font-size: .92rem; color: #1e293b; }
    .page-row-meta { font-size: .75rem; color: #94a3b8; margin-top: 2px; }
    .nav-badge { font-size: .7rem; background: #dcfce7; color: #15803d;
      padding: 2px 7px; border-radius: 4px; }
    .hidden-badge { font-size: .7rem; background: #fee2e2; color: #991b1b;
      padding: 2px 7px; border-radius: 4px; }
    .page-row-actions { display: flex; gap: 8px; }
    .btn-sm { font-size: .78rem; padding: 5px 12px; border-radius: 7px; border: 1px solid #e2e8f0;
      background: #f8fafc; cursor: pointer; transition: background .15s; }
    .btn-sm:hover { background: #f1f5f9; }
    .btn-sm.danger { color: #ef4444; border-color: #fecaca; }
    .btn-sm.danger:hover { background: #fef2f2; }
    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000;
      display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: #fff; border-radius: 16px; width: 760px; max-width: 95vw;
      max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; }
    .modal-header { display: flex; align-items: center; justify-content: space-between;
      padding: 18px 24px; border-bottom: 1px solid #f1f5f9; }
    .modal-title { font-size: 1.1rem; font-weight: 700; }
    .modal-close { font-size: 20px; background: none; border: none; cursor: pointer; color: #94a3b8; }
    .modal-body { padding: 20px 24px; display: flex; flex-direction: column; gap: 16px; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid #f1f5f9; display: flex; gap: 10px; justify-content: flex-end; }
    .field-group { display: flex; flex-direction: column; gap: 6px; }
    .field-label { font-size: .83rem; font-weight: 600; color: #374151; }
    .field-input { border: 1px solid #e2e8f0; border-radius: 8px; padding: 9px 12px; font-size: .9rem; width: 100%; box-sizing: border-box; }
    .field-input:focus { outline: none; border-color: #3b82f6; }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .editor-wrap { border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; }
    .quill-editor { min-height: 180px; }
    .toggle-row { display: flex; align-items: center; gap: 10px; }
    .toggle-label { font-size: .88rem; color: #374151; }
    .vis-switch { position: relative; display: inline-flex; align-items: center; cursor: pointer; }
    .vis-switch input { opacity: 0; width: 0; }
    .vis-slider { width: 40px; height: 22px; background: #e2e8f0; border-radius: 11px;
      display: inline-block; position: relative; transition: background .2s; }
    .vis-slider::after { content: ''; position: absolute; top: 4px; left: 4px;
      width: 14px; height: 14px; border-radius: 50%; background: #fff; transition: transform .2s; }
    .vis-switch input:checked + .vis-slider { background: #22c55e; }
    .vis-switch input:checked + .vis-slider::after { transform: translateX(18px); }
    .nav-parent-select { border: 1px solid #e2e8f0; border-radius: 8px; padding: 9px 12px;
      font-size: .9rem; width: 100%; box-sizing: border-box; }
    .empty-state { text-align: center; padding: 40px 20px; color: #94a3b8; }
    .empty-state-icon { font-size: 40px; margin-bottom: 12px; }
  </style>
</head>
<body>
<div class="cms-shell">
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div><div class="cms-logo-name">MediThai</div><div class="cms-logo-sub">Admin Portal</div></div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">เนื้อหา</div>
      <a href="/admin/cms" class="cms-nav-item"><span class="cms-nav-icon">✏️</span> แก้ไขเนื้อหา</a>
      <a href="/admin/cms/layout" class="cms-nav-item"><span class="cms-nav-icon">⚙️</span> จัดเรียง Sections</a>
      <a href="/admin/cms/components" class="cms-nav-item"><span class="cms-nav-icon">🧩</span> Components</a>
      <a href="/admin/cms/nav" class="cms-nav-item"><span class="cms-nav-icon">🔗</span> Navigation</a>
      <a href="/admin/cms/pages" class="cms-nav-item active"><span class="cms-nav-icon">📄</span> หน้าเว็บ</a>
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item"><span class="cms-nav-icon">🌐</span> ดูเว็บไซต์</a>
    </nav>
  </aside>

  <main class="cms-main">
    <div class="cms-topbar">
      <div class="cms-topbar-left">
        <a href="/admin/cms" class="cms-back-btn">← กลับ</a>
        <div>
          <h1 class="cms-page-title">📄 หน้าเว็บ</h1>
          <p class="cms-page-sub">สร้าง แก้ไข และลบ custom pages — เพิ่มใน nav ได้</p>
        </div>
      </div>
      <button class="cms-btn cms-btn-primary" onclick="openCreate()">+ สร้างหน้าใหม่</button>
    </div>

    <div id="cms-save-bar" class="cms-save-bar" style="display:none">
      <span id="cms-save-msg"></span>
    </div>

    <div class="pages-list" id="pages-list" data-pages={JSON.stringify(pages ?? [])}>
      <!-- Rendered by JS -->
    </div>
  </main>
</div>

<!-- Create/Edit Modal -->
<div class="modal-overlay" id="page-modal">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">สร้างหน้าใหม่</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id" value="" />

      <div class="field-row">
        <div class="field-group">
          <label class="field-label">ชื่อหน้า (ไทย) *</label>
          <input class="field-input" id="f-title-th" placeholder="เช่น โปรโมชัน" />
        </div>
        <div class="field-group">
          <label class="field-label">Page title (English) *</label>
          <input class="field-input" id="f-title-en" placeholder="e.g. Promotions" />
        </div>
      </div>

      <div class="field-group">
        <label class="field-label">URL Slug * <span style="color:#94a3b8;font-weight:400">(a-z, 0-9, - เท่านั้น)</span></label>
        <input class="field-input" id="f-slug" placeholder="promotions" />
      </div>

      <div class="field-group">
        <label class="field-label">เนื้อหา (ภาษาไทย)</label>
        <div class="editor-wrap">
          <div class="quill-editor" id="editor-th"></div>
        </div>
      </div>

      <div class="field-group">
        <label class="field-label">Content (English)</label>
        <div class="editor-wrap">
          <div class="quill-editor" id="editor-en"></div>
        </div>
      </div>

      <div style="border-top:1px solid #f1f5f9;padding-top:16px">
        <div class="field-label" style="margin-bottom:12px">⚙️ ตั้งค่า</div>
        <div class="toggle-row" style="margin-bottom:10px">
          <label class="vis-switch">
            <input type="checkbox" id="f-visible" checked />
            <span class="vis-slider"></span>
          </label>
          <span class="toggle-label">แสดงหน้านี้ (visible)</span>
        </div>
        <div class="toggle-row" style="margin-bottom:10px">
          <label class="vis-switch">
            <input type="checkbox" id="f-show-nav" onchange="toggleNavFields(this)" />
            <span class="vis-slider"></span>
          </label>
          <span class="toggle-label">แสดงใน Navigation</span>
        </div>
        <div id="nav-fields" style="display:none;margin-top:10px">
          <div class="field-row" style="margin-bottom:10px">
            <div class="field-group">
              <label class="field-label">ชื่อใน Nav (ไทย)</label>
              <input class="field-input" id="f-nav-th" placeholder="โปรโมชัน" />
            </div>
            <div class="field-group">
              <label class="field-label">Nav label (English)</label>
              <input class="field-input" id="f-nav-en" placeholder="Promotions" />
            </div>
          </div>
          <div class="field-group">
            <label class="field-label">อยู่ใน menu ไหน</label>
            <select class="nav-parent-select" id="f-nav-parent">
              <option value="">— top-level (แยก tab) —</option>
              <option value="hospitals">โรงพยาบาล</option>
              <option value="services">บริการ</option>
              <option value="packages">แพ็กเกจ</option>
              <option value="health">สุขภาพน่ารู้</option>
              <option value="about">เกี่ยวกับเรา</option>
            </select>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="cms-btn cms-btn-ghost" onclick="closeModal()">ยกเลิก</button>
      <button class="cms-btn cms-btn-primary" onclick="savePage()">💾 บันทึก</button>
    </div>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script is:inline>
const listEl = document.getElementById('pages-list');
let pages = JSON.parse(listEl.dataset.pages);

let quillTh, quillEn;
document.addEventListener('DOMContentLoaded', () => {
  const opts = { theme: 'snow', modules: { toolbar: [
    ['bold','italic','underline'],
    [{ header: [2,3,false] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['link'], ['clean']
  ]}};
  quillTh = new Quill('#editor-th', opts);
  quillEn = new Quill('#editor-en', opts);
});

function renderList() {
  if (!pages.length) {
    listEl.innerHTML = `<div class="empty-state">
      <div class="empty-state-icon">📄</div>
      <div>ยังไม่มีหน้าเว็บ กด "สร้างหน้าใหม่" เพื่อเริ่ม</div>
    </div>`;
    return;
  }
  listEl.innerHTML = pages.map(p => `
    <div class="page-row" data-id="${p.id}">
      <div class="page-row-icon">📄</div>
      <div class="page-row-body">
        <div class="page-row-title">${escH(p.title_th)} / ${escH(p.title_en)}</div>
        <div class="page-row-meta">
          /${escH(p.slug)}
          ${p.show_in_nav ? `<span class="nav-badge" style="margin-left:6px">Nav: ${escH(p.nav_parent || 'top')}</span>` : ''}
          ${!p.visible ? `<span class="hidden-badge" style="margin-left:6px">ซ่อน</span>` : ''}
        </div>
      </div>
      <div class="page-row-actions">
        <a href="/p/${escH(p.slug)}" target="_blank" class="btn-sm">🌐 ดู</a>
        <button class="btn-sm" onclick="openEdit(${JSON.stringify(JSON.stringify(p))})">✏️ แก้ไข</button>
        <button class="btn-sm danger" onclick="deletePage('${p.id}')">🗑️</button>
      </div>
    </div>
  `).join('');
}

function openCreate() {
  document.getElementById('modal-title').textContent = 'สร้างหน้าใหม่';
  document.getElementById('edit-id').value = '';
  document.getElementById('f-title-th').value = '';
  document.getElementById('f-title-en').value = '';
  document.getElementById('f-slug').value = '';
  document.getElementById('f-slug').disabled = false;
  quillTh?.setContents([]);
  quillEn?.setContents([]);
  document.getElementById('f-visible').checked = true;
  document.getElementById('f-show-nav').checked = false;
  document.getElementById('f-nav-th').value = '';
  document.getElementById('f-nav-en').value = '';
  document.getElementById('f-nav-parent').value = '';
  document.getElementById('nav-fields').style.display = 'none';
  document.getElementById('page-modal').classList.add('open');
}

function openEdit(jsonStr) {
  const p = JSON.parse(jsonStr);
  document.getElementById('modal-title').textContent = 'แก้ไขหน้า';
  document.getElementById('edit-id').value = p.id;
  document.getElementById('f-title-th').value = p.title_th || '';
  document.getElementById('f-title-en').value = p.title_en || '';
  document.getElementById('f-slug').value = p.slug || '';
  document.getElementById('f-slug').disabled = true;
  quillTh?.clipboard.dangerouslyPasteHTML(p.content_th || '');
  quillEn?.clipboard.dangerouslyPasteHTML(p.content_en || '');
  document.getElementById('f-visible').checked = p.visible !== false;
  document.getElementById('f-show-nav').checked = !!p.show_in_nav;
  document.getElementById('f-nav-th').value = p.nav_label_th || '';
  document.getElementById('f-nav-en').value = p.nav_label_en || '';
  document.getElementById('f-nav-parent').value = p.nav_parent || '';
  document.getElementById('nav-fields').style.display = p.show_in_nav ? 'block' : 'none';
  document.getElementById('page-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('page-modal').classList.remove('open');
}

function toggleNavFields(cb) {
  document.getElementById('nav-fields').style.display = cb.checked ? 'block' : 'none';
}

async function savePage() {
  const id = document.getElementById('edit-id').value;
  const isCreate = !id;
  const slug = document.getElementById('f-slug').value.trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
  const title_th = document.getElementById('f-title-th').value.trim();
  const title_en = document.getElementById('f-title-en').value.trim();
  if (!slug || !title_th || !title_en) { alert('กรุณากรอก slug, ชื่อไทย และชื่ออังกฤษ'); return; }

  const body = {
    ...(id && { id }),
    slug, title_th, title_en,
    content_th: quillTh?.root.innerHTML || '',
    content_en: quillEn?.root.innerHTML || '',
    visible: document.getElementById('f-visible').checked,
    show_in_nav: document.getElementById('f-show-nav').checked,
    nav_label_th: document.getElementById('f-nav-th').value.trim(),
    nav_label_en: document.getElementById('f-nav-en').value.trim(),
    nav_parent: document.getElementById('f-nav-parent').value,
  };

  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/pages', {
    method: isCreate ? 'POST' : 'PUT',
    credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  const d = await res.json();
  if (!res.ok) { showSaveBar('❌ ' + d.error, 'error'); return; }

  if (isCreate) pages.unshift(d.page);
  else { const idx = pages.findIndex(p => p.id === id); if (idx >= 0) pages[idx] = d.page; }
  closeModal();
  renderList();
  showSaveBar('✓ บันทึกแล้ว', 'success');
}

async function deletePage(id) {
  if (!confirm('ลบหน้านี้? ไม่สามารถกู้คืนได้')) return;
  const res = await fetch(`/api/admin/pages?id=${id}`, { method: 'DELETE', credentials: 'include' });
  const d = await res.json();
  if (!res.ok) { showSaveBar('❌ ' + d.error, 'error'); return; }
  pages = pages.filter(p => p.id !== id);
  renderList();
  showSaveBar('✓ ลบแล้ว', 'success');
}

function escH(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

let saveBarTimer;
function showSaveBar(msg, type) {
  const bar = document.getElementById('cms-save-bar'), m = document.getElementById('cms-save-msg');
  m.textContent = msg; bar.style.display = 'flex';
  bar.className = `cms-save-bar cms-save-bar--${type}`;
  clearTimeout(saveBarTimer);
  if (type !== 'saving') saveBarTimer = setTimeout(() => bar.style.display = 'none', 3500);
}

renderList();
</script>
</body>
</html>
