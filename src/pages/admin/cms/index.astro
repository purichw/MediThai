---
export const prerender = false;
import { createAdminSupabase } from '../../../lib/supabase-server';
import { CMS_PAGES } from '../../../lib/cmsSchema';

const supabase = createAdminSupabase();
const { data: meta } = await supabase
  .from('site_content')
  .select('page_slug, updated_at')
  .order('updated_at', { ascending: false });

const lastModified: Record<string, string> = {};
const sectionCount: Record<string, number> = {};
for (const row of meta ?? []) {
  if (!lastModified[row.page_slug]) lastModified[row.page_slug] = row.updated_at;
  sectionCount[row.page_slug] = (sectionCount[row.page_slug] ?? 0) + 1;
}

const { count: customPagesCount } = await supabase.from('custom_pages').select('*', { count: 'exact', head: true });
const { count: componentsCount } = await supabase.from('page_components').select('*', { count: 'exact', head: true });
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Management | MediThai Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
</head>
<body>
<div class="cms-shell">
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div><div class="cms-logo-name">MediThai</div><div class="cms-logo-sub">Admin Portal</div></div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">จัดการ</div>
      <a href="/admin" class="cms-nav-item"><span class="cms-nav-icon">📊</span> ภาพรวม</a>
      <a href="/admin/appointments" class="cms-nav-item"><span class="cms-nav-icon">📅</span> นัดหมาย</a>
      <a href="/admin/analytics" class="cms-nav-item"><span class="cms-nav-icon">📈</span> Analytics</a>
      <div class="cms-nav-group-label">เนื้อหา</div>
      <a href="/admin/cms" class="cms-nav-item active"><span class="cms-nav-icon">✏️</span> แก้ไขเนื้อหา</a>
      <a href="/admin/cms/layout" class="cms-nav-item"><span class="cms-nav-icon">⚙️</span> จัดเรียง Sections</a>
      <a href="/admin/cms/components" class="cms-nav-item"><span class="cms-nav-icon">🧩</span> Components</a>
      <a href="/admin/cms/nav" class="cms-nav-item"><span class="cms-nav-icon">🔗</span> Navigation</a>
      <a href="/admin/cms/pages" class="cms-nav-item"><span class="cms-nav-icon">📄</span> หน้าเว็บ</a>
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item"><span class="cms-nav-icon">🌐</span> ดูเว็บไซต์</a>
      <form method="POST" action="/logout">
        <button type="submit" class="cms-nav-item cms-nav-logout"><span class="cms-nav-icon">🚪</span> ออกจากระบบ</button>
      </form>
    </nav>
  </aside>

  <main class="cms-main">
    <div class="cms-topbar">
      <div>
        <h1 class="cms-page-title">Content Management</h1>
        <p class="cms-page-sub">แก้ไขเนื้อหา จัดเรียง sections และจัดการหน้าเว็บ</p>
      </div>
    </div>

    <!-- Phase 1: Text/Image editing -->
    <h2 class="cms-section-group-title">✏️ Phase 1 — แก้ไขเนื้อหา</h2>
    <div class="cms-cards-grid">
      {CMS_PAGES.map(page => {
        const modified = lastModified[page.slug];
        const saved = sectionCount[page.slug] ?? 0;
        const total = page.sections.length;
        return (
          <a href={`/admin/cms/${page.slug}`} class="cms-page-card">
            <div class="cms-page-card-icon">{page.icon}</div>
            <div class="cms-page-card-body">
              <div class="cms-page-card-title">{page.label}</div>
              <div class="cms-page-card-desc">{page.description}</div>
              <div class="cms-page-card-meta">
                <span class={`cms-status-badge ${saved > 0 ? 'has-overrides' : 'default'}`}>
                  {saved > 0 ? `${saved}/${total} sections` : 'ค่าเริ่มต้น'}
                </span>
                {modified && <span class="cms-page-card-date">{new Date(modified).toLocaleDateString('th-TH', { day:'numeric', month:'short' })}</span>}
              </div>
            </div>
            <div class="cms-page-card-arrow">→</div>
          </a>
        );
      })}
    </div>

    <!-- Phase 2 + 3 + 4 quick-access -->
    <h2 class="cms-section-group-title" style="margin-top:2rem">⚙️ Phase 2–4 — จัดการโครงสร้าง</h2>
    <div class="cms-cards-grid">
      <a href="/admin/cms/layout" class="cms-page-card">
        <div class="cms-page-card-icon">📐</div>
        <div class="cms-page-card-body">
          <div class="cms-page-card-title">จัดเรียง Sections</div>
          <div class="cms-page-card-desc">ซ่อน/แสดง และเรียงลำดับ sections บนหน้าแรก</div>
          <div class="cms-page-card-meta"><span class="cms-status-badge default">Phase 2</span></div>
        </div>
        <div class="cms-page-card-arrow">→</div>
      </a>
      <a href="/admin/cms/components" class="cms-page-card">
        <div class="cms-page-card-icon">🧩</div>
        <div class="cms-page-card-body">
          <div class="cms-page-card-title">Components</div>
          <div class="cms-page-card-desc">เพิ่ม/แก้ไข/ลบ cards เฉพาะทาง รีวิว quick actions</div>
          <div class="cms-page-card-meta">
            <span class={`cms-status-badge ${componentsCount ? 'has-overrides' : 'default'}`}>
              {componentsCount || 0} components
            </span>
          </div>
        </div>
        <div class="cms-page-card-arrow">→</div>
      </a>
      <a href="/admin/cms/nav" class="cms-page-card">
        <div class="cms-page-card-icon">🔗</div>
        <div class="cms-page-card-body">
          <div class="cms-page-card-title">Navigation</div>
          <div class="cms-page-card-desc">ซ่อน/แสดง nav tabs และ dropdown items</div>
          <div class="cms-page-card-meta"><span class="cms-status-badge default">Phase 3</span></div>
        </div>
        <div class="cms-page-card-arrow">→</div>
      </a>
      <a href="/admin/cms/pages" class="cms-page-card">
        <div class="cms-page-card-icon">📄</div>
        <div class="cms-page-card-body">
          <div class="cms-page-card-title">หน้าเว็บ</div>
          <div class="cms-page-card-desc">สร้าง/แก้ไข/ลบ custom pages และเพิ่มใน nav</div>
          <div class="cms-page-card-meta">
            <span class={`cms-status-badge ${customPagesCount ? 'has-overrides' : 'default'}`}>
              {customPagesCount || 0} หน้า
            </span>
          </div>
        </div>
        <div class="cms-page-card-arrow">→</div>
      </a>
    </div>
  </main>
</div>
</body>
</html>
