---
export const prerender = false;
import { createAdminSupabase } from '../../../lib/supabase-server';
import { CMS_PAGE_MAP, CMS_PAGES } from '../../../lib/cmsSchema';
import { DEFAULT_TH, DEFAULT_EN } from '../../../lib/cmsDefaults';

const { page: pageSlug } = Astro.params;
const pageDef = pageSlug ? CMS_PAGE_MAP[pageSlug] : null;
if (!pageDef) return Astro.redirect('/admin/cms');

// Load existing DB overrides for this page
const supabase = createAdminSupabase();
const { data: rows } = await supabase
  .from('site_content')
  .select('section_key, content, updated_at')
  .eq('page_slug', pageSlug);

// Build section content map
const dbContent: Record<string, { th?: Record<string, string>; en?: Record<string, string>; meta?: Record<string, string>; updated_at?: string }> = {};
for (const row of rows ?? []) {
  dbContent[row.section_key] = { ...row.content, updated_at: row.updated_at };
}

// Helper: get current value for a field
function getVal(sectionKey: string, fieldKey: string, lang: 'th' | 'en' | 'meta'): string {
  return dbContent[sectionKey]?.[lang]?.[fieldKey] ?? '';
}

// Rich-text fields (need Quill editor)
const richTextFields = new Set<string>();
for (const sec of pageDef.sections) {
  for (const f of sec.fields) {
    if (f.type === 'richtext' || f.type === 'html') richTextFields.add(`${sec.key}::${f.key}`);
  }
}
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageDef.label} | Content Management | MediThai Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
  <!-- Quill rich text editor -->
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
</head>
<body>
<div class="cms-shell">
  <!-- Sidebar -->
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div>
          <div class="cms-logo-name">MediThai</div>
          <div class="cms-logo-sub">Admin Portal</div>
        </div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">จัดการ</div>
      <a href="/admin" class="cms-nav-item"><span class="cms-nav-icon">📊</span> ภาพรวม</a>
      <a href="/admin#appointments" class="cms-nav-item"><span class="cms-nav-icon">📅</span> นัดหมาย</a>
      <a href="/admin#analytics" class="cms-nav-item"><span class="cms-nav-icon">📈</span> Analytics</a>
      <div class="cms-nav-group-label">เนื้อหา</div>
      <a href="/admin#content" class="cms-nav-item active"><span class="cms-nav-icon">✏️</span> แก้ไขเนื้อหา</a>
      <div class="cms-nav-group-label">หน้า</div>
      {CMS_PAGES.map(p => (
        <a href={`/admin/cms/${p.slug}`} class={`cms-nav-item cms-nav-page ${p.slug === pageSlug ? 'active' : ''}`}>
          <span class="cms-nav-icon">{p.icon}</span> {p.label}
        </a>
      ))}
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item">
        <span class="cms-nav-icon">🌐</span> ดูเว็บไซต์
      </a>
      <form method="POST" action="/logout">
        <button type="submit" class="cms-nav-item cms-nav-logout">
          <span class="cms-nav-icon">🚪</span> ออกจากระบบ
        </button>
      </form>
    </nav>
  </aside>

  <!-- Main -->
  <main class="cms-main">
    <div class="cms-topbar">
      <div class="cms-topbar-left">
        <a href="/admin#content" class="cms-back-btn">← กลับ</a>
        <div>
          <h1 class="cms-page-title">{pageDef.icon} {pageDef.label}</h1>
          <p class="cms-page-sub">{pageDef.description}</p>
        </div>
      </div>
      <div class="cms-topbar-right">
        <a href="/" target="_blank" class="cms-btn cms-btn-outline">Preview ↗</a>
      </div>
    </div>

    <!-- Save status bar -->
    <div id="cms-save-bar" class="cms-save-bar" style="display:none">
      <span id="cms-save-msg"></span>
    </div>

    <!-- Sections -->
    <div class="cms-sections" id="cms-sections"
      data-page={pageSlug}
      data-rich-keys={JSON.stringify([...richTextFields])}>

      {pageDef.sections.map((section, si) => {
        const sectionDb = dbContent[section.key];
        const isCustomized = !!sectionDb;
        return (
          <div class="cms-section" id={`section-${section.key}`} data-section={section.key}>
            <div class="cms-section-header" onclick={`cmsToggleSection('${section.key}')`}>
              <div class="cms-section-header-left">
                <span class="cms-section-chevron" id={`chevron-${section.key}`}>▶</span>
                <span class="cms-section-icon">{section.icon}</span>
                <span class="cms-section-label">{section.label}</span>
                {isCustomized && <span class="cms-section-badge">แก้ไขแล้ว</span>}
              </div>
              <div class="cms-section-header-right">
                {sectionDb?.updated_at && (
                  <span class="cms-section-date">
                    {new Date(sectionDb.updated_at).toLocaleDateString('th-TH', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  </span>
                )}
              </div>
            </div>

            <div class="cms-section-body" id={`body-${section.key}`} style="display:none">
              <div class="cms-fields-grid">
                {section.fields.map(field => {
                  const thVal = getVal(section.key, field.key, 'th');
                  const enVal = getVal(section.key, field.key, 'en');
                  const metaVal = getVal(section.key, field.key, 'meta');
                  const isRichText = field.type === 'richtext';
                  const isHtml = field.type === 'html';
                  const isImage = field.type === 'image';

                  return (
                    <div class={`cms-field ${field.bilingual ? 'cms-field-bilingual' : 'cms-field-mono'} ${isImage ? 'cms-field-image-type' : ''}`}
                      data-key={field.key} data-type={field.type} data-bilingual={field.bilingual ? 'true' : 'false'}>
                      <div class="cms-field-label">{field.label}</div>
                      <div class="cms-field-key-hint">{field.key}</div>

                      {field.bilingual ? (
                        <div class="cms-field-langs">
                          <div class="cms-lang-group">
                            <div class="cms-lang-badge cms-lang-th">TH</div>
                            {isRichText ? (
                              <div class="cms-quill-wrap">
                                <div class="cms-quill-editor"
                                  id={`quill-th-${section.key}-${field.key}`}
                                  data-lang="th"
                                  data-field={field.key}
                                  set:html={thVal || ''}
                                ></div>
                              </div>
                            ) : isImage ? (
                              <div class="cms-image-field">
                                <input type="url"
                                  class="cms-input cms-input-url"
                                  data-lang="th" data-field={field.key}
                                  value={thVal}
                                  placeholder="https://..." />
                                {thVal && <img class="cms-image-preview" src={thVal} alt="preview" />}
                              </div>
                            ) : (
                              <textarea
                                class="cms-textarea"
                                data-lang="th" data-field={field.key}
                                rows={field.type === 'number' ? 1 : 2}
                                placeholder={DEFAULT_TH[field.key] ?? ''}
                                set:text={thVal}
                              ></textarea>
                            )}
                          </div>
                          <div class="cms-lang-group">
                            <div class="cms-lang-badge cms-lang-en">EN</div>
                            {isRichText ? (
                              <div class="cms-quill-wrap">
                                <div class="cms-quill-editor"
                                  id={`quill-en-${section.key}-${field.key}`}
                                  data-lang="en"
                                  data-field={field.key}
                                  set:html={enVal || ''}
                                ></div>
                              </div>
                            ) : isImage ? (
                              <div class="cms-image-field">
                                <input type="url"
                                  class="cms-input cms-input-url"
                                  data-lang="en" data-field={field.key}
                                  value={enVal}
                                  placeholder="https://..." />
                                {enVal && <img class="cms-image-preview" src={enVal} alt="preview" />}
                              </div>
                            ) : (
                              <textarea
                                class="cms-textarea"
                                data-lang="en" data-field={field.key}
                                rows={field.type === 'number' ? 1 : 2}
                                placeholder={DEFAULT_EN[field.key] ?? ''}
                                set:text={enVal}
                              ></textarea>
                            )}
                          </div>
                        </div>
                      ) : (
                        // Mono field (no bilingual)
                        <div class="cms-field-mono-wrap">
                          {isHtml || isRichText ? (
                            <div class="cms-quill-wrap">
                              <div class="cms-quill-editor"
                                id={`quill-meta-${section.key}-${field.key}`}
                                data-lang="meta"
                                data-field={field.key}
                                set:html={metaVal || thVal || ''}
                              ></div>
                            </div>
                          ) : isImage ? (
                            <div class="cms-image-field">
                              <input type="url"
                                class="cms-input cms-input-url cms-input-full"
                                data-lang="meta" data-field={field.key}
                                value={metaVal || thVal}
                                placeholder="https://..." />
                              {(metaVal || thVal) && (
                                <img class="cms-image-preview cms-image-preview-lg"
                                  src={metaVal || thVal} alt="preview" />
                              )}
                            </div>
                          ) : (
                            <textarea
                              class="cms-textarea cms-textarea-full"
                              data-lang="meta" data-field={field.key}
                              rows={field.type === 'number' ? 1 : 2}
                              placeholder={DEFAULT_TH[field.key] ?? ''}
                              set:text={metaVal || thVal}
                            ></textarea>
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>

              <!-- Section actions -->
              <div class="cms-section-actions">
                {isCustomized && (
                  <button
                    class="cms-btn cms-btn-ghost"
                    onclick={`cmsResetSection('${section.key}')`}
                    title="ลบ overrides ทั้งหมดของ section นี้ กลับสู่ค่าเริ่มต้น"
                  >
                    ↺ Reset เป็นค่าเริ่มต้น
                  </button>
                )}
                <button
                  class="cms-btn cms-btn-primary"
                  onclick={`cmsSaveSection('${section.key}')`}
                  id={`save-btn-${section.key}`}
                >
                  💾 บันทึก {section.label}
                </button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </main>
</div>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js" is:inline></script>
<script src="/js/admin-cms.js" is:inline></script>
</body>
</html>
