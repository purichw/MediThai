---
export const prerender = false;
import { createAdminSupabase } from '../../../lib/supabase-server';

// Default nav structure mirrors Header.astro
const DEFAULT_NAV = [
  { id: 'home', label_th: 'หน้าแรก', label_en: 'Home', href: '/', visible: true, children: [] },
  { id: 'hospitals', label_th: 'โรงพยาบาล', label_en: 'Hospitals', href: null, visible: true, children: [
    { id: 'h-bkk', label_th: 'MediThai กรุงเทพ', label_en: 'MediThai Bangkok', href: '/hospitals/medithai-bangkok', visible: true },
    { id: 'h-heart', label_th: 'MediThai หัวใจ', label_en: 'MediThai Heart', href: '/hospitals/medithai-heart', visible: true },
    { id: 'h-cancer', label_th: 'MediThai มะเร็ง', label_en: 'MediThai Cancer', href: '/hospitals/medithai-cancer', visible: true },
    { id: 'h-spine', label_th: 'MediThai สมองและกระดูก', label_en: 'MediThai Spine', href: '/hospitals/medithai-spine', visible: true },
    { id: 'h-child', label_th: 'MediThai เด็ก', label_en: 'MediThai Children', href: '/hospitals/medithai-children', visible: true },
    { id: 'h-cm', label_th: 'MediThai เชียงใหม่', label_en: 'MediThai Chiang Mai', href: '/hospitals/medithai-chiangmai', visible: true },
  ]},
  { id: 'services', label_th: 'บริการ', label_en: 'Services', href: null, visible: true, children: [
    { id: 's-appt', label_th: 'นัดหมายแพทย์', label_en: 'Book Appointment', href: '/appointments', visible: true },
    { id: 's-tele', label_th: 'พบแพทย์ออนไลน์', label_en: 'Telehealth', href: '/telehealth', visible: true },
    { id: 's-sym', label_th: 'ตรวจสอบอาการ', label_en: 'Symptom Checker', href: '/symptoms', visible: true },
    { id: 's-rec', label_th: 'ขอเวชระเบียน', label_en: 'Medical Records', href: '/medical-records', visible: true },
    { id: 's-bill', label_th: 'ชำระค่าบริการ', label_en: 'Bill Payment', href: '/bill-payment', visible: true },
    { id: 's-exec', label_th: 'Executive Health', label_en: 'Executive Health', href: '/executive-health', visible: true },
  ]},
  { id: 'doctors', label_th: 'แพทย์', label_en: 'Doctors', href: '/doctors', visible: true, children: [] },
  { id: 'packages', label_th: 'แพ็กเกจ', label_en: 'Packages', href: null, visible: true, children: [
    { id: 'p-pkg', label_th: 'แพ็กเกจสุขภาพ', label_en: 'Health Packages', href: '/packages', visible: true },
    { id: 'p-exec', label_th: 'Executive Health', label_en: 'Executive Health', href: '/executive-health', visible: true },
    { id: 'p-card', label_th: 'MediThai Card', label_en: 'MediThai Card', href: '/loyalty', visible: true },
    { id: 'p-corp', label_th: 'บริการองค์กร', label_en: 'Corporate', href: '/corporate', visible: true },
  ]},
  { id: 'health', label_th: 'สุขภาพน่ารู้', label_en: 'Health Info', href: null, visible: true, children: [
    { id: 'hl-lib', label_th: 'คลังความรู้', label_en: 'Health Library', href: '/health-library', visible: true },
    { id: 'hl-sym', label_th: 'ตรวจสอบอาการ', label_en: 'Symptom Checker', href: '/symptoms', visible: true },
    { id: 'hl-calc', label_th: 'โปรแกรมคำนวณ', label_en: 'Calculators', href: '/calculators', visible: true },
    { id: 'hl-story', label_th: 'เรื่องราวผู้ป่วย', label_en: 'Patient Stories', href: '/patient-stories', visible: true },
  ]},
  { id: 'about', label_th: 'เกี่ยวกับเรา', label_en: 'About', href: null, visible: true, children: [
    { id: 'a-about', label_th: 'เกี่ยวกับเรา', label_en: 'About Us', href: '/about', visible: true },
    { id: 'a-expat', label_th: 'Expat Hub', label_en: 'Expat Hub', href: '/expat-hub', visible: true },
    { id: 'a-career', label_th: 'ร่วมงานกับเรา', label_en: 'Careers', href: '/careers', visible: true },
    { id: 'a-give', label_th: 'ร่วมสนับสนุน', label_en: 'Giving', href: '/giving', visible: true },
  ]},
];

// Load saved nav config
const supabase = createAdminSupabase();
const { data: navRow } = await supabase
  .from('site_content')
  .select('content')
  .eq('page_slug', 'global')
  .eq('section_key', '_nav_config')
  .single();

const savedNav = navRow?.content?.meta?.nav_items
  ? JSON.parse(navRow.content.meta.nav_items)
  : DEFAULT_NAV;

// Load custom pages that want to be in nav
const { data: customPages } = await supabase
  .from('custom_pages')
  .select('id, slug, title_th, title_en, nav_label_th, nav_label_en, nav_parent, show_in_nav, visible')
  .eq('show_in_nav', true)
  .eq('visible', true);
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Navigation | MediThai Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
  <style>
    .nav-tree { display: flex; flex-direction: column; gap: 12px; max-width: 700px; }
    .nav-tab { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
    .nav-tab-header { display: flex; align-items: center; gap: 12px; padding: 14px 16px;
      background: #f8fafc; cursor: pointer; }
    .nav-tab-header:hover { background: #f1f5f9; }
    .nav-tab-chevron { color: #94a3b8; transition: transform .2s; }
    .nav-tab.open .nav-tab-chevron { transform: rotate(90deg); }
    .nav-tab-label { flex: 1; font-weight: 700; }
    .nav-tab-body { display: none; padding: 0 16px 16px; }
    .nav-tab.open .nav-tab-body { display: block; }
    .nav-item-row { display: flex; align-items: center; gap: 10px; padding: 8px 0;
      border-bottom: 1px solid #f1f5f9; }
    .nav-item-row:last-child { border-bottom: none; }
    .nav-item-indent { width: 20px; color: #cbd5e1; }
    .nav-item-label { flex: 1; font-size: .88rem; }
    .nav-label-edit { font-size: .8rem; border: 1px solid #e2e8f0; border-radius: 6px;
      padding: 4px 8px; width: 140px; }
    .vis-switch { position: relative; display: inline-flex; align-items: center; cursor: pointer; }
    .vis-switch input { opacity: 0; width: 0; }
    .vis-slider { width: 36px; height: 20px; background: #e2e8f0; border-radius: 10px;
      display: inline-block; position: relative; transition: background .2s; }
    .vis-slider::after { content: ''; position: absolute; top: 3px; left: 3px;
      width: 14px; height: 14px; border-radius: 50%; background: #fff; transition: transform .2s; }
    .vis-switch input:checked + .vis-slider { background: #22c55e; }
    .vis-switch input:checked + .vis-slider::after { transform: translateX(16px); }
    .custom-page-badge { font-size: .7rem; background: #dbeafe; color: #1e40af;
      padding: 2px 6px; border-radius: 4px; }
    .save-nav-bar { display: flex; gap: 12px; margin-top: 24px; }
  </style>
</head>
<body>
<div class="cms-shell">
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div><div class="cms-logo-name">MediThai</div><div class="cms-logo-sub">Admin Portal</div></div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">เนื้อหา</div>
      <a href="/admin/cms" class="cms-nav-item"><span class="cms-nav-icon">✏️</span> แก้ไขเนื้อหา</a>
      <a href="/admin/cms/layout" class="cms-nav-item"><span class="cms-nav-icon">⚙️</span> จัดเรียง Sections</a>
      <a href="/admin/cms/components" class="cms-nav-item"><span class="cms-nav-icon">🧩</span> Components</a>
      <a href="/admin/cms/nav" class="cms-nav-item active"><span class="cms-nav-icon">🔗</span> Navigation</a>
      <a href="/admin/cms/pages" class="cms-nav-item"><span class="cms-nav-icon">📄</span> หน้าเว็บ</a>
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item"><span class="cms-nav-icon">🌐</span> ดูเว็บไซต์</a>
    </nav>
  </aside>

  <main class="cms-main">
    <div class="cms-topbar">
      <div class="cms-topbar-left">
        <a href="/admin/cms" class="cms-back-btn">← กลับ</a>
        <div>
          <h1 class="cms-page-title">🔗 Navigation</h1>
          <p class="cms-page-sub">ซ่อน/แสดง tab และ dropdown items แก้ชื่อ nav</p>
        </div>
      </div>
    </div>

    <div id="cms-save-bar" class="cms-save-bar" style="display:none">
      <span id="cms-save-msg"></span>
    </div>

    <div class="nav-tree" id="nav-tree" data-nav={JSON.stringify(savedNav)} data-custom={JSON.stringify(customPages ?? [])}>
      <!-- Rendered by JS -->
    </div>

    <div class="save-nav-bar">
      <button class="cms-btn cms-btn-primary" onclick="saveNav()">💾 บันทึก Navigation</button>
      <button class="cms-btn cms-btn-ghost" onclick="resetNav()">↺ รีเซ็ต</button>
    </div>

    <div class="cms-info-box" style="margin-top:24px">
      💡 Custom pages ที่เปิด "แสดงใน Nav" จะปรากฏใน dropdown ที่เลือกไว้ ไปจัดการที่
      <a href="/admin/cms/pages">หน้าเว็บ →</a>
    </div>
  </main>
</div>

<script is:inline>
const treeEl = document.getElementById('nav-tree');
let navData = JSON.parse(treeEl.dataset.nav);
const customPages = JSON.parse(treeEl.dataset.custom);

function renderNav() {
  treeEl.innerHTML = navData.map((tab, ti) => `
    <div class="nav-tab ${tab.visible ? 'open' : ''}" data-tab="${tab.id}">
      <div class="nav-tab-header" onclick="toggleTab('${tab.id}')">
        <span class="nav-tab-chevron">▶</span>
        <div class="nav-tab-label">
          <input class="nav-label-edit" data-path="${ti}.label_th" value="${escH(tab.label_th)}" placeholder="ชื่อไทย" onclick="event.stopPropagation()" />
          <input class="nav-label-edit" data-path="${ti}.label_en" value="${escH(tab.label_en)}" placeholder="English" onclick="event.stopPropagation()" style="margin-left:6px" />
        </div>
        ${tab.href ? `<span style="font-size:.75rem;color:#94a3b8">${tab.href}</span>` : ''}
        <label class="vis-switch" onclick="event.stopPropagation()">
          <input type="checkbox" ${tab.visible ? 'checked' : ''} onchange="setPath('${ti}.visible', this.checked)" />
          <span class="vis-slider"></span>
        </label>
      </div>
      ${tab.children && tab.children.length ? `
      <div class="nav-tab-body">
        ${tab.children.map((child, ci) => `
        <div class="nav-item-row">
          <span class="nav-item-indent">└</span>
          <div class="nav-item-label">
            <input class="nav-label-edit" data-path="${ti}.children.${ci}.label_th" value="${escH(child.label_th)}" placeholder="ชื่อไทย" />
            <input class="nav-label-edit" data-path="${ti}.children.${ci}.label_en" value="${escH(child.label_en)}" placeholder="English" style="margin-left:4px" />
            <span style="font-size:.75rem;color:#94a3b8;margin-left:6px">${child.href || ''}</span>
          </div>
          <label class="vis-switch">
            <input type="checkbox" ${child.visible ? 'checked' : ''} onchange="setPath('${ti}.children.${ci}.visible', this.checked)" />
            <span class="vis-slider"></span>
          </label>
        </div>`).join('')}
        ${customPages.filter(p => p.nav_parent === tab.id).map(p => `
        <div class="nav-item-row">
          <span class="nav-item-indent">└</span>
          <div class="nav-item-label">
            <span class="custom-page-badge">Custom</span>
            <span style="margin-left:6px">${escH(p.nav_label_th || p.title_th)} / ${escH(p.nav_label_en || p.title_en)}</span>
            <a href="/admin/cms/pages" style="font-size:.75rem;color:#3b82f6;margin-left:8px">แก้ไข →</a>
          </div>
          <span style="font-size:.75rem;color:#22c55e">✓</span>
        </div>`).join('')}
      </div>` : ''}
    </div>
  `).join('');

  // Sync inputs to navData on change
  treeEl.querySelectorAll('[data-path]').forEach(inp => {
    inp.addEventListener('input', () => setPath(inp.dataset.path, inp.value));
  });
}

function toggleTab(id) {
  document.querySelector(`[data-tab="${id}"]`)?.classList.toggle('open');
}

function setPath(path, value) {
  const parts = path.split('.');
  let obj = navData;
  for (let i = 0; i < parts.length - 1; i++) {
    obj = obj[parts[i]];
  }
  obj[parts[parts.length - 1]] = value;
}

function escH(s) { return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;'); }

async function saveNav() {
  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/content', {
    method: 'PUT', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      page_slug: 'global', section_key: '_nav_config',
      content: { meta: { nav_items: JSON.stringify(navData) } }
    }),
  });
  const d = await res.json();
  showSaveBar(res.ok ? '✓ บันทึกแล้ว — nav จะอัปเดตทันที' : '❌ ' + d.error, res.ok ? 'success' : 'error');
}

async function resetNav() {
  if (!confirm('รีเซ็ต nav กลับค่าเริ่มต้น?')) return;
  await fetch('/api/admin/content?page=global&section=_nav_config', { method: 'DELETE', credentials: 'include' });
  showSaveBar('✓ รีเซ็ตแล้ว', 'success');
  setTimeout(() => location.reload(), 1000);
}

let saveBarTimer;
function showSaveBar(msg, type) {
  const bar = document.getElementById('cms-save-bar'), m = document.getElementById('cms-save-msg');
  m.textContent = msg; bar.style.display = 'flex';
  bar.className = `cms-save-bar cms-save-bar--${type}`;
  clearTimeout(saveBarTimer);
  if (type !== 'saving') saveBarTimer = setTimeout(() => bar.style.display = 'none', 3500);
}

renderNav();
</script>
</body>
</html>
