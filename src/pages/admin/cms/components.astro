---
export const prerender = false;
import { createAdminSupabase } from '../../../lib/supabase-server';

const supabase = createAdminSupabase();
const { data: components } = await supabase
  .from('page_components')
  .select('*')
  .order('section_key')
  .order('sort_order');

const COMP_TYPES = [
  { type: 'specialty_card', label: 'ศูนย์เฉพาะทาง', section: 'specialties', icon: '🏥',
    fields: [
      { key: 'icon', label: 'Icon/Emoji', mono: true },
      { key: 'name', label: 'ชื่อศูนย์', bilingual: true },
      { key: 'desc', label: 'คำอธิบาย', bilingual: true },
      { key: 'href', label: 'ลิงก์ (path)', mono: true },
    ]},
  { type: 'quick_card', label: 'Quick Card (Hero)', section: 'hero', icon: '⚡',
    fields: [
      { key: 'icon', label: 'Icon/Emoji', mono: true },
      { key: 'color', label: 'สี (teal/amber/green/purple)', mono: true },
      { key: 'title', label: 'หัวข้อ', bilingual: true },
      { key: 'desc', label: 'คำอธิบาย', bilingual: true },
      { key: 'href', label: 'ลิงก์ (path)', mono: true },
    ]},
  { type: 'trust_point', label: 'จุดแข็ง (Why MediThai)', section: 'trust', icon: '🏆',
    fields: [
      { key: 'icon', label: 'Icon/Emoji', mono: true },
      { key: 'title', label: 'หัวข้อ', bilingual: true },
      { key: 'desc', label: 'รายละเอียด', bilingual: true },
    ]},
  { type: 'testimonial', label: 'รีวิวผู้ป่วย', section: 'testimonials', icon: '💬',
    fields: [
      { key: 'author', label: 'ชื่อผู้รีวิว', mono: true },
      { key: 'detail', label: 'รายละเอียด (อายุ/แผนก)', bilingual: true },
      { key: 'text', label: 'รีวิว', bilingual: true },
      { key: 'rating', label: 'คะแนน (1-5)', mono: true },
      { key: 'avatar', label: 'ตัวอักษร Avatar', mono: true },
    ]},
  { type: 'stat_counter', label: 'สถิติตัวเลข', section: 'stats', icon: '📊',
    fields: [
      { key: 'number', label: 'ตัวเลข', mono: true },
      { key: 'suffix', label: 'หน่วย (+, K, %, ฯ)', mono: true },
      { key: 'label', label: 'ป้ายกำกับ', bilingual: true },
      { key: 'icon', label: 'Icon/Emoji', mono: true },
    ]},
];

const compTypeMap = Object.fromEntries(COMP_TYPES.map(c => [c.type, c]));
const bySection: Record<string, typeof components> = {};
for (const c of components ?? []) {
  if (!bySection[c.section_key]) bySection[c.section_key] = [];
  bySection[c.section_key]!.push(c);
}
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Components | MediThai Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-cms.css" />
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
  <style>
    .comp-type-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
    .comp-tab { padding: 8px 16px; border-radius: 20px; border: 1.5px solid #e2e8f0;
      cursor: pointer; background: #fff; font-size: .85rem; transition: all .15s; }
    .comp-tab.active { background: var(--primary); color: #fff; border-color: var(--primary); }
    .comp-list { display: flex; flex-direction: column; gap: 12px; }
    .comp-item { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
    .comp-item-header { display: flex; align-items: center; gap: 12px; padding: 14px 16px;
      cursor: pointer; background: #f8fafc; }
    .comp-item-header:hover { background: #f1f5f9; }
    .comp-item-num { font-weight: 700; color: #64748b; min-width: 24px; }
    .comp-item-title { flex: 1; font-weight: 600; }
    .comp-item-actions { display: flex; gap: 8px; }
    .comp-item-body { padding: 16px; border-top: 1px solid #e2e8f0; display: none; }
    .comp-item.open .comp-item-body { display: block; }
    .comp-fields { display: grid; gap: 12px; }
    .comp-field label { display: block; font-size: .8rem; font-weight: 600; color: #64748b; margin-bottom: 4px; }
    .comp-field input, .comp-field textarea {
      width: 100%; border: 1px solid #e2e8f0; border-radius: 8px;
      padding: 8px 12px; font-size: .9rem; outline: none;
      transition: border-color .15s; box-sizing: border-box;
    }
    .comp-field input:focus, .comp-field textarea:focus { border-color: var(--primary); }
    .comp-bilingual { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .lang-tag { font-size: .7rem; padding: 2px 6px; border-radius: 4px; font-weight: 700;
      display: inline-block; margin-bottom: 4px; }
    .lang-th { background: #fef3c7; color: #92400e; }
    .lang-en { background: #dbeafe; color: #1e40af; }
    .visible-toggle { display: flex; align-items: center; gap: 8px; }
    .add-comp-panel { background: #f8fafc; border: 2px dashed #e2e8f0; border-radius: 12px;
      padding: 24px; text-align: center; margin-top: 16px; }
    .add-comp-panel select { padding: 8px 12px; border-radius: 8px; border: 1px solid #e2e8f0;
      font-size: .9rem; margin-right: 8px; }
    .comp-drag-handle { color: #cbd5e1; cursor: grab; font-size: 16px; }
    .visibility-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 6px; }
    .vis-on { background: #22c55e; }
    .vis-off { background: #e2e8f0; }
  </style>
</head>
<body>
<div class="cms-shell">
  <aside class="cms-sidebar">
    <div class="cms-sidebar-header">
      <a href="/admin" class="cms-logo">
        <span class="cms-logo-mark">M</span>
        <div><div class="cms-logo-name">MediThai</div><div class="cms-logo-sub">Admin Portal</div></div>
      </a>
    </div>
    <nav class="cms-nav">
      <div class="cms-nav-group-label">เนื้อหา</div>
      <a href="/admin/cms" class="cms-nav-item"><span class="cms-nav-icon">✏️</span> แก้ไขเนื้อหา</a>
      <a href="/admin/cms/layout" class="cms-nav-item"><span class="cms-nav-icon">⚙️</span> จัดเรียง Sections</a>
      <a href="/admin/cms/components" class="cms-nav-item active"><span class="cms-nav-icon">🧩</span> Components</a>
      <a href="/admin/cms/nav" class="cms-nav-item"><span class="cms-nav-icon">🔗</span> Navigation</a>
      <a href="/admin/cms/pages" class="cms-nav-item"><span class="cms-nav-icon">📄</span> หน้าเว็บ</a>
      <div style="margin-top:auto"></div>
      <a href="/" target="_blank" class="cms-nav-item"><span class="cms-nav-icon">🌐</span> ดูเว็บไซต์</a>
    </nav>
  </aside>

  <main class="cms-main">
    <div class="cms-topbar">
      <div class="cms-topbar-left">
        <a href="/admin/cms" class="cms-back-btn">← กลับ</a>
        <div>
          <h1 class="cms-page-title">🧩 Components</h1>
          <p class="cms-page-sub">เพิ่ม/แก้ไข/ลบ cards ที่แสดงในแต่ละ section</p>
        </div>
      </div>
    </div>

    <div id="cms-save-bar" class="cms-save-bar" style="display:none">
      <span id="cms-save-msg"></span>
    </div>

    <!-- Type filter tabs -->
    <div class="comp-type-tabs">
      <button class="comp-tab active" onclick="filterType('all', this)">ทั้งหมด ({(components ?? []).length})</button>
      {COMP_TYPES.map(ct => (
        <button class="comp-tab" onclick={`filterType('${ct.type}', this)`}>
          {ct.icon} {ct.label} ({(bySection[ct.section] ?? []).filter(c => c.comp_type === ct.type).length})
        </button>
      ))}
    </div>

    <!-- Component list -->
    <div id="comp-list" class="comp-list" data-comps={JSON.stringify(components ?? [])} data-types={JSON.stringify(COMP_TYPES)}>
      <!-- Rendered by JS -->
    </div>

    <!-- Add new -->
    <div class="add-comp-panel">
      <p style="color:#64748b;margin-bottom:12px">เพิ่ม component ใหม่</p>
      <select id="new-comp-type">
        {COMP_TYPES.map(ct => <option value={ct.type}>{ct.icon} {ct.label}</option>)}
      </select>
      <button class="cms-btn cms-btn-primary" onclick="addComponent()">+ เพิ่ม</button>
    </div>
  </main>
</div>

<script is:inline>
const ALL_COMPS = JSON.parse(document.getElementById('comp-list').dataset.comps);
const COMP_TYPES = JSON.parse(document.getElementById('comp-list').dataset.types);
const typeMap = Object.fromEntries(COMP_TYPES.map(t => [t.type, t]));
let currentFilter = 'all';
let localComps = [...ALL_COMPS];

function renderList() {
  const list = document.getElementById('comp-list');
  const filtered = currentFilter === 'all' ? localComps : localComps.filter(c => c.comp_type === currentFilter);

  if (filtered.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8">ยังไม่มี components — กดเพิ่มด้านล่าง</div>';
    return;
  }

  list.innerHTML = filtered.map((comp, idx) => {
    const typeDef = typeMap[comp.comp_type] || { label: comp.comp_type, icon: '🔲', fields: [] };
    const nameVal = comp.content?.name_th || comp.content?.title_th || comp.content?.author || comp.comp_type;
    return `
    <div class="comp-item" id="comp-${comp.id}" data-id="${comp.id}">
      <div class="comp-item-header" onclick="toggleComp('${comp.id}')">
        <span class="comp-drag-handle">⣿</span>
        <span class="comp-item-num">${idx + 1}</span>
        <span class="visibility-dot ${comp.visible ? 'vis-on' : 'vis-off'}"></span>
        <span style="font-size:18px">${typeDef.icon}</span>
        <div class="comp-item-title">
          <div>${nameVal || '(ไม่มีชื่อ)'}</div>
          <div style="font-size:.75rem;color:#94a3b8">${typeDef.label}</div>
        </div>
        <div class="comp-item-actions" onclick="event.stopPropagation()">
          <button class="cms-btn cms-btn-sm cms-btn-ghost" onclick="toggleVisible('${comp.id}', ${comp.visible})">${comp.visible ? '👁️' : '👁️‍🗨️'}</button>
          <button class="cms-btn cms-btn-sm cms-btn-ghost" style="color:#ef4444" onclick="deleteComp('${comp.id}')">🗑️</button>
        </div>
      </div>
      <div class="comp-item-body">
        ${renderFields(comp, typeDef)}
        <div style="display:flex;gap:8px;margin-top:16px">
          <button class="cms-btn cms-btn-primary" onclick="saveComp('${comp.id}')">💾 บันทึก</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function renderFields(comp, typeDef) {
  return typeDef.fields.map(f => {
    if (f.bilingual) {
      const thVal = comp.content[f.key + '_th'] || '';
      const enVal = comp.content[f.key + '_en'] || '';
      return `<div class="comp-field">
        <label>${f.label}</label>
        <div class="comp-bilingual">
          <div><span class="lang-tag lang-th">TH</span>
            <input type="text" data-field="${f.key}_th" value="${escHtml(thVal)}" placeholder="ภาษาไทย" /></div>
          <div><span class="lang-tag lang-en">EN</span>
            <input type="text" data-field="${f.key}_en" value="${escHtml(enVal)}" placeholder="English" /></div>
        </div></div>`;
    } else {
      const val = comp.content[f.key] || '';
      return `<div class="comp-field">
        <label>${f.label}</label>
        <input type="text" data-field="${f.key}" value="${escHtml(val)}" /></div>`;
    }
  }).join('');
}

function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

function toggleComp(id) {
  const el = document.getElementById('comp-' + id);
  el?.classList.toggle('open');
}

function filterType(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.comp-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}

async function saveComp(id) {
  const el = document.getElementById('comp-' + id);
  const inputs = el.querySelectorAll('[data-field]');
  const content = {};
  inputs.forEach(inp => { content[inp.dataset.field] = inp.value; });
  showSaveBar('กำลังบันทึก...', 'saving');
  const res = await fetch('/api/admin/components', {
    method: 'PUT', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, content }),
  });
  const d = await res.json();
  if (res.ok) {
    const i = localComps.findIndex(c => c.id === id);
    if (i >= 0) localComps[i] = d;
    showSaveBar('✓ บันทึกสำเร็จ', 'success');
    renderList();
  } else showSaveBar('❌ ' + d.error, 'error');
}

async function toggleVisible(id, current) {
  const res = await fetch('/api/admin/components', {
    method: 'PUT', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, visible: !current }),
  });
  const d = await res.json();
  if (res.ok) {
    const i = localComps.findIndex(c => c.id === id);
    if (i >= 0) localComps[i] = d;
    renderList();
  }
}

async function deleteComp(id) {
  if (!confirm('ลบ component นี้?')) return;
  const res = await fetch(`/api/admin/components?id=${id}`, { method: 'DELETE', credentials: 'include' });
  if (res.ok) {
    localComps = localComps.filter(c => c.id !== id);
    showSaveBar('✓ ลบแล้ว', 'success');
    renderList();
  }
}

async function addComponent() {
  const compType = document.getElementById('new-comp-type').value;
  const typeDef = typeMap[compType];
  showSaveBar('กำลังสร้าง...', 'saving');
  const res = await fetch('/api/admin/components', {
    method: 'POST', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      page_slug: 'home',
      section_key: typeDef.section,
      comp_type: compType,
      sort_order: localComps.filter(c => c.comp_type === compType).length,
    }),
  });
  const d = await res.json();
  if (res.ok) {
    localComps.push(d);
    currentFilter = compType;
    document.querySelectorAll('.comp-tab').forEach(b => b.classList.remove('active'));
    showSaveBar('✓ สร้างแล้ว — กรอกข้อมูลแล้วกดบันทึก', 'success');
    renderList();
    // Open the new item
    setTimeout(() => document.getElementById('comp-' + d.id)?.classList.add('open'), 100);
  } else showSaveBar('❌ ' + d.error, 'error');
}

let saveBarTimer;
function showSaveBar(msg, type) {
  const bar = document.getElementById('cms-save-bar');
  const m = document.getElementById('cms-save-msg');
  m.textContent = msg;
  bar.style.display = 'flex';
  bar.className = `cms-save-bar cms-save-bar--${type}`;
  clearTimeout(saveBarTimer);
  if (type !== 'saving') saveBarTimer = setTimeout(() => bar.style.display = 'none', 3500);
}

renderList();
</script>
</body>
</html>
