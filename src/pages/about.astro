---
export const prerender = false;
import Layout from '../components/Layout.astro';
import { Icon } from 'astro-icon/components';
import { makePageCms } from '../lib/cmsPage';

const cms = await makePageCms('about');

// ── Hero ──
const heroTitle = cms.t('hero', 'pg_title', 'เกี่ยวกับ MediThai', 'About MediThai');
const heroDesc  = cms.t('hero', 'pg_desc', '25 ปีแห่งความไว้วางใจ มาตรฐานระดับนานาชาติ', '25 years of trust, international medical standards');

// ── Intro ──
const introTag     = cms.t('intro', 'tag', 'เกี่ยวกับเรา', 'About Us');
const introHeading = cms.t('intro', 'heading', 'ดูแลทุกชีวิต ด้วยความเชี่ยวชาญระดับโลกมากว่า 25 ปี', 'Caring for every life with world-class expertise for over 25 years');
const introPara1   = cms.t('intro', 'para1', 'เครือโรงพยาบาล MediThai ก่อตั้งในปี พ.ศ. 2544 โดยกลุ่มแพทย์และนักธุรกิจที่มีวิสัยทัศน์ในการยกระดับมาตรฐานการแพทย์ไทยสู่ระดับโลก', 'The MediThai Hospital Network was founded in 2001 by a group of doctors and entrepreneurs with a vision to elevate Thai medicine to world standards.');
const introPara2   = cms.t('intro', 'para2', 'ปัจจุบันเรามี 6 โรงพยาบาลเฉพาะทางทั่วประเทศ ทีมแพทย์กว่า 200 ท่าน และให้การดูแลผู้ป่วยมากกว่า 50,000 รายต่อปี โดยได้รับการรับรองมาตรฐาน JCI และ HA', 'Today we operate 6 specialized hospitals nationwide with over 200 doctors, caring for more than 50,000 patients per year, accredited by JCI and HA.');
const stats = cms.items('intro', 'stats').map((it, i) => ({
  num: it.num, suffix: it.suffix || '',
  label: cms.li('intro', 'stats', i, 'label', it),
}));

// ── Vision / Mission / Values ──
const vmvHeading = cms.t('vmv', 'heading', 'วิสัยทัศน์ พันธกิจ และค่านิยม', 'Vision, Mission and Values');
const vmvVision  = cms.t('vmv', 'vision', '"เป็นเครือโรงพยาบาลชั้นนำระดับเอเชีย ที่ผู้คนทุกคนสามารถเข้าถึงการรักษาที่ดีที่สุดได้"', '"To be Asia\'s leading hospital network where everyone can access the best care."');
const vmvMission = cms.t('vmv', 'mission', 'ให้บริการทางการแพทย์ที่ได้มาตรฐานสูงสุด ด้วยเทคโนโลยีที่ทันสมัย ทีมแพทย์ผู้เชี่ยวชาญ และความใส่ใจผู้ป่วยอย่างแท้จริง', 'Deliver medical services of the highest standard with modern technology, expert doctors, and genuine patient care.');
const vmvValues  = cms.items('vmv', 'values').map((it, i) => cms.li('vmv', 'values', i, 'text', it));

// ── Mission cards ──
const mcTag     = cms.t('mission_cards', 'tag', 'พันธกิจของเรา', 'Our Mission');
const mcHeading = cms.t('mission_cards', 'heading', 'ดูแลคุณในทุกมิติของสุขภาพ', 'Caring for every dimension of your health');
const missionCards = cms.items('mission_cards', 'cards').map((it, i) => ({
  icon: it.icon || 'circle-check',
  title: cms.li('mission_cards', 'cards', i, 'title', it),
  desc:  cms.li('mission_cards', 'cards', i, 'desc', it),
}));

// ── Timeline ──
const tlTag     = cms.t('timeline', 'tag', 'ประวัติความเป็นมา', 'Our History');
const tlHeading = cms.t('timeline', 'heading', '25 ปีแห่งการเติบโต', '25 Years of Growth');
const timeline = cms.items('timeline', 'items').map((it, i) => ({
  year: it.year,
  title: cms.li('timeline', 'items', i, 'title', it),
  desc:  cms.li('timeline', 'items', i, 'desc', it),
}));

// ── Accreditations ──
const acTag     = cms.t('accreditations', 'tag', 'รางวัลและการรับรอง', 'Awards & Accreditations');
const acHeading = cms.t('accreditations', 'heading', 'มาตรฐานที่ได้รับการรับรอง', 'Certified Standards');
const accreds = cms.items('accreditations', 'items').map((it, i) => ({
  emoji: it.emoji, title: it.title,
  desc: cms.li('accreditations', 'items', i, 'desc', it),
}));

// ── Leadership ──
const ldTag     = cms.t('leadership', 'tag', 'ทีมผู้บริหาร', 'Leadership Team');
const ldHeading = cms.t('leadership', 'heading', 'ผู้นำเครือโรงพยาบาล MediThai', 'Leaders of the MediThai Network');
const leaders = cms.items('leadership', 'people').map((it, i) => ({
  photo: it.photo || '',
  name: cms.li('leadership', 'people', i, 'name', it),
  role: cms.li('leadership', 'people', i, 'role', it),
}));
const LEAD_COLORS = [
  ['#EFF6FF', '#DBEAFE', '#2554A0'],
  ['#F0FDF4', '#DCFCE7', '#16A34A'],
  ['#FFF7ED', '#FFEDD5', '#D97706'],
  ['#FDF4FF', '#F5D0FE', '#9333EA'],
];

const cmsScript = cms.script();
---
<Layout title="เกี่ยวกับเรา | MediThai Hospital Network" description="25 ปีแห่งความไว้วางใจ มาตรฐานระดับนานาชาติ"
  extraHead={`${cmsScript}
    <style>
    .timeline{position:relative;padding-left:32px;}
    .timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--primary),var(--secondary));}
    .timeline-item{position:relative;margin-bottom:36px;}
    .timeline-item::before{content:'';position:absolute;left:-38px;top:4px;width:12px;height:12px;border-radius:50%;background:var(--secondary);border:3px solid #fff;box-shadow:0 0 0 3px var(--secondary);}
    .timeline-year{font-family:var(--font-heading);font-size:.8rem;font-weight:700;color:var(--secondary);letter-spacing:.08em;margin-bottom:4px;}
    .timeline-title{font-size:.95rem;font-weight:600;color:var(--gray-800);margin-bottom:4px;}
    .timeline-desc{font-size:.82rem;color:var(--gray-500);line-height:1.7;}
    .accred-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
    @media(max-width:760px){.accred-grid{grid-template-columns:repeat(2,1fr);}}
    .accred-card{background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:24px 20px;text-align:center;box-shadow:var(--shadow-sm);}
    .accred-icon{font-size:2.8rem;margin-bottom:10px;}
    .accred-card h4{font-size:.85rem;font-weight:700;color:var(--primary);margin-bottom:4px;}
    .accred-card p{font-size:.75rem;color:var(--gray-500);}
    .team-photo-img{width:100%;height:100%;object-fit:cover;}
    </style>
  `}
>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">หน้าแรก</a><Icon name="fa6-solid:chevron-right" /><span data-i18n={heroTitle.k}>{heroTitle.th}</span></div>
    <h1 data-i18n={heroTitle.k}>{heroTitle.th}</h1>
    <p data-i18n={heroDesc.k} set:html={heroDesc.th}></p>
  </div>
</section>

<!-- Intro -->
<section class="section-pad">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div class="reveal-left">
        <div class="tag"><Icon name="fa6-solid:circle-info" /> <span data-i18n={introTag.k}>{introTag.th}</span></div>
        <h2 class="section-heading" data-i18n={introHeading.k}>{introHeading.th}</h2>
        <p style="color:var(--gray-600);line-height:1.9;margin-bottom:20px" data-i18n={introPara1.k} set:html={introPara1.th}></p>
        <p style="color:var(--gray-600);line-height:1.9;margin-bottom:24px" data-i18n={introPara2.k} set:html={introPara2.th}></p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          {stats.map(s => (
            <div style="background:var(--gray-50);padding:16px;border-radius:var(--radius);text-align:center">
              <div style="font-family:var(--font-heading);font-size:2rem;font-weight:700;color:var(--primary)" data-target={s.num} data-suffix={s.suffix}>0</div>
              <div style="font-size:.8rem;color:var(--gray-500)" data-i18n={s.label.k}>{s.label.th}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="reveal-right" style="background:linear-gradient(135deg,var(--primary),var(--secondary));border-radius:var(--radius-xl);padding:40px;color:#fff">
        <h3 style="font-size:1.1rem;margin-bottom:24px;font-weight:600" data-i18n={vmvHeading.k}>{vmvHeading.th}</h3>
        <div style="margin-bottom:20px">
          <div style="font-size:.75rem;font-weight:700;color:rgba(255,255,255,.6);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">วิสัยทัศน์</div>
          <p style="color:rgba(255,255,255,.9);font-size:.9rem;line-height:1.7" data-i18n={vmvVision.k} set:html={vmvVision.th}></p>
        </div>
        <div style="margin-bottom:20px">
          <div style="font-size:.75rem;font-weight:700;color:rgba(255,255,255,.6);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">พันธกิจ</div>
          <p style="color:rgba(255,255,255,.9);font-size:.9rem;line-height:1.7" data-i18n={vmvMission.k} set:html={vmvMission.th}></p>
        </div>
        <div>
          <div style="font-size:.75rem;font-weight:700;color:rgba(255,255,255,.6);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px">ค่านิยม</div>
          <div style="display:flex;flex-direction:column;gap:8px">
            {vmvValues.map(v => (
              <div style="display:flex;gap:8px;align-items:center;font-size:.85rem;color:rgba(255,255,255,.85)"><Icon name="fa6-solid:check" style="color:var(--accent)" /> <span data-i18n={v.k}>{v.th}</span></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mission -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="text-center reveal" style="margin-bottom:48px">
      <div class="tag"><Icon name="fa6-solid:bullseye" /> <span data-i18n={mcTag.k}>{mcTag.th}</span></div>
      <h2 class="section-heading" data-i18n={mcHeading.k}>{mcHeading.th}</h2>
    </div>
    <div class="mission-grid">
      {missionCards.map((c, i) => (
        <div class={`mission-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
          <div class="mission-icon"><Icon name={`fa6-solid:${c.icon}`} /></div>
          <h3 data-i18n={c.title.k}>{c.title.th}</h3>
          <p data-i18n={c.desc.k}>{c.desc.th}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- History Timeline + Accreditations -->
<section class="section-pad">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start">
      <div>
        <div class="tag reveal"><Icon name="fa6-solid:clock-rotate-left" /> <span data-i18n={tlTag.k}>{tlTag.th}</span></div>
        <h2 class="section-heading reveal" data-i18n={tlHeading.k}>{tlHeading.th}</h2>
        <div class="timeline reveal" style="margin-top:32px">
          {timeline.map(item => (
            <div class="timeline-item">
              <div class="timeline-year">{item.year}</div>
              <div class="timeline-title" data-i18n={item.title.k}>{item.title.th}</div>
              <div class="timeline-desc" data-i18n={item.desc.k}>{item.desc.th}</div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div class="tag reveal"><Icon name="fa6-solid:award" /> <span data-i18n={acTag.k}>{acTag.th}</span></div>
        <h2 class="section-heading reveal" data-i18n={acHeading.k}>{acHeading.th}</h2>
        <div class="accred-grid reveal" style="margin-top:32px">
          {accreds.map(a => (
            <div class="accred-card"><div class="accred-icon">{a.emoji}</div><h4>{a.title}</h4><p data-i18n={a.desc.k}>{a.desc.th}</p></div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Leadership -->
<section class="section-pad" style="background:var(--gray-50)">
  <div class="container">
    <div class="text-center reveal" style="margin-bottom:48px">
      <div class="tag"><Icon name="fa6-solid:people-group" /> <span data-i18n={ldTag.k}>{ldTag.th}</span></div>
      <h2 class="section-heading" data-i18n={ldHeading.k}>{ldHeading.th}</h2>
    </div>
    <div class="team-grid">
      {leaders.map((p, i) => {
        const [bg1, bg2, fg] = LEAD_COLORS[i % LEAD_COLORS.length];
        return (
          <div class={`team-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
            <div class="team-photo">
              {p.photo
                ? <img class="team-photo-img" src={p.photo} alt={p.name.th} />
                : <div style={`width:100%;height:100%;background:linear-gradient(135deg,${bg1},${bg2});display:flex;align-items:center;justify-content:center;font-size:3rem`}><Icon name="fa6-solid:user-tie" style={`color:${fg}`} /></div>
              }
            </div>
            <h4 data-i18n={p.name.k}>{p.name.th}</h4>
            <p data-i18n={p.role.k}>{p.role.th}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

</Layout>
