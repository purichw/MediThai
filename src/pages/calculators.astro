        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:24px">ประมาณการวันไข่ตก ช่วงมีโอกาสตั้งครรภ์ และวันทดสอบการตั้งครรภ์</p>
        <div class="form-group">
          <label>วันแรกที่เพิ่งมีประจำเดือน</label>
          <input type="date" id="ov-last" onchange="calcOvulation()" />
        </div>
        <div class="form-group">
          <label>ระยะเวลารอบเดือน (วัน) — ปกติ 28 วัน</label>
          <select id="ov-cycle" class="filter-select" style="width:100%;height:48px" onchange="calcOvulation()">
            {Array.from({length:16}, (_,i) => i+23).map(d => `<option value="${d}"${d===28?' selected':''}>${d} วัน</option>`).join('')}
          </select>
        </div>
        <div style="background:var(--gray-50);border-radius:12px;padding:16px;font-size:.8rem;color:var(--gray-600)">
          <strong>วิธีคำนวณ:</strong> วันไข่ตก = วันแรกของรอบถัดไป − 14 วัน
        </div>
      </div>
      <div class="calc-result-section" id="ov-result">
        <div style="text-align:center;opacity:.6;padding:40px 0">
          <Icon name="fa6-solid:calendar-days" style="font-size:3rem;margin-bottom:12px" />
          <p>เลือกวันที่ประจำเดือนมาล่าสุดเพื่อดูผล</p>
        </div>
      </div>
    </div>

    <!-- ===== Age Calculator ===== -->
    <div class="calc-panel" id="panel-age">
      <div class="calc-input-section">
        <h2 style="font-size:1.2rem;font-weight:700;color:var(--primary);margin-bottom:8px">คำนวณอายุ</h2>
        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:24px">คำนวณอายุละเอียดระดับปี เดือน วัน ชั่วโมง พร้อมนับถอยหลังวันเกิด</p>
        <div class="form-group">
          <label>วันเกิด (วัน/เดือน/ปี ค.ศ.)</label>
          <input type="date" id="age-dob" onchange="calcAge()" />
        </div>
        <div class="form-group">
          <label>คำนวณถึงวันที่ (ค่าเริ่มต้น = วันนี้)</label>
          <input type="date" id="age-todate" onchange="calcAge()" />
        </div>
        <div style="background:var(--gray-50);border-radius:12px;padding:16px;font-size:.8rem;color:var(--gray-600)">
          💡 สามารถใช้คำนวณระยะห่างระหว่างวันสองวันใดก็ได้ ไม่ใช่แค่อายุ
        </div>
      </div>
      <div class="calc-result-section" id="age-result">
        <div style="text-align:center;opacity:.6;padding:40px 0">
          <Icon name="fa6-solid:cake-candles" style="font-size:3rem;margin-bottom:12px" />
          <p>เลือกวันเกิดเพื่อดูผล</p>
        </div>
      </div>
    </div>

    <!-- ===== Percentage Calculator ===== -->
    <div class="calc-panel" id="panel-percent">
      <div class="calc-input-section">
        <h2 style="font-size:1.2rem;font-weight:700;color:var(--primary);margin-bottom:8px">คำนวณเปอร์เซ็นต์</h2>
        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:16px">คำนวณเปอร์เซ็นต์ 4 แบบที่ใช้บ่อยในชีวิตประจำวัน</p>
        <!-- Mode buttons -->
        <div class="pct-mode-tabs">
          <button class="pct-mode-btn active" data-pct="1" onclick="showPctMode('1')">X% ของ Y</button>
          <button class="pct-mode-btn" data-pct="2" onclick="showPctMode('2')">A คิดเป็นกี่ % ของ B</button>
          <button class="pct-mode-btn" data-pct="3" onclick="showPctMode('3')">เพิ่ม/ลด X%</button>
          <button class="pct-mode-btn" data-pct="4" onclick="showPctMode('4')">ความแตกต่าง %</button>
        </div>
        <!-- Mode 1: X% of Y -->
        <div class="pct-section active" id="pct-1">
          <div class="form-row">
            <div class="form-group"><label>เปอร์เซ็นต์ (X)</label><input type="number" id="pct1-x" placeholder="เช่น 20" oninput="calcPct1()" /></div>
            <div class="form-group"><label>จำนวน (Y)</label><input type="number" id="pct1-y" placeholder="เช่น 500" oninput="calcPct1()" /></div>
          </div>
          <p style="font-size:.85rem;color:var(--gray-500)">→ X% ของ Y = ?</p>
        </div>
        <!-- Mode 2: A is what % of B -->
        <div class="pct-section" id="pct-2">
          <div class="form-row">
            <div class="form-group"><label>ค่า A</label><input type="number" id="pct2-a" placeholder="เช่น 75" oninput="calcPct2()" /></div>
            <div class="form-group"><label>ค่า B (ฐาน)</label><input type="number" id="pct2-b" placeholder="เช่น 300" oninput="calcPct2()" /></div>
          </div>
          <p style="font-size:.85rem;color:var(--gray-500)">→ A คิดเป็นกี่ % ของ B?</p>
        </div>
        <!-- Mode 3: Percentage change -->
        <div class="pct-section" id="pct-3">
          <div class="form-group"><label>ค่าเริ่มต้น</label><input type="number" id="pct3-val" placeholder="เช่น 1000" oninput="calcPct3()" /></div>
          <div class="form-row">
            <div class="form-group">
              <label>เพิ่ม / ลด</label>
              <select id="pct3-dir" class="filter-select" style="width:100%;height:48px" onchange="calcPct3()">
                <option value="inc">เพิ่ม</option><option value="dec">ลด</option>
              </select>
            </div>
            <div class="form-group"><label>เปอร์เซ็นต์ (%)</label><input type="number" id="pct3-pct" placeholder="เช่น 15" oninput="calcPct3()" /></div>
          </div>
        </div>
        <!-- Mode 4: Percentage difference -->
        <div class="pct-section" id="pct-4">
          <div class="form-row">
            <div class="form-group"><label>ค่า A</label><input type="number" id="pct4-a" placeholder="เช่น 80" oninput="calcPct4()" /></div>
            <div class="form-group"><label>ค่า B</label><input type="number" id="pct4-b" placeholder="เช่น 100" oninput="calcPct4()" /></div>
          </div>
          <p style="font-size:.85rem;color:var(--gray-500)">→ A กับ B ต่างกันกี่ %?</p>
        </div>
      </div>
      <div class="calc-result-section" id="pct-result">
        <div style="text-align:center;opacity:.6;padding:40px 0">
          <Icon name="fa6-solid:percent" style="font-size:3rem;margin-bottom:12px" />
          <p>กรอกตัวเลขเพื่อดูผล</p>
        </div>
      </div>
    </div>

    <!-- ===== Calorie Table ===== -->
    <div class="calc-panel" id="panel-calories" style="grid-template-columns:1fr">
      <div class="calc-input-section">
        <h2 style="font-size:1.2rem;font-weight:700;color:var(--primary);margin-bottom:8px">ตารางแคลอรี่อาหารไทย</h2>
        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:20px">ค่าพลังงาน (กิโลแคลอรี่) ของอาหารไทยที่พบบ่อย — 45+ รายการ</p>
        <input type="text" id="food-search" class="search-food" placeholder="ค้นหาอาหาร... เช่น ข้าว, ไก่, ผัก, ขนม" />
        <div style="overflow-x:auto">
          <table class="food-table">
            <thead><tr><th>อาหาร / ปริมาณ</th><th>แคลอรี่ (kcal)</th><th>หมวด</th></tr></thead>
            <tbody id="food-tbody"></tbody>
          </table>
        </div>
        <p style="font-size:.75rem;color:var(--gray-400);margin-top:12px">* ค่าประมาณการ อาจแตกต่างตามวิธีปรุงและแหล่งที่มา</p>
      </div>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="section-pad-sm" style="background:var(--primary);color:#fff;text-align:center">
  <div class="container">
    <h2 style="margin-bottom:12px">ต้องการคำแนะนำจากผู้เชี่ยวชาญ?</h2>
    <p style="opacity:.8;margin-bottom:24px">โปรแกรมคำนวณเป็นเพียงเครื่องมือเบื้องต้น — พบแพทย์และนักโภชนากรเพื่อแผนสุขภาพที่เหมาะกับคุณโดยเฉพาะ</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/appointments" class="btn btn-accent"><Icon name="fa6-solid:calendar-check" /> นัดหมายแพทย์</a>
      <a href="/telehealth" class="btn btn-outline" style="color:#fff;border-color:rgba(255,255,255,.5)"><Icon name="fa6-solid:video" /> ปรึกษาออนไลน์</a>
    </div>
  </div>
</section>

</Layout>
