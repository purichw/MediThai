          <Icon name={t.icon} /> {t.label}
        </button>
      ))}
    </div>

    <!-- ===== BMI ===== -->
    <div class="calc-panel" id="panel-bmi">
      <div class="calc-input-section">
        <h2 style="font-size:1.2rem;font-weight:700;color:var(--primary);margin-bottom:8px">คำนวณ BMI</h2>
        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:24px">Body Mass Index — ดัชนีมวลกาย ใช้ประเมินภาวะน้ำหนักเบื้องต้น</p>
        <div class="form-row">
          <div class="form-group">
            <label>เพศ</label>
            <select id="bmi-gender" class="filter-select" style="width:100%;height:48px" onchange="calcBMI()">
              <option value="m">ชาย</option><option value="f">หญิง</option>
            </select>
          </div>
          <div class="form-group"><label>อายุ (ปี)</label><input type="number" id="bmi-age" placeholder="เช่น 30" min="5" max="120" oninput="calcBMI()" /></div>
        </div>
        <div class="form-group">
          <label>น้ำหนัก (กิโลกรัม)</label>
          <input type="number" id="bmi-weight" placeholder="เช่น 65" min="20" max="300" oninput="calcBMI()" />
        </div>
        <div class="form-group">
          <label>ส่วนสูง (เซนติเมตร)</label>
          <input type="number" id="bmi-height" placeholder="เช่น 170" min="100" max="250" oninput="calcBMI()" />
