        { id:'tdee',      icon:'fa6-solid:bolt',                label:'TDEE' },
        { id:'bodyfat',   icon:'fa6-solid:circle-half-stroke',  label:'ไขมันในร่างกาย' },
        { id:'water',     icon:'fa6-solid:droplet',             label:'น้ำที่ควรดื่ม' },
        { id:'ovulation', icon:'fa6-solid:calendar-days',       label:'วันไข่ตก' },
        { id:'age',       icon:'fa6-solid:cake-candles',        label:'คำนวณอายุ' },
        { id:'percent',   icon:'fa6-solid:percent',             label:'เปอร์เซ็นต์' },
        { id:'calories',  icon:'fa6-solid:utensils',            label:'ตารางแคลอรี่' },
