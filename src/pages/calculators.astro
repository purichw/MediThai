    ['เค้กช็อกโกแลต 1 ชิ้น (100g)', '371', 'ขนม'],
    ['มันฝรั่งทอด 1 ถุงเล็ก (27g)', '149', 'ขนม'],
    ['บัวลอยน้ำกะทิ 1 ถ้วย', '280', 'ขนม'],
    ['ลอดช่อง 1 ถ้วย', '180', 'ขนม'],
  ];

  function renderFoodTable(filter) {
    const tbody = document.getElementById('food-tbody');
    const q = filter.toLowerCase();
    const rows = foodData.filter(f => !q || f[0].toLowerCase().includes(q) || f[2].includes(q));
    tbody.innerHTML = rows.map(f =>
      '<tr><td>' + f[0] + '</td><td style="font-weight:700;color:var(--primary)">' + f[1] + '</td><td>' +
      '<span style="background:var(--secondary)15;color:var(--secondary);padding:2px 8px;border-radius:20px;font-size:.75rem">' + f[2] + '</span></td></tr>'
    ).join('') || '<tr><td colspan="3" style="text-align:center;color:var(--gray-400);padding:24px">ไม่พบรายการที่ค้นหา</td></tr>';
  }

  document.addEventListener('DOMContentLoaded', () => {
    showCalc('bmi');
    renderFoodTable('');
    // Set today as default for age calculator
    const today = new Date().toISOString().split('T')[0];
    const todayEl = document.getElementById('age-todate');
    if (todayEl) todayEl.value = today;
    document.getElementById('food-search').addEventListener('input', e => renderFoodTable(e.target.value));
  });
  </script>`}
